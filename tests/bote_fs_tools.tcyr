# bote_fs_tools.tcyr — unit tests for src/fs_tools.cyr.
#
# Covers the pure, tricky logic without touching the filesystem:
#   - _fs_path_unsafe  (traversal / absolute / empty guard)
#   - _fs_unescape     (JSON string escapes incl. \uXXXX -> UTF-8)
#   - fs_tools_register (handlers land on the dispatcher)
#   - fs_write_handler refuses an unsafe path (guard runs before any I/O)
# Run: cyrius test tests/bote_fs_tools.tcyr

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fs.cyr"
include "lib/hashmap.cyr"
include "lib/bayan.cyr"
include "lib/fnptr.cyr"
include "lib/chrono.cyr"
include "lib/tagged.cyr"
include "lib/freelist.cyr"
include "lib/thread.cyr"
include "lib/thread_local.cyr"
include "lib/sakshi.cyr"
include "lib/assert.cyr"

include "src/error.cyr"
include "src/protocol.cyr"
include "src/jsonx.cyr"
include "src/registry.cyr"
include "src/prompts.cyr"
include "src/events.cyr"
include "src/audit.cyr"
include "src/dispatch.cyr"
include "src/schema.cyr"
include "src/fs_tools.cyr"

fn main() {
    alloc_init();

    # ---------------- path safety ----------------
    assert_eq(_fs_path_unsafe("src/main.py"), 0, "relative path is safe");
    assert_eq(_fs_path_unsafe("a/b/c.txt"),   0, "nested relative path is safe");
    assert_eq(_fs_path_unsafe(""),            1, "empty path refused");
    assert_eq(_fs_path_unsafe("/etc/passwd"), 1, "absolute path refused");
    assert_eq(_fs_path_unsafe(".."),          1, "bare .. refused");
    assert_eq(_fs_path_unsafe("../escape"),   1, "leading .. refused");
    assert_eq(_fs_path_unsafe("a/../b"),      1, "embedded .. refused");
    assert_eq(_fs_path_unsafe(0),             1, "null path refused");

    # ---------------- JSON unescape ----------------
    var ls[8];

    store64(&ls, 0);
    var d1 = _fs_unescape("hello", &ls);
    assert_eq(load64(&ls), 5, "plain string length");
    assert_eq(load8(d1), 104, "plain string first byte 'h'");

    store64(&ls, 0);
    var d2 = _fs_unescape("a\\nb", &ls);           # a \ n b -> a <LF> b
    assert_eq(load64(&ls), 3, "\\n decodes to one byte");
    assert_eq(load8(d2 + 1), 10, "\\n -> newline (0x0a)");

    store64(&ls, 0);
    var d3 = _fs_unescape("x\\ty", &ls);           # x \ t y -> x <TAB> y
    assert_eq(load8(d3 + 1), 9, "\\t -> tab (0x09)");

    store64(&ls, 0);
    var d4 = _fs_unescape("a\\\\b", &ls);          # a \ \ b -> a \ b
    assert_eq(load64(&ls), 3, "\\\\ decodes to one backslash");
    assert_eq(load8(d4 + 1), 92, "\\\\ -> backslash (0x5c)");

    store64(&ls, 0);
    var d5 = _fs_unescape("a\\\"b", &ls);          # a \ " b -> a " b
    assert_eq(load8(d5 + 1), 34, "\\\" -> double-quote (0x22)");

    store64(&ls, 0);
    var d6 = _fs_unescape("\\u0041", &ls);         # A -> 'A'
    assert_eq(load64(&ls), 1, "\\u0041 decodes to one byte");
    assert_eq(load8(d6), 65, "\\u0041 -> 'A' (0x41)");

    store64(&ls, 0);
    var d7 = _fs_unescape("\\u00e9", &ls);         # é -> 0xC3 0xA9 (2-byte UTF-8)
    assert_eq(load64(&ls), 2, "\\u00e9 -> 2 UTF-8 bytes");
    assert_eq(load8(d7),     195, "\\u00e9 lead byte 0xC3");
    assert_eq(load8(d7 + 1), 169, "\\u00e9 cont byte 0xA9");

    # ---------------- registration ----------------
    var reg = tool_registry_new();
    var disp = dispatcher_new(reg);
    fs_tools_register(disp);
    assert_eq(map_has(dispatcher_handlers(disp), "fs_write"), 1, "fs_write registered");
    assert_eq(map_has(dispatcher_handlers(disp), "fs_read"),  1, "fs_read registered");
    assert_eq(map_has(dispatcher_handlers(disp), "fs_mkdir"), 1, "fs_mkdir registered");

    # ---------------- handler guard (no I/O on refusal) ----------------
    var refused = fs_write_handler("{\"path\":\"../evil\",\"content\":\"x\"}", 0);
    assert(refused != 0, "unsafe write returns a result");
    assert_eq(load8(refused), 123, "result is a JSON object (starts with '{')");

    return assert_summary();
}

var rc = main();
syscall(SYS_EXIT, rc);
