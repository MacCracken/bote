# bote_host.tcyr — unit tests for src/host.cyr (HostRegistry + SSRF guard).
#
# Split out of bote.tcyr for the cyrius 4.5.1 parser identifier-buffer
# cap — same pattern as bote_content / bote_libro_tools.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/fnptr.cyr"
include "lib/assert.cyr"

# 2.7.1: hot-reload parser piggybacks on jsonx for whitespace /
# string / struct skipping — same surface bote uses everywhere else
# for JSON-ish handling.
include "src/jsonx.cyr"
include "src/host.cyr"

fn main() {
    alloc_init();

    # ================================================================
    # HostEntry
    # ================================================================
    var e = host_entry_new("github", "https://api.github.com");
    assert(streq(host_entry_name(e), "github") == 1, "entry name");
    assert(streq(host_entry_url(e), "https://api.github.com") == 1, "entry url");
    assert_eq(host_entry_headers(e), 0, "no default headers");
    assert_eq(host_entry_capabilities(e), 0, "no default capabilities");
    # No-caps means every cap is allowed (fail-open by design; a caller
    # that wants allowlist semantics supplies an explicit vec).
    assert_eq(host_entry_allows(e, "fetch"), 1, "no caps → anything allowed");

    # With capabilities set, enforcement kicks in
    var caps = vec_new();
    vec_push(caps, "fetch");
    vec_push(caps, "resource_link");
    host_entry_with_capabilities(e, caps);
    assert_eq(host_entry_allows(e, "fetch"), 1, "fetch allowed");
    assert_eq(host_entry_allows(e, "resource_link"), 1, "resource_link allowed");
    assert_eq(host_entry_allows(e, "tools/call"), 0, "tools/call denied");

    # Headers pass-through
    var hdrs = vec_new();
    vec_push(hdrs, "Authorization");
    vec_push(hdrs, "Bearer xxx");
    host_entry_with_headers(e, hdrs);
    assert_eq(host_entry_headers(e), hdrs, "headers wired");

    # ================================================================
    # HostRegistry
    # ================================================================
    var r = host_registry_new();
    assert_eq(host_registry_count(r), 0, "registry starts empty");

    host_registry_add(r, e);
    assert_eq(host_registry_count(r), 1, "count after add");
    assert_eq(host_registry_has(r, "github"), 1, "has github");
    assert_eq(host_registry_has(r, "missing"), 0, "does not have missing");

    var got = host_registry_get(r, "github");
    assert_eq(got, e, "get returns same entry ptr");

    # Replacement doesn't double-count
    var e2 = host_entry_new("github", "https://api.github.com/v3");
    host_registry_add(r, e2);
    assert_eq(host_registry_count(r), 1, "count stable on replace");
    assert(streq(host_entry_url(host_registry_get(r, "github")), "https://api.github.com/v3") == 1,
           "replacement url visible");

    # Second distinct entry bumps count
    var e3 = host_entry_new("gitlab", "https://gitlab.com");
    host_registry_add(r, e3);
    assert_eq(host_registry_count(r), 2, "count=2");
    var names = host_registry_names(r);
    assert_eq(vec_len(names), 2, "names vec has 2");

    # ================================================================
    # SSRF guard — public IPs pass
    # ================================================================
    assert_eq(ssrf_check("https://api.github.com/foo"), SSRF_OK, "public DNS OK");
    assert_eq(ssrf_check("https://1.1.1.1/"), SSRF_OK, "1.1.1.1 OK");
    assert_eq(ssrf_check("https://8.8.8.8"), SSRF_OK, "8.8.8.8 OK");
    assert_eq(ssrf_check("http://example.com:8080/path?x=1"), SSRF_OK, "port + query OK");
    assert_eq(ssrf_check("https://user:pass@example.com/x"), SSRF_OK, "userinfo stripped");

    # Scheme gate — only http/https
    assert_eq(ssrf_check("file:///etc/passwd"), SSRF_SCHEME, "file:// rejected");
    assert_eq(ssrf_check("gopher://h.x/"), SSRF_SCHEME, "gopher rejected");
    assert_eq(ssrf_check("ftp://h.x/"), SSRF_SCHEME, "ftp rejected");

    # IPv4 blocklist
    assert_eq(ssrf_check("http://127.0.0.1/"), SSRF_LOOPBACK, "loopback blocked");
    assert_eq(ssrf_check("http://127.255.255.254/"), SSRF_LOOPBACK, "loopback /8 blocked");
    assert_eq(ssrf_check("http://10.0.0.1/"), SSRF_PRIVATE, "10/8 blocked");
    assert_eq(ssrf_check("http://192.168.1.1/"), SSRF_PRIVATE, "192.168/16 blocked");
    assert_eq(ssrf_check("http://172.16.5.4/"), SSRF_PRIVATE, "172.16/12 blocked");
    assert_eq(ssrf_check("http://172.31.255.255/"), SSRF_PRIVATE, "172.31 blocked");
    # Edge: 172.15 is public
    assert_eq(ssrf_check("http://172.15.0.1/"), SSRF_OK, "172.15 OK");
    assert_eq(ssrf_check("http://172.32.0.1/"), SSRF_OK, "172.32 OK");
    # Link-local + metadata
    assert_eq(ssrf_check("http://169.254.169.254/"), SSRF_METADATA, "AWS/GCP metadata blocked");
    assert_eq(ssrf_check("http://169.254.1.1/"), SSRF_METADATA, "169.254/16 blocked");
    # Unspecified
    assert_eq(ssrf_check("http://0.0.0.0/"), SSRF_UNSPEC, "0.0.0.0 blocked");
    # Multicast
    assert_eq(ssrf_check("http://224.0.0.1/"), SSRF_MULTICAST, "multicast blocked");

    # Hostname blocklist
    assert_eq(ssrf_check("http://localhost/"), SSRF_LOOPBACK, "localhost blocked");
    assert_eq(ssrf_check("HTTP://LocalHost/x"), SSRF_LOOPBACK, "localhost case-insensitive");
    assert_eq(ssrf_check("http://metadata.google.internal/"), SSRF_METADATA, "gcp metadata hostname");
    assert_eq(ssrf_check("http://metadata/"), SSRF_METADATA, "bare metadata hostname");

    # Null / malformed input
    assert_eq(ssrf_check(0), SSRF_PARSE, "null url");
    assert_eq(ssrf_check("not-a-url"), SSRF_SCHEME, "no scheme");
    assert_eq(ssrf_check("http:///"), SSRF_PARSE, "empty host");

    # Convenience wrapper
    assert_eq(ssrf_is_safe("https://api.github.com"), 1, "is_safe public");
    assert_eq(ssrf_is_safe("http://127.0.0.1"), 0, "is_safe loopback");

    # ---------------- IPv6 (1.9.1) ----------------
    # Bracket form parses + classifies
    assert_eq(ssrf_check("http://[::1]/"), SSRF_LOOPBACK, "::1 loopback");
    assert_eq(ssrf_check("http://[::1]:8080/x"), SSRF_LOOPBACK, "::1 with port");
    assert_eq(ssrf_check("http://[::]/"), SSRF_UNSPEC, ":: unspec");
    assert_eq(ssrf_check("http://[fe80::1]/"), SSRF_LINK_LOCAL, "fe80:: link-local");
    assert_eq(ssrf_check("http://[fc00::1]/"), SSRF_PRIVATE, "fc00:: ULA private");
    assert_eq(ssrf_check("http://[fd12:3456:789a::1]/"), SSRF_PRIVATE, "fd ULA private");
    assert_eq(ssrf_check("http://[ff02::1]/"), SSRF_MULTICAST, "ff multicast");
    # Public IPv6 passes
    assert_eq(ssrf_check("http://[2606:4700:4700::1111]/"), SSRF_OK, "1.1.1.1 v6 OK");
    # Malformed bracket
    assert_eq(ssrf_check("http://[::1/"), SSRF_PARSE, "missing closing bracket");

    # ---------------- 1.9.5 audit fixes — SSRF bypasses ----------------
    # C1: integer-form IPv4 (2130706433 == 127.0.0.1)
    assert(ssrf_check("http://2130706433/") != SSRF_OK, "integer IPv4 blocked");
    # C2: octal IPv4 — leading-zero multi-digit octets rejected
    assert(ssrf_check("http://0177.0.0.1/") != SSRF_OK, "octal IPv4 blocked");
    assert(ssrf_check("http://0010.0.0.1/") != SSRF_OK, "octal-looking IPv4 blocked");
    # Canonical decimal still passes / blocks correctly
    assert_eq(ssrf_check("http://10.0.0.1/"), SSRF_PRIVATE, "canonical 10.* private");
    assert_eq(ssrf_check("http://1.2.3.4/"), SSRF_OK, "canonical public OK");
    # Short-form IPv4 (e.g. `127.1`) — only 1 dot, classifier rejects
    assert(ssrf_check("http://127.1/") != SSRF_OK, "short-form 127.1 blocked");
    # All-digit hostname (no dots) — also blocked at hostname classifier
    assert(ssrf_check("http://2130706433/") != SSRF_OK, "all-digit hostname blocked");
    # C3: IPv4-mapped IPv6
    assert(ssrf_check("http://[::ffff:127.0.0.1]/") != SSRF_OK, "::ffff:127.0.0.1 blocked");
    assert(ssrf_check("http://[::ffff:7f00:1]/") != SSRF_OK, "::ffff hex form blocked");
    # IPv4-compatible IPv6 (deprecated but defense in depth)
    assert(ssrf_check("http://[::127.0.0.1]/") != SSRF_OK, "::127.0.0.1 blocked");
    # NAT64 well-known prefix
    assert(ssrf_check("http://[64:ff9b::1.2.3.4]/") != SSRF_OK, "NAT64 prefix blocked");

    # ================================================================
    # 2.7.1 — HostRegistry hot-reload (JSON config)
    # ================================================================
    var ej_min = host_entry_from_json("{\"name\":\"a\",\"url\":\"https://a.example\"}");
    assert(ej_min != 0, "from_json minimal entry");
    assert(streq(host_entry_name(ej_min), "a") == 1, "from_json name");
    assert(streq(host_entry_url(ej_min), "https://a.example") == 1, "from_json url");
    assert_eq(host_entry_capabilities(ej_min), 0, "from_json no caps");

    # With capabilities array
    var caps_json = "{\"name\":\"b\",\"url\":\"https://b.example\",\"capabilities\":[\"fetch\",\"tools_call\"]}";
    var ej_caps = host_entry_from_json(caps_json);
    assert(ej_caps != 0, "from_json with caps");
    var caps_v = host_entry_capabilities(ej_caps);
    assert(caps_v != 0, "caps vec present");
    assert_eq(vec_len(caps_v), 2, "2 capabilities");
    var cap0 = vec_get(caps_v, 0);
    var cap1 = vec_get(caps_v, 1);
    assert(streq(cap0, "fetch") == 1, "cap idx0 is fetch");
    assert(streq(cap1, "tools_call") == 1, "cap idx1 is tools_call");
    assert_eq(host_entry_allows(ej_caps, "fetch"), 1, "from_json caps allows fetch");
    assert_eq(host_entry_allows(ej_caps, "delete"), 0, "from_json caps rejects unlisted");

    # Empty capabilities array = explicit allowlist of nothing
    var empty_caps_json = "{\"name\":\"c\",\"url\":\"https://c.example\",\"capabilities\":[]}";
    var ej_empty = host_entry_from_json(empty_caps_json);
    assert(ej_empty != 0, "from_json empty caps array");
    assert(host_entry_capabilities(ej_empty) != 0, "empty caps still allocates vec");
    assert_eq(vec_len(host_entry_capabilities(ej_empty)), 0, "empty caps len 0");
    assert_eq(host_entry_allows(ej_empty, "fetch"), 0, "empty caps rejects all");

    # Rejections
    assert_eq(host_entry_from_json(0), 0, "from_json null");
    assert_eq(host_entry_from_json("not an object"), 0, "from_json non-object");
    assert_eq(host_entry_from_json("{\"url\":\"https://x\"}"), 0, "from_json missing name");
    assert_eq(host_entry_from_json("{\"name\":\"x\"}"), 0, "from_json missing url");

    # ---------------- host_registry_load_json ----------------
    var two_entry_json = "[{\"name\":\"alpha\",\"url\":\"https://a.example\"},{\"name\":\"beta\",\"url\":\"https://b.example\",\"capabilities\":[\"fetch\"]}]";
    var rj = host_registry_load_json(two_entry_json);
    assert(rj != 0, "load_json 2-entry array");
    assert_eq(host_registry_count(rj), 2, "load_json count 2");
    assert_eq(host_registry_has(rj, "alpha"), 1, "alpha present");
    assert_eq(host_registry_has(rj, "beta"), 1, "beta present");
    var bx = host_registry_get(rj, "beta");
    assert(streq(host_entry_url(bx), "https://b.example") == 1, "beta url roundtrip");
    assert_eq(host_entry_allows(bx, "fetch"), 1, "beta allows fetch");

    # Empty array → empty registry (legal, not an error)
    var rj_empty = host_registry_load_json("[]");
    assert(rj_empty != 0, "load_json empty array OK");
    assert_eq(host_registry_count(rj_empty), 0, "empty registry count 0");

    # Parse failures → 0
    assert_eq(host_registry_load_json(0), 0, "load_json null");
    assert_eq(host_registry_load_json("not json"), 0, "load_json non-array");
    assert_eq(host_registry_load_json("[{\"name\":\"x\"}]"), 0, "load_json malformed entry");

    # ---------------- host_registry_load_from_file ----------------
    var tmp_path = "/tmp/bote_host_test.json";
    var cfg_v1 = "[{\"name\":\"svc-1\",\"url\":\"https://svc1.example\"}]";
    file_write_all(tmp_path, cfg_v1, strlen(cfg_v1));
    var rf = host_registry_load_from_file(tmp_path);
    assert(rf != 0, "load_from_file v1");
    assert_eq(host_registry_count(rf), 1, "v1 count 1");
    assert_eq(host_registry_has(rf, "svc-1"), 1, "v1 has svc-1");

    # ---------------- host_registry_reload ----------------
    var cfg_v2 = "[{\"name\":\"svc-2\",\"url\":\"https://svc2.example\"},{\"name\":\"svc-3\",\"url\":\"https://svc3.example\",\"capabilities\":[\"fetch\"]}]";
    file_write_all(tmp_path, cfg_v2, strlen(cfg_v2));
    var rc_reload = host_registry_reload(rf, tmp_path);
    assert_eq(rc_reload, 0, "reload returns 0 on success");
    assert_eq(host_registry_count(rf), 2, "post-reload count 2");
    assert_eq(host_registry_has(rf, "svc-1"), 0, "v1 entry gone after reload");
    assert_eq(host_registry_has(rf, "svc-2"), 1, "v2 entry present");
    assert_eq(host_registry_has(rf, "svc-3"), 1, "v3 entry present");

    # Malformed reload → -1, registry unchanged (fail-safe)
    var bad = "this is not json";
    file_write_all(tmp_path, bad, strlen(bad));
    assert_eq(host_registry_reload(rf, tmp_path), 0 - 1, "reload -1 on parse error");
    assert_eq(host_registry_count(rf), 2, "registry unchanged after failed reload");
    assert_eq(host_registry_has(rf, "svc-2"), 1, "svc-2 still present after failed reload");

    # Missing file → -1
    assert_eq(host_registry_reload(rf, "/tmp/does_not_exist_bote.json"), 0 - 1,
              "reload -1 on missing file");

    # Null args reject
    assert_eq(host_registry_reload(0, tmp_path), 0 - 1, "reload null registry");
    assert_eq(host_registry_reload(rf, 0), 0 - 1, "reload null path");

    # ---------------- host_registry_clear ----------------
    host_registry_clear(rf);
    assert_eq(host_registry_count(rf), 0, "clear empties count");
    assert_eq(host_registry_has(rf, "svc-2"), 0, "clear removes entries");

    return assert_summary();
}

var rc = main();
syscall(SYS_EXIT, rc);
