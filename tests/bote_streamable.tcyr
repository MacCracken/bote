# bote_streamable.tcyr — Streamable HTTP / SSE transport data layer
# (EventIdGenerator + StreamEvent + ResumptionBuffer + StreamableConfig)
#
# Run: cyrius test tests/bote_streamable.tcyr
#
# 2.7.2: extracted from tests/bote.tcyr to fit under the cyrius 5.10.x
# 2 MB compile-source cap. Reconsolidates on cyrius 5.11.x migration.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/bayan.cyr"
include "lib/fnptr.cyr"
include "lib/chrono.cyr"
include "lib/tagged.cyr"
include "lib/net.cyr"
include "lib/async.cyr"
include "lib/fdlopen.cyr"
include "lib/tls.cyr"
include "lib/sandhi.cyr"
include "lib/freelist.cyr"
include "lib/thread.cyr"
include "lib/thread_local.cyr"  # sigil 3.7.14 TLS crypto_scratch — SIGILL guard
include "lib/sakshi.cyr"
include "lib/sigil.cyr"
include "lib/patra.cyr"
include "lib/libro.cyr"
include "lib/majra.cyr"
include "lib/assert.cyr"

include "src/error.cyr"
include "src/protocol.cyr"
include "src/jsonx.cyr"
include "src/registry.cyr"
include "src/prompts.cyr"
include "src/resources.cyr"
include "src/events.cyr"
include "src/audit.cyr"
include "src/audit_libro.cyr"
include "src/events_majra.cyr"
include "src/dispatch.cyr"
include "src/codec.cyr"
include "src/schema.cyr"
include "src/stream.cyr"
include "src/session.cyr"
include "src/auth.cyr"
include "src/transport_streamable.cyr"

# Minimal tool handler for the notify-sink full-path test.
fn _n_handler(args, claims) { return "{}"; }

fn main() {
    alloc_init();
    fl_init();

    # ---------------- EventIdGenerator ----------------
    var gen = event_id_gen_new();
    var id0 = event_id_gen_next(gen);
    var id1 = event_id_gen_next(gen);
    var id2 = event_id_gen_next(gen);
    assert(streq(id0, "evt-0") == 1, "first id evt-0");
    assert(streq(id1, "evt-1") == 1, "second id evt-1");
    assert(streq(id2, "evt-2") == 1, "third id evt-2");

    # ---------------- StreamEvent + wire format ----------------
    var ev1 = stream_event_new("evt-7", "{\"hello\":\"world\"}");
    assert(streq(stream_event_id(ev1), "evt-7") == 1, "ev id");
    assert(streq(stream_event_type(ev1), "message") == 1, "ev type default");
    assert(streq(stream_event_data(ev1), "{\"hello\":\"world\"}") == 1, "ev data");
    var wire = stream_event_to_wire(ev1);
    assert(streq(wire, "id: evt-7\nevent: message\ndata: {\"hello\":\"world\"}\n\n") == 1,
    "ev wire format");

    var primer = stream_event_primer("evt-0");
    var primer_wire = stream_event_to_wire(primer);
    assert(streq(primer_wire, "id: evt-0\nevent: message\ndata: \n\n") == 1,
    "primer wire (empty data)");

    # ---------------- ResumptionBuffer ----------------
    var rb = resumption_buffer_new(3);
    assert_eq(resumption_buffer_len(rb), 0, "buffer empty");
    resumption_buffer_push(rb, stream_event_new("evt-1", "a"));
    resumption_buffer_push(rb, stream_event_new("evt-2", "b"));
    resumption_buffer_push(rb, stream_event_new("evt-3", "c"));
    assert_eq(resumption_buffer_len(rb), 3, "buffer 3");
    # Push one more — evicts evt-1
    resumption_buffer_push(rb, stream_event_new("evt-4", "d"));
    assert_eq(resumption_buffer_len(rb), 3, "buffer still 3 (capped)");
    var first = vec_get(resumption_buffer_events(rb), 0);
    assert(streq(stream_event_id(first), "evt-2") == 1, "evt-1 evicted, head = evt-2");

    # events_after — present id
    var after2 = resumption_buffer_events_after(rb, "evt-2");
    assert_eq(vec_len(after2), 2, "after evt-2 → 2 events");
    assert(streq(stream_event_id(vec_get(after2, 0)), "evt-3") == 1, "next is evt-3");
    assert(streq(stream_event_id(vec_get(after2, 1)), "evt-4") == 1, "then evt-4");

    # events_after — absent id (returns empty, caller must full-resync)
    var after_missing = resumption_buffer_events_after(rb, "evt-99");
    assert_eq(vec_len(after_missing), 0, "missing id → empty");

    # events_after — defensive guards (p(-1) hardening)
    assert_eq(vec_len(resumption_buffer_events_after(rb, 0)), 0, "null id → empty (no segfault)");
    assert_eq(vec_len(resumption_buffer_events_after(rb, "")), 0, "empty id → empty");

    # ---------------- SessionOutbound: per-session buffer + id gen ----------------
    var so1 = session_outbound_new();
    assert(session_outbound_buffer(so1) != 0, "outbound has a buffer");
    assert(session_outbound_id_gen(so1) != 0, "outbound has an id gen");
    assert(streq(event_id_gen_next(session_outbound_id_gen(so1)), "evt-0") == 1,
    "per-session id gen starts at evt-0");

    # _strm_session_outbound lazily allocs into the McpSession slot, idempotent.
    var so_sess = mcp_session_new("s1", "2025-11-25", 1000);
    assert_eq(mcp_session_outbound(so_sess), 0, "session outbound starts empty");
    var got1 = _strm_session_outbound(so_sess);
    assert(got1 != 0, "lazy-alloc returns a bundle");
    assert(mcp_session_outbound(so_sess) == got1, "bundle stashed in session slot");
    assert(_strm_session_outbound(so_sess) == got1, "second call returns the same bundle");

    # Two sessions → independent, non-cross-talking buffers + id spaces.
    var sess_a = mcp_session_new("a", "2025-11-25", 1000);
    var sess_b = mcp_session_new("b", "2025-11-25", 1000);
    var oa = _strm_session_outbound(sess_a);
    var ob = _strm_session_outbound(sess_b);
    assert(oa != ob, "distinct sessions → distinct bundles");
    resumption_buffer_push(session_outbound_buffer(oa),
    stream_event_new(event_id_gen_next(session_outbound_id_gen(oa)), "dA"));
    assert_eq(resumption_buffer_len(session_outbound_buffer(oa)), 1, "A has 1 event");
    assert_eq(resumption_buffer_len(session_outbound_buffer(ob)), 0, "B empty (no cross-talk)");
    assert(streq(event_id_gen_next(session_outbound_id_gen(ob)), "evt-0") == 1,
    "B id gen independent — also starts evt-0, no straddle");

    # ---------------- _strm_drain_events: cursor vs unconditional drain ----------------
    var dbuf = resumption_buffer_default();
    resumption_buffer_push(dbuf, stream_event_new("evt-a", "1"));
    resumption_buffer_push(dbuf, stream_event_new("evt-b", "2"));
    resumption_buffer_push(dbuf, stream_event_new("evt-c", "3"));
    # No cursor → drain everything currently buffered.
    assert_eq(vec_len(_strm_drain_events(dbuf, 0)), 3, "no cursor drains all");
    # Empty cursor → treated as absent → drain all (not events_after "").
    assert_eq(vec_len(_strm_drain_events(dbuf, "")), 3, "empty cursor drains all");
    # Cursor present → strictly after it.
    var after_b = _strm_drain_events(dbuf, "evt-b");
    assert_eq(vec_len(after_b), 1, "cursor evt-b → 1 event after");
    assert(streq(stream_event_id(vec_get(after_b, 0)), "evt-c") == 1, "after evt-b is evt-c");
    # Unknown cursor → empty (client missed too much).
    assert_eq(vec_len(_strm_drain_events(dbuf, "evt-zzz")), 0, "unknown cursor → empty");

    # ---------------- notify sink: tool-set changes → session buffers ----------------
    var nstore = session_store_default();
    var nsink = strm_notify_sink(nstore);
    var nsid = session_store_create(nstore, "2025-11-25");
    var nsess = session_store_validate(nstore, nsid);
    # A tool-registered event broadcasts notifications/tools/list_changed.
    event_sink_publish(nsink, TOPIC_TOOL_REGISTERED(), "{\"tool_name\":\"x_y\"}");
    var nso = _strm_session_outbound(nsess);
    assert_eq(resumption_buffer_len(session_outbound_buffer(nso)), 1,
    "tool_registered → 1 buffered notification");
    var nev = vec_get(resumption_buffer_events(session_outbound_buffer(nso)), 0);
    assert(streq(stream_event_data(nev),
    "{\"jsonrpc\":\"2.0\",\"method\":\"notifications/tools/list_changed\",\"params\":{}}") == 1,
    "buffered event is tools/list_changed");
    # Non-tool-set topics (audit events) are ignored by the client sink.
    event_sink_publish(nsink, TOPIC_TOOL_COMPLETED(), "{}");
    assert_eq(resumption_buffer_len(session_outbound_buffer(nso)), 1, "completed topic ignored");
    # Deregister also notifies.
    event_sink_publish(nsink, TOPIC_TOOL_DEREGISTERED(), "{\"tool_name\":\"x_y\"}");
    assert_eq(resumption_buffer_len(session_outbound_buffer(nso)), 2,
    "tool_deregistered → another notification");

    # Full path: dispatcher_register_tool fires the event through the sink.
    var ndisp = dispatcher_new(tool_registry_new());
    dispatcher_set_events(ndisp, nsink);
    var nbefore = resumption_buffer_len(session_outbound_buffer(nso));
    dispatcher_register_tool(ndisp,
    tool_def_new("reg_tool", "d", schema_new("object", 0, vec_new())), &_n_handler);
    assert_eq(resumption_buffer_len(session_outbound_buffer(nso)), nbefore + 1,
    "dispatcher_register_tool → list_changed reaches the session buffer");

    # Prompt-set changes produce notifications/prompts/list_changed.
    var pbefore = resumption_buffer_len(session_outbound_buffer(nso));
    event_sink_publish(nsink, TOPIC_PROMPT_REGISTERED(), "{\"prompt_name\":\"p_q\"}");
    assert_eq(resumption_buffer_len(session_outbound_buffer(nso)), pbefore + 1,
    "prompt_registered → notification");
    var pev = vec_get(resumption_buffer_events(session_outbound_buffer(nso)), pbefore);
    assert(streq(stream_event_data(pev),
    "{\"jsonrpc\":\"2.0\",\"method\":\"notifications/prompts/list_changed\",\"params\":{}}") == 1,
    "buffered event is prompts/list_changed");
    # Full path: dispatcher_register_prompt fires the prompt event through the sink.
    var pbefore2 = resumption_buffer_len(session_outbound_buffer(nso));
    dispatcher_register_prompt(ndisp, prompt_def_new("greet2", "g", 0), &_n_handler);
    assert_eq(resumption_buffer_len(session_outbound_buffer(nso)), pbefore2 + 1,
    "dispatcher_register_prompt → prompts/list_changed reaches the buffer");

    # ---------------- POST piggyback: Accept negotiation + response frame ----------------
    var acc_yes = "POST /mcp HTTP/1.1\r\nAccept: application/json, text/event-stream\r\n\r\n";
    assert_eq(_strm_accepts_sse(acc_yes, strlen(acc_yes)), 1, "Accept with event-stream → sse ok");
    var acc_no = "POST /mcp HTTP/1.1\r\nAccept: application/json\r\n\r\n";
    assert_eq(_strm_accepts_sse(acc_no, strlen(acc_no)), 0, "Accept without event-stream → no sse");
    var acc_absent = "POST /mcp HTTP/1.1\r\nContent-Type: application/json\r\n\r\n";
    assert_eq(_strm_accepts_sse(acc_absent, strlen(acc_absent)), 0, "absent Accept → no sse");
    # The response is framed as an id-less SSE `message` event.
    assert(streq(_strm_response_frame("{\"jsonrpc\":\"2.0\",\"id\":1,\"result\":{}}"),
    "event: message\ndata: {\"jsonrpc\":\"2.0\",\"id\":1,\"result\":{}}\n\n") == 1,
    "response frame is an id-less SSE message");

    # ---------------- StreamableConfig ----------------
    var scfg = streamable_config_new("/mcp", 0x0100007F, 8392);
    assert(streq(streamable_config_path(scfg), "/mcp") == 1, "scfg path");
    assert_eq(streamable_config_addr(scfg), 0x0100007F, "scfg addr");
    assert_eq(streamable_config_port(scfg), 8392, "scfg port");
    assert_eq(streamable_config_retry_ms(scfg), 5000, "scfg default retry_ms");
    assert_eq(streamable_config_session_store(scfg), 0, "scfg no default session");

    streamable_config_with_retry_ms(scfg, 1000);
    assert_eq(streamable_config_retry_ms(scfg), 1000, "scfg custom retry_ms");

    # ---------------- POST/GET path matching uses sandhi_server_path_only ----------------
    # Sanity that the transport's path check ignores the query string —
    # exercises the same stdlib helper but at our usage site.
    assert(streq(sandhi_server_path_only("/mcp?lastEventId=evt-7"), "/mcp") == 1,
    "path strips query for routing");

    return assert_summary();
}

var rc = main();
syscall(SYS_EXIT, rc);
