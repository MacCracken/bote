# bote.tcyr — error + protocol + registry unit tests
# Run: cyrius test tests/bote.tcyr

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/json.cyr"
include "lib/fnptr.cyr"
include "lib/chrono.cyr"
include "lib/tagged.cyr"
include "lib/net.cyr"
include "lib/base64.cyr"
include "lib/freelist.cyr"
include "lib/thread.cyr"
include "lib/sakshi.cyr"
include "lib/bigint.cyr"
include "lib/sigil.cyr"
include "lib/libro_error.cyr"
include "lib/libro_hasher.cyr"
include "lib/libro_entry.cyr"
include "lib/libro_verify.cyr"
include "lib/libro_query.cyr"
include "lib/libro_retention.cyr"
include "lib/libro_chain.cyr"
include "lib/majra_error.cyr"
include "lib/majra_counter.cyr"
include "lib/majra_envelope.cyr"
include "lib/majra_namespace.cyr"
include "lib/majra_queue.cyr"
include "lib/majra_pubsub.cyr"
include "lib/assert.cyr"

include "src/error.cyr"
include "src/protocol.cyr"
include "src/jsonx.cyr"
include "src/registry.cyr"
include "src/events.cyr"
include "src/audit.cyr"
include "src/audit_libro.cyr"
include "src/events_majra.cyr"
include "src/dispatch.cyr"
include "src/codec.cyr"
include "src/schema.cyr"
include "src/stream.cyr"
include "src/session.cyr"
include "src/discovery.cyr"
include "src/transport_http.cyr"
include "src/bridge.cyr"
include "src/transport_streamable.cyr"
# NB: lib/ws_server.cyr intentionally NOT included here — its frame I/O isn't
# exercised in these shape-only tests (live round-trip is covered by the
# stdlib ws_server conformance tests). Keeping it out also avoids pushing
# the cyrius 4.5.1 parser past its input-buffer cap. Same reason splits
# libro_tools into tests/bote_libro_tools.tcyr.
include "src/transport_ws.cyr"

# Test handler: echoes its arguments verbatim.
fn h_echo(args) {
    return args;
}

# Test handler: returns a constant.
fn h_const(args) {
    return "{\"answer\":42}";
}

# EventSink test backend: pushes (topic, payload) pairs into a global vec.
# Used by discovery, audit, and events tests below.
var _ev_topics = 0;
var _ev_payloads = 0;
fn test_event_publish(ctx, topic, payload) {
    if (_ev_topics == 0) { _ev_topics = vec_new(); _ev_payloads = vec_new(); }
    vec_push(_ev_topics, topic);
    vec_push(_ev_payloads, payload);
    return 0;
}
fn _ev_reset() {
    _ev_topics = vec_new();
    _ev_payloads = vec_new();
    return 0;
}

# AuditSink test backend: pushes ToolCallEvent ptrs into a global vec.
var _audit_events = 0;
fn test_audit_log(ctx, event) {
    if (_audit_events == 0) { _audit_events = vec_new(); }
    vec_push(_audit_events, event);
    return 0;
}
fn _audit_reset() { _audit_events = vec_new(); return 0; }

fn main() {
    alloc_init();
    fl_init();

    # ---------------- error: rpc_code mapping ----------------
    assert_eq(bote_err_rpc_code(ERR_PARSE), 0 - 32700, "rpc_code parse");
    assert_eq(bote_err_rpc_code(ERR_PROTOCOL), 0 - 32600, "rpc_code protocol");
    assert_eq(bote_err_rpc_code(ERR_TOOL_NOT_FOUND), 0 - 32601, "rpc_code tool_not_found");
    assert_eq(bote_err_rpc_code(ERR_INVALID_PARAMS), 0 - 32602, "rpc_code invalid_params");
    assert_eq(bote_err_rpc_code(ERR_SCHEMA_VIOLATION), 0 - 32602, "rpc_code schema_violation");
    assert_eq(bote_err_rpc_code(ERR_EXEC_FAILED), 0 - 32000, "rpc_code exec_failed");
    assert_eq(bote_err_rpc_code(ERR_SANDBOX), 0 - 32000, "rpc_code sandbox");
    assert_eq(bote_err_rpc_code(ERR_TRANSPORT_CLOSED), 0 - 32003, "rpc_code transport_closed");
    assert_eq(bote_err_rpc_code(ERR_BIND_FAILED), 0 - 32003, "rpc_code bind_failed");
    assert_eq(bote_err_rpc_code(ERR_REQUEST_CANCELLED), 0 - 32800, "rpc_code cancelled");
    assert_eq(bote_err_rpc_code(ERR_JSON), 0 - 32700, "rpc_code json");
    assert_eq(bote_err_rpc_code(ERR_IO), 0 - 32603, "rpc_code io");

    # ---------------- error: accessors ----------------
    var e = bote_err_new(ERR_INVALID_PARAMS, "echo", "missing 'name'");
    assert_eq(bote_err_tag(e), ERR_INVALID_PARAMS, "tag stored");
    assert(streq(bote_err_tool(e), "echo") == 1, "tool stored");
    assert(streq(bote_err_reason(e), "missing 'name'") == 1, "reason stored");
    assert_eq(bote_err_violations(e), 0, "no violations on plain err");

    # ---------------- error: format ----------------
    var s1 = bote_err_format(bote_err_new(ERR_TOOL_NOT_FOUND, "foo", 0));
    assert(str_eq(s1, str_from("tool not found: foo")) == 1, "fmt tool_not_found");

    var s2 = bote_err_format(bote_err_new(ERR_INVALID_PARAMS, "t", "r"));
    assert(str_eq(s2, str_from("invalid params for tool 't': r")) == 1, "fmt invalid_params");

    var s3 = bote_err_format(bote_err_new(ERR_EXEC_FAILED, "t", "r"));
    assert(str_eq(s3, str_from("tool execution failed: t - r")) == 1, "fmt exec_failed");

    var s4 = bote_err_format(bote_err_new(ERR_TRANSPORT_CLOSED, 0, 0));
    assert(str_eq(s4, str_from("transport closed")) == 1, "fmt transport_closed");

    var s5 = bote_err_format(bote_err_new(ERR_BIND_FAILED, 0, "port in use"));
    assert(str_eq(s5, str_from("transport bind failed: port in use")) == 1, "fmt bind_failed");

    # ---------------- error: schema violations join ----------------
    var vs = vec_new();
    vec_push(vs, "name required");
    vec_push(vs, "id must be int");
    var sv = bote_err_with_violations(ERR_SCHEMA_VIOLATION, "tool_x", vs);
    var s6 = bote_err_format(sv);
    assert(str_eq(s6, str_from("schema violation for tool 'tool_x': name required; id must be int")) == 1, "fmt schema joins");

    # ---------------- protocol: request creation ----------------
    var req = req_new("1", "tools/list");
    assert(streq(req_jsonrpc(req), "2.0") == 1, "req jsonrpc 2.0");
    assert(streq(req_id(req), "1") == 1, "req id stored");
    assert(streq(req_method(req), "tools/list") == 1, "req method stored");
    assert_eq(req_is_notification(req), 0, "req not notification");

    # ---------------- protocol: notification ----------------
    var n = req_notification("notifications/initialized");
    assert_eq(req_id(n), 0, "notif id is 0");
    assert_eq(req_is_notification(n), 1, "notif flagged");
    assert(streq(req_method(n), "notifications/initialized") == 1, "notif method");

    # ---------------- protocol: with_params ----------------
    var rp = req_with_params(req_new("42", "tools/call"), "{\"name\":\"echo\"}");
    assert(streq(req_params(rp), "{\"name\":\"echo\"}") == 1, "params overridden");

    # default params when not set
    var rd = req_new("1", "initialize");
    assert(streq(req_params(rd), "null") == 1, "default params null");

    # ---------------- protocol: response success ----------------
    var ok = resp_success("1", "{\"tools\":[]}");
    assert(streq(resp_jsonrpc(ok), "2.0") == 1, "resp jsonrpc 2.0");
    assert(streq(resp_id(ok), "1") == 1, "resp id");
    assert(streq(resp_result(ok), "{\"tools\":[]}") == 1, "resp result");
    assert_eq(resp_error_obj(ok), 0, "resp success no error obj");

    # ---------------- protocol: response error ----------------
    var er = resp_error("1", 0 - 32601, "tool not found");
    assert_eq(resp_result(er), 0, "resp error no result");
    var eobj = resp_error_obj(er);
    assert(eobj != 0, "resp error has error obj");
    assert_eq(rpc_err_code(eobj), 0 - 32601, "rpc err code");
    assert(streq(rpc_err_message(eobj), "tool not found") == 1, "rpc err message");
    assert_eq(rpc_err_data(eobj), 0, "rpc err data null");

    # ---------------- protocol: response preserves arbitrary id ----------------
    var rid = resp_success("\"abc-123\"", "{}");
    assert(streq(resp_id(rid), "\"abc-123\"") == 1, "string id preserved");

    # ---------------- registry: empty ----------------
    var reg = registry_new();
    assert_eq(registry_is_empty(reg), 1, "new reg empty");
    assert_eq(registry_len(reg), 0, "new reg len 0");
    assert_eq(registry_get(reg, "anything"), 0, "get on empty returns 0");
    assert_eq(vec_len(registry_list(reg)), 0, "list on empty returns empty vec");

    # ---------------- registry: register + get + contains ----------------
    var req_path = vec_new();
    vec_push(req_path, "path");
    var schema_a = schema_new("object", 0, req_path);
    var tool_a = tool_def_new("scan", "scan tool", schema_a);
    registry_register(reg, tool_a);
    assert_eq(registry_contains(reg, "scan"), 1, "contains registered");
    assert_eq(registry_contains(reg, "nope"), 0, "contains absent");
    assert_eq(registry_len(reg), 1, "len after register");
    var got = registry_get(reg, "scan");
    assert(got != 0, "get returns def");
    assert(streq(tool_def_name(got), "scan") == 1, "got correct name");
    assert(streq(tool_def_description(got), "scan tool") == 1, "got description");

    # ---------------- registry: list returns insertion order ----------------
    var schema_b = schema_new("object", 0, vec_new());
    registry_register(reg, tool_def_new("alpha", "a tool", schema_b));
    registry_register(reg, tool_def_new("beta", "b tool", schema_b));
    var lst = registry_list(reg);
    assert_eq(vec_len(lst), 3, "list has 3");
    assert(streq(tool_def_name(vec_get(lst, 0)), "scan") == 1, "list[0] = scan");
    assert(streq(tool_def_name(vec_get(lst, 1)), "alpha") == 1, "list[1] = alpha");
    assert(streq(tool_def_name(vec_get(lst, 2)), "beta") == 1, "list[2] = beta");

    # ---------------- registry: register overwrites ----------------
    var schema_dup = schema_new("object", 0, vec_new());
    registry_register(reg, tool_def_new("scan", "updated", schema_dup));
    assert_eq(registry_len(reg), 3, "len unchanged on overwrite");
    assert(streq(tool_def_description(registry_get(reg, "scan")), "updated") == 1, "description updated");

    # ---------------- registry: validate_params ok with required field ----------------
    var reg2 = registry_new();
    var rp2 = vec_new();
    vec_push(rp2, "path");
    var schema_p = schema_new("object", 0, rp2);
    registry_register(reg2, tool_def_new("scan", "scan tool", schema_p));
    var ok_err = registry_validate_params(reg2, "scan", "{\"path\":\"/tmp\"}");
    assert_eq(ok_err, 0, "validate ok with field");

    # ---------------- registry: validate_params missing field ----------------
    var miss_err = registry_validate_params(reg2, "scan", "{}");
    assert(miss_err != 0, "validate err on missing");
    assert_eq(bote_err_tag(miss_err), ERR_INVALID_PARAMS, "missing -> INVALID_PARAMS");

    # ---------------- registry: validate_params unknown tool ----------------
    var unk_err = registry_validate_params(reg2, "nope", "{}");
    assert(unk_err != 0, "validate err on unknown");
    assert_eq(bote_err_tag(unk_err), ERR_TOOL_NOT_FOUND, "unknown -> TOOL_NOT_FOUND");

    # ---------------- registry: validate rejects non-object params ----------------
    var nob1 = registry_validate_params(reg2, "scan", "null");
    assert(nob1 != 0, "null rejected");
    assert_eq(bote_err_tag(nob1), ERR_INVALID_PARAMS, "null -> INVALID_PARAMS");
    var nob2 = registry_validate_params(reg2, "scan", "[1,2]");
    assert(nob2 != 0, "array rejected");
    var nob3 = registry_validate_params(reg2, "scan", "42");
    assert(nob3 != 0, "number rejected");
    var nob4 = registry_validate_params(reg2, "scan", "true");
    assert(nob4 != 0, "bool rejected");
    var nob5 = registry_validate_params(reg2, "scan", "\"string\"");
    assert(nob5 != 0, "string rejected");

    # ---------------- registry: validate passes with no required ----------------
    var reg3 = registry_new();
    registry_register(reg3, tool_def_new("open", "no required", schema_new("object", 0, vec_new())));
    assert_eq(registry_validate_params(reg3, "open", "{}"), 0, "empty ok no required");

    # ---------------- registry: deregister ----------------
    var removed = registry_deregister(reg2, "scan");
    assert(removed != 0, "deregister returns def");
    assert_eq(registry_contains(reg2, "scan"), 0, "after dereg not contains");
    assert_eq(registry_len(reg2), 0, "after dereg len 0");
    assert_eq(registry_deregister(reg2, "scan"), 0, "dereg twice returns 0");

    # ---------------- registry: versioned ----------------
    var regv = registry_new();
    var ts = schema_new("object", 0, vec_new());
    registry_register(regv, tool_def_with_version(tool_def_new("calc", "v1", ts), "1.0"));
    registry_register(regv, tool_def_with_version(tool_def_new("calc", "v2", ts), "2.0"));
    var v1 = registry_get_versioned(regv, "calc", "1.0");
    var v2 = registry_get_versioned(regv, "calc", "2.0");
    assert(v1 != 0, "got v1");
    assert(v2 != 0, "got v2");
    assert(streq(tool_def_description(v1), "v1") == 1, "v1 description");
    assert(streq(tool_def_description(v2), "v2") == 1, "v2 description");
    assert_eq(registry_get_versioned(regv, "calc", "9.9"), 0, "missing version");
    assert_eq(vec_len(registry_list_versions(regv, "calc")), 2, "two versions tracked");

    # ---------------- registry: deprecate ----------------
    registry_deprecate(regv, "calc", "use calc2");
    var dep_t = registry_get(regv, "calc");
    assert(streq(tool_def_deprecated(dep_t), "use calc2") == 1, "deprecated set");

    # ---------------- annotations: presets ----------------
    var ro = ann_read_only();
    assert_eq(ann_read_only_hint(ro), HINT_TRUE, "ro hint true");
    assert_eq(ann_destructive_hint(ro), HINT_FALSE, "ro destructive false");
    assert_eq(ann_idempotent_hint(ro), HINT_TRUE, "ro idempotent true");
    assert_eq(ann_open_world_hint(ro), HINT_FALSE, "ro open_world false");

    var de = ann_destructive();
    assert_eq(ann_read_only_hint(de), HINT_FALSE, "de read_only false");
    assert_eq(ann_destructive_hint(de), HINT_TRUE, "de destructive true");

    var blank = ann_new();
    assert_eq(ann_read_only_hint(blank), HINT_UNSET, "blank unset");

    # ---------------- jsonx: flat get_str ----------------
    var jx1 = jsonx_get_str("{\"name\":\"echo\"}", "name");
    assert(jx1 != 0, "jx flat name found");
    assert(streq(jx1, "echo") == 1, "jx flat name value");
    assert_eq(jsonx_get_str("{\"name\":\"echo\"}", "missing"), 0, "jx missing key");

    # ---------------- jsonx: nested raw extraction ----------------
    var nested = "{\"name\":\"calc\",\"arguments\":{\"a\":1,\"b\":2}}";
    var jx_name = jsonx_get_str(nested, "name");
    assert(streq(jx_name, "calc") == 1, "jx nested skip-past name");
    var jx_args = jsonx_get_raw(nested, "arguments");
    assert(jx_args != 0, "jx nested args found");
    assert(streq(jx_args, "{\"a\":1,\"b\":2}") == 1, "jx nested args raw bytes");

    # ---------------- jsonx: deeply nested ----------------
    var deep = "{\"a\":{\"b\":{\"c\":[1,2,3]}},\"after\":7}";
    var jx_a = jsonx_get_raw(deep, "a");
    assert(streq(jx_a, "{\"b\":{\"c\":[1,2,3]}}") == 1, "jx deep nested");
    var jx_after = jsonx_get_raw(deep, "after");
    assert(streq(jx_after, "7") == 1, "jx after deep");

    # ---------------- jsonx: array values ----------------
    var arr = "{\"xs\":[1,{\"k\":\"v\"},3],\"y\":2}";
    var jx_xs = jsonx_get_raw(arr, "xs");
    assert(jx_xs != 0, "jx xs found");
    assert(streq(jx_xs, "[1,{\"k\":\"v\"},3]") == 1, "jx array with nested obj");

    # ---------------- jsonx: truncated string regression (jsonx_get_str must clamp) ----------------
    # Input has opening quote but no closing — _jx_skip_string returns end == len,
    # so end - pos - 2 was negative → memcpy(out, src, -1) → segfault.
    # Now clamped to 0 (returns empty string).
    var trunc1 = jsonx_get_str("{\"k\":\"", "k");
    assert(trunc1 != 0, "trunc string returns non-null");
    assert_eq(strlen(trunc1), 0, "trunc string is empty");
    var trunc2 = jsonx_get_str("{\"k\":\"v", "k");
    assert(trunc2 != 0, "trunc-with-data returns non-null");
    # NB: behavior is to drop the unfinished 'v' since there's no closing quote.

    # ---------------- jsonx: predicates ----------------
    assert_eq(jsonx_has("{\"k\":1}", "k"), 1, "jsonx_has yes");
    assert_eq(jsonx_has("{\"k\":1}", "x"), 0, "jsonx_has no");
    assert_eq(jsonx_is_object("{\"k\":1}"), 1, "is_object yes");
    assert_eq(jsonx_is_object("[1,2]"), 0, "array not object");
    assert_eq(jsonx_is_object("  {} "), 1, "is_object skips ws");
    assert_eq(jsonx_is_object("null"), 0, "null not object");

    # ---------------- validate_tool_name ----------------
    assert_eq(validate_tool_name("good_name"), 0, "valid name");
    assert_eq(validate_tool_name("a_b_c_1_2"), 0, "valid name with digits");
    assert(validate_tool_name(0) != 0, "null name fails");
    assert(validate_tool_name("") != 0, "empty fails");
    assert(validate_tool_name("noundercore") != 0, "no underscore fails");
    assert(validate_tool_name("bad-name") != 0, "hyphen fails");
    assert(validate_tool_name("bad name") != 0, "space fails");
    assert(validate_tool_name("bad/name") != 0, "slash fails");

    # ---------------- dispatch: initialize ----------------
    var dreg = registry_new();
    var d = dispatcher_new(dreg);

    var init_req = req_with_params(req_new("1", "initialize"), "{\"protocolVersion\":\"2024-11-05\"}");
    var init_resp = dispatcher_dispatch(d, init_req);
    assert(init_resp != 0, "init not notification");
    assert(streq(resp_id(init_resp), "1") == 1, "init id");
    var init_result = resp_result(init_resp);
    assert(init_result != 0, "init result present");
    # Body should mention the negotiated version + serverInfo
    assert_eq(jsonx_has(init_result, "protocolVersion"), 1, "init body has protocolVersion");
    assert_eq(jsonx_has(init_result, "serverInfo"), 1, "init body has serverInfo");
    var negotiated = jsonx_get_str(init_result, "protocolVersion");
    assert(streq(negotiated, "2024-11-05") == 1, "init negotiates supported version");

    # Init with unsupported version → fall back to latest
    var bad_init = req_with_params(req_new("1", "initialize"), "{\"protocolVersion\":\"1999-01-01\"}");
    var bi_resp = dispatcher_dispatch(d, bad_init);
    var bi_neg = jsonx_get_str(resp_result(bi_resp), "protocolVersion");
    assert(streq(bi_neg, "2025-11-25") == 1, "init falls back to latest");

    # ---------------- dispatch: tools/list empty ----------------
    var ll_resp = dispatcher_dispatch(d, req_new("2", "tools/list"));
    var ll_body = resp_result(ll_resp);
    assert(streq(ll_body, "{\"tools\":[]}") == 1, "tools/list empty");

    # ---------------- dispatch: tools/list with one tool ----------------
    var sa = schema_new("object", 0, vec_new());
    registry_register(dreg, tool_def_new("svc_echo", "echo it", sa));
    var ll2 = dispatcher_dispatch(d, req_new("2", "tools/list"));
    var ll2_body = resp_result(ll2);
    assert_eq(jsonx_has(ll2_body, "tools"), 1, "list has tools");
    # The tools array is "[{...}]" — get_raw returns the array verbatim
    var tools_raw = jsonx_get_raw(ll2_body, "tools");
    assert(tools_raw != 0, "tools array present");

    # ---------------- dispatch: tools/call success ----------------
    dispatcher_handle(d, "svc_echo", &h_echo);
    var call_req = req_with_params(req_new("3", "tools/call"),
        "{\"name\":\"svc_echo\",\"arguments\":{\"msg\":\"hi\"}}");
    var call_resp = dispatcher_dispatch(d, call_req);
    var call_result = resp_result(call_resp);
    assert(call_result != 0, "call has result");
    assert(streq(call_result, "{\"msg\":\"hi\"}") == 1, "echo handler returned args");
    assert_eq(resp_error_obj(call_resp), 0, "call success no error");

    # ---------------- dispatch: tools/call with const handler ----------------
    registry_register(dreg, tool_def_new("svc_const", "constant", sa));
    dispatcher_handle(d, "svc_const", &h_const);
    var cc = dispatcher_dispatch(d, req_with_params(req_new("4", "tools/call"),
        "{\"name\":\"svc_const\",\"arguments\":{}}"));
    assert(streq(resp_result(cc), "{\"answer\":42}") == 1, "const handler returned constant");

    # ---------------- dispatch: tools/call missing name ----------------
    var bad_call = dispatcher_dispatch(d, req_with_params(req_new("5", "tools/call"), "{}"));
    var bc_err = resp_error_obj(bad_call);
    assert(bc_err != 0, "missing name -> err");
    assert_eq(rpc_err_code(bc_err), 0 - 32602, "missing name -32602");

    # ---------------- dispatch: tools/call unknown tool ----------------
    var unk_call = dispatcher_dispatch(d, req_with_params(req_new("6", "tools/call"),
        "{\"name\":\"nope_x\",\"arguments\":{}}"));
    var uc_err = resp_error_obj(unk_call);
    assert(uc_err != 0, "unknown tool -> err");
    assert_eq(rpc_err_code(uc_err), 0 - 32601, "unknown tool -32601");

    # ---------------- dispatch: unknown method ----------------
    var um_resp = dispatcher_dispatch(d, req_new("7", "garbage/method"));
    var um_err = resp_error_obj(um_resp);
    assert(um_err != 0, "unknown method -> err");
    assert_eq(rpc_err_code(um_err), 0 - 32601, "unknown method -32601");

    # ---------------- dispatch: notification returns 0 ----------------
    var notif = req_notification("notifications/initialized");
    assert_eq(dispatcher_dispatch(d, notif), 0, "notification dispatch returns 0");

    # ---------------- dispatch: dynamic register_tool with bad name ----------------
    var bad_reg = dispatcher_register_tool(d, tool_def_new("badname", "x", sa), &h_echo);
    assert(bad_reg != 0, "bad name register fails");
    assert_eq(bote_err_tag(bad_reg), ERR_INVALID_PARAMS, "bad name -> INVALID_PARAMS");

    # ---------------- dispatch: dynamic register + dispatch ----------------
    var ok_reg = dispatcher_register_tool(d, tool_def_new("dyn_tool", "dyn", sa), &h_echo);
    assert_eq(ok_reg, 0, "valid register succeeds");
    var dyn_call = dispatcher_dispatch(d, req_with_params(req_new("8", "tools/call"),
        "{\"name\":\"dyn_tool\",\"arguments\":{\"q\":1}}"));
    assert(streq(resp_result(dyn_call), "{\"q\":1}") == 1, "dyn handler dispatched");

    # ---------------- dispatch: deregister ----------------
    var dereg_ok = dispatcher_deregister_tool(d, "dyn_tool");
    assert_eq(dereg_ok, 0, "deregister ok");
    var dyn_after = dispatcher_dispatch(d, req_with_params(req_new("9", "tools/call"),
        "{\"name\":\"dyn_tool\",\"arguments\":{}}"));
    var da_err = resp_error_obj(dyn_after);
    assert(da_err != 0, "after dereg unknown tool");
    assert_eq(rpc_err_code(da_err), 0 - 32601, "after dereg -32601");

    # Deregister missing
    var dereg_miss = dispatcher_deregister_tool(d, "never_existed");
    assert(dereg_miss != 0, "dereg missing returns err");
    assert_eq(bote_err_tag(dereg_miss), ERR_TOOL_NOT_FOUND, "dereg missing -> TOOL_NOT_FOUND");

    # ---------------- codec: parse_request happy path ----------------
    var pr = codec_parse_request("{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\",\"params\":{}}");
    assert(pr != 0, "parse_request ok");
    assert(streq(req_jsonrpc(pr), "2.0") == 1, "pr jsonrpc");
    assert(streq(req_method(pr), "tools/list") == 1, "pr method");
    assert(streq(req_id(pr), "1") == 1, "pr id raw");
    assert(streq(req_params(pr), "{}") == 1, "pr params raw");

    # parse_request missing params → defaults to "null"
    var pr2 = codec_parse_request("{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"initialize\"}");
    assert(streq(req_params(pr2), "null") == 1, "params defaults null");

    # parse_request notification (no id)
    var pr3 = codec_parse_request("{\"jsonrpc\":\"2.0\",\"method\":\"notify\"}");
    assert_eq(req_is_notification(pr3), 1, "parse notification flagged");

    # parse_request malformed → 0
    assert_eq(codec_parse_request("not json"), 0, "parse non-json -> 0");
    assert_eq(codec_parse_request("[1,2]"), 0, "parse array -> 0 (not object)");
    assert_eq(codec_parse_request("{\"id\":1}"), 0, "parse no method -> 0");

    # ---------------- codec: serialize_response ----------------
    var sok = codec_serialize_response(resp_success("1", "{\"x\":1}"));
    assert(streq(sok, "{\"jsonrpc\":\"2.0\",\"id\":1,\"result\":{\"x\":1}}") == 1, "serialize success");

    var serr = codec_serialize_response(resp_error("1", 0 - 32601, "tool not found"));
    assert(streq(serr, "{\"jsonrpc\":\"2.0\",\"id\":1,\"error\":{\"code\":-32601,\"message\":\"tool not found\"}}") == 1, "serialize error");

    # serialize with null result
    var sn = codec_serialize_response(resp_success("1", 0));
    assert(streq(sn, "{\"jsonrpc\":\"2.0\",\"id\":1,\"result\":null}") == 1, "serialize null result");

    # serialize with string id
    var sid = codec_serialize_response(resp_success("\"abc\"", "true"));
    assert(streq(sid, "{\"jsonrpc\":\"2.0\",\"id\":\"abc\",\"result\":true}") == 1, "serialize string id");

    # serialize escapes message quote/backslash/newline
    var sesc = codec_serialize_response(resp_error("1", 0 - 32000, "a \"b\" \\ c\nd"));
    assert(streq(sesc, "{\"jsonrpc\":\"2.0\",\"id\":1,\"error\":{\"code\":-32000,\"message\":\"a \\\"b\\\" \\\\ c\\nd\"}}") == 1, "serialize escapes");

    # ---------------- codec: process_message single ----------------
    var dreg2 = registry_new();
    var d2 = dispatcher_new(dreg2);
    var sa2 = schema_new("object", 0, vec_new());
    registry_register(dreg2, tool_def_new("svc_echo", "echo", sa2));
    dispatcher_handle(d2, "svc_echo", &h_echo);

    var pm1 = codec_process_message("{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\"}", d2);
    assert(pm1 != 0, "single ok");
    assert_eq(jsonx_has(pm1, "result"), 1, "single has result");

    # process_message notification → 0
    assert_eq(codec_process_message("{\"jsonrpc\":\"2.0\",\"method\":\"notify\"}", d2), 0, "single notif -> 0");

    # process_message non-json → parse error
    var pmpe = codec_process_message("not json", d2);
    assert(pmpe != 0, "non-json returns err");
    assert_eq(jsonx_has(pmpe, "error"), 1, "non-json -> error obj");

    # process_message non-object/non-array → invalid request
    var pmni = codec_process_message("42", d2);
    assert(pmni != 0, "scalar returns err");
    assert_eq(jsonx_has(pmni, "error"), 1, "scalar -> error obj");

    # process_message wrong jsonrpc version
    var pmwv = codec_process_message("{\"jsonrpc\":\"1.0\",\"id\":1,\"method\":\"x\"}", d2);
    assert_eq(jsonx_has(pmwv, "error"), 1, "wrong version -> err");

    # ---------------- codec: process_message batch ----------------
    var pmb = codec_process_message(
        "[{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\"},{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/list\"}]",
        d2);
    assert(pmb != 0, "batch returns array");
    # Should be an array
    assert_eq(load8(pmb), 91, "batch starts with [");

    # batch with notification (only one response back)
    var pmbn = codec_process_message(
        "[{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\"},{\"jsonrpc\":\"2.0\",\"method\":\"notify\"}]",
        d2);
    assert(pmbn != 0, "mixed batch returns");

    # all-notifications batch → 0
    var pmbz = codec_process_message(
        "[{\"jsonrpc\":\"2.0\",\"method\":\"a\"},{\"jsonrpc\":\"2.0\",\"method\":\"b\"}]",
        d2);
    assert_eq(pmbz, 0, "all-notif batch -> 0");

    # empty batch → invalid request
    var pmbe = codec_process_message("[]", d2);
    assert(pmbe != 0, "empty batch returns err");
    assert_eq(jsonx_has(pmbe, "error"), 1, "empty batch -> error");

    # ---------------- schema: type checking ----------------
    var ps = vec_new();
    vec_push(ps, schema_prop_new("name", "{\"type\":\"string\"}"));
    var s_str = schema_new("object", ps, vec_new());
    var c_str = compiled_compile(s_str);

    assert_eq(vec_len(compiled_validate(c_str, "{\"name\":\"alice\"}")), 0, "string ok");
    assert_eq(vec_len(compiled_validate(c_str, "{\"name\":42}")), 1, "string rejects int");

    var ps_n = vec_new();
    vec_push(ps_n, schema_prop_new("score", "{\"type\":\"number\"}"));
    var c_num = compiled_compile(schema_new("object", ps_n, vec_new()));
    assert_eq(vec_len(compiled_validate(c_num, "{\"score\":42}")), 0, "number ok int");
    assert_eq(vec_len(compiled_validate(c_num, "{\"score\":\"abc\"}")), 1, "number rejects string");

    var ps_i = vec_new();
    vec_push(ps_i, schema_prop_new("count", "{\"type\":\"integer\"}"));
    var c_int = compiled_compile(schema_new("object", ps_i, vec_new()));
    assert_eq(vec_len(compiled_validate(c_int, "{\"count\":42}")), 0, "integer ok");
    assert_eq(vec_len(compiled_validate(c_int, "{\"count\":3.14}")), 1, "integer rejects float");

    var ps_b = vec_new();
    vec_push(ps_b, schema_prop_new("flag", "{\"type\":\"boolean\"}"));
    var c_bool = compiled_compile(schema_new("object", ps_b, vec_new()));
    assert_eq(vec_len(compiled_validate(c_bool, "{\"flag\":true}")), 0, "bool ok true");
    assert_eq(vec_len(compiled_validate(c_bool, "{\"flag\":false}")), 0, "bool ok false");
    assert_eq(vec_len(compiled_validate(c_bool, "{\"flag\":\"yes\"}")), 1, "bool rejects string");

    # ---------------- schema: array of strings ----------------
    var ps_a = vec_new();
    vec_push(ps_a, schema_prop_new("tags", "{\"type\":\"array\",\"items\":{\"type\":\"string\"}}"));
    var c_arr = compiled_compile(schema_new("object", ps_a, vec_new()));
    assert_eq(vec_len(compiled_validate(c_arr, "{\"tags\":[\"a\",\"b\"]}")), 0, "array of strings ok");
    assert_eq(vec_len(compiled_validate(c_arr, "{\"tags\":[1,2]}")), 2, "array of strings rejects ints");
    assert_eq(vec_len(compiled_validate(c_arr, "{\"tags\":\"not array\"}")), 1, "array rejects scalar");

    # ---------------- schema: nested object ----------------
    var ps_o = vec_new();
    vec_push(ps_o, schema_prop_new("config",
        "{\"type\":\"object\",\"properties\":{\"host\":{\"type\":\"string\"},\"port\":{\"type\":\"integer\"}},\"required\":[\"host\"]}"));
    var c_obj = compiled_compile(schema_new("object", ps_o, vec_new()));
    assert_eq(vec_len(compiled_validate(c_obj, "{\"config\":{\"host\":\"localhost\",\"port\":8080}}")), 0, "nested ok");
    assert_eq(vec_len(compiled_validate(c_obj, "{\"config\":{\"port\":8080}}")), 1, "nested missing required");
    assert_eq(vec_len(compiled_validate(c_obj, "{\"config\":{\"host\":42}}")), 1, "nested wrong type");

    # ---------------- schema: enum ----------------
    var ps_e = vec_new();
    vec_push(ps_e, schema_prop_new("mode", "{\"type\":\"string\",\"enum\":[\"read\",\"write\",\"append\"]}"));
    var c_en = compiled_compile(schema_new("object", ps_e, vec_new()));
    assert_eq(vec_len(compiled_validate(c_en, "{\"mode\":\"read\"}")), 0, "enum ok");
    assert_eq(vec_len(compiled_validate(c_en, "{\"mode\":\"delete\"}")), 1, "enum rejects unknown");

    # ---------------- schema: number bounds ----------------
    var ps_nb = vec_new();
    vec_push(ps_nb, schema_prop_new("age", "{\"type\":\"number\",\"minimum\":0,\"maximum\":150}"));
    var c_nb = compiled_compile(schema_new("object", ps_nb, vec_new()));
    assert_eq(vec_len(compiled_validate(c_nb, "{\"age\":25}")), 0, "in bounds");
    assert_eq(vec_len(compiled_validate(c_nb, "{\"age\":-1}")), 1, "below min");
    assert_eq(vec_len(compiled_validate(c_nb, "{\"age\":200}")), 1, "above max");

    # ---------------- schema: integer bounds ----------------
    var ps_ib = vec_new();
    vec_push(ps_ib, schema_prop_new("retries", "{\"type\":\"integer\",\"minimum\":0,\"maximum\":5}"));
    var c_ib = compiled_compile(schema_new("object", ps_ib, vec_new()));
    assert_eq(vec_len(compiled_validate(c_ib, "{\"retries\":3}")), 0, "int in bounds");
    assert_eq(vec_len(compiled_validate(c_ib, "{\"retries\":-1}")), 1, "int below");
    assert_eq(vec_len(compiled_validate(c_ib, "{\"retries\":10}")), 1, "int above");

    # ---------------- schema: required ----------------
    var ps_r = vec_new();
    vec_push(ps_r, schema_prop_new("name", "{\"type\":\"string\"}"));
    vec_push(ps_r, schema_prop_new("age", "{\"type\":\"integer\"}"));
    var req_one = vec_new();
    vec_push(req_one, "name");
    var c_req = compiled_compile(schema_new("object", ps_r, req_one));
    assert_eq(vec_len(compiled_validate(c_req, "{\"name\":\"alice\"}")), 0, "required present");
    assert_eq(vec_len(compiled_validate(c_req, "{\"age\":25}")), 1, "missing required");

    # ---------------- schema: multiple violations reported ----------------
    var req2 = vec_new();
    vec_push(req2, "name");
    vec_push(req2, "age");
    var c_multi = compiled_compile(schema_new("object", ps_r, req2));
    assert_eq(vec_len(compiled_validate(c_multi, "{}")), 2, "two missing required");

    # ---------------- schema: unknown type → ANY ----------------
    var ps_any = vec_new();
    vec_push(ps_any, schema_prop_new("data", "{\"type\":\"custom_type\"}"));
    var c_any = compiled_compile(schema_new("object", ps_any, vec_new()));
    assert_eq(vec_len(compiled_validate(c_any, "{\"data\":42}")), 0, "any accepts int");
    assert_eq(vec_len(compiled_validate(c_any, "{\"data\":\"hi\"}")), 0, "any accepts string");

    # ---------------- schema: extra fields allowed ----------------
    assert_eq(vec_len(compiled_validate(c_str, "{\"name\":\"a\",\"extra\":42}")), 0, "extra allowed");

    # ---------------- schema: non-object rejected ----------------
    assert_eq(vec_len(compiled_validate(c_str, "\"not object\"")), 1, "non-object rejected");

    # ---------------- registry: validate uses compiled when attached ----------------
    var rcompiled = registry_new();
    var p_compiled = vec_new();
    vec_push(p_compiled, schema_prop_new("count", "{\"type\":\"integer\",\"minimum\":1,\"maximum\":10}"));
    var s_compiled = schema_new("object", p_compiled, vec_new());
    var t_compiled = tool_def_with_compiled(tool_def_new("svc_count", "compiled", s_compiled),
                                            compiled_compile(s_compiled));
    registry_register(rcompiled, t_compiled);
    assert_eq(registry_validate_params(rcompiled, "svc_count", "{\"count\":5}"), 0, "compiled validate ok");
    var bv = registry_validate_params(rcompiled, "svc_count", "{\"count\":99}");
    assert(bv != 0, "compiled validate err on bound");
    assert_eq(bote_err_tag(bv), ERR_SCHEMA_VIOLATION, "bound err -> SCHEMA_VIOLATION");
    var tv = registry_validate_params(rcompiled, "svc_count", "{\"count\":\"x\"}");
    assert(tv != 0, "compiled validate err on type");
    assert_eq(bote_err_tag(tv), ERR_SCHEMA_VIOLATION, "type err -> SCHEMA_VIOLATION");

    # ---------------- stream: cancellation token ----------------
    var tok = cancel_token_new();
    assert_eq(cancel_token_is_cancelled(tok), 0, "fresh token not cancelled");
    cancel_token_cancel(tok);
    assert_eq(cancel_token_is_cancelled(tok), 1, "after cancel set");

    # ---------------- stream: progress sender + updates ----------------
    var ps_send = progress_sender_new();
    progress_sender_report(ps_send, 3, 10);
    progress_sender_report_msg(ps_send, 5, 10, "halfway");
    var updates = progress_sender_updates(ps_send);
    assert_eq(vec_len(updates), 2, "two updates");
    var u1 = vec_get(updates, 0);
    assert_eq(progress_update_progress(u1), 3, "u1 progress");
    assert_eq(progress_update_total(u1), 10, "u1 total");
    var u2 = vec_get(updates, 1);
    assert_eq(progress_update_progress(u2), 5, "u2 progress");
    assert(streq(progress_update_message(u2), "halfway") == 1, "u2 message");

    # send-after-close is silently dropped
    progress_sender_close(ps_send);
    progress_sender_report(ps_send, 9, 10);
    assert_eq(vec_len(updates), 2, "post-close drop");

    # ---------------- stream: progress_notification JSON ----------------
    var u_notif = progress_update_new(3, 10, "working");
    var prog_notif = progress_notification("42", u_notif);
    assert(streq(prog_notif, "{\"jsonrpc\":\"2.0\",\"method\":\"notifications/progress\",\"params\":{\"progressToken\":42,\"progress\":3,\"total\":10,\"message\":\"working\"}}") == 1, "progress notif json");

    var u_min = progress_update_new(7, 0 - 1, 0);
    var notif_min = progress_notification("\"abc\"", u_min);
    assert(streq(notif_min, "{\"jsonrpc\":\"2.0\",\"method\":\"notifications/progress\",\"params\":{\"progressToken\":\"abc\",\"progress\":7}}") == 1, "progress notif minimal");

    # ---------------- session: validate_protocol_version ----------------
    assert_eq(validate_protocol_version("2025-11-25"), 0, "proto 2025-11-25 ok");
    assert_eq(validate_protocol_version("2025-03-26"), 0, "proto 2025-03-26 ok");
    assert_eq(validate_protocol_version("2024-11-05"), 0, "proto 2024-11-05 ok");
    assert(validate_protocol_version("1999-01-01") != 0, "proto 1999 rejected");
    assert(validate_protocol_version(0) != 0, "null proto rejected");

    # ---------------- session: validate_origin ----------------
    assert_eq(validate_origin("", 0), 0, "empty origin allowed");
    assert_eq(validate_origin(0, 0), 0, "null origin allowed");

    var allowed_star = vec_new();
    vec_push(allowed_star, "*");
    assert_eq(validate_origin("http://evil.com", allowed_star), 0, "wildcard allows");

    var allowed_loop = vec_new();
    vec_push(allowed_loop, "http://localhost:8090");
    assert_eq(validate_origin("http://localhost:8090", allowed_loop), 0, "matched origin");
    assert(validate_origin("http://evil.com", allowed_loop) != 0, "unmatched origin");

    var allowed_empty = vec_new();
    assert(validate_origin("http://localhost", allowed_empty) != 0, "empty list strict mode");

    # ---------------- session: SessionStore lifecycle ----------------
    var store = session_store_default();
    assert_eq(session_store_active_count(store), 0, "fresh store empty");
    var sid_a = session_store_create(store, "2025-11-25");
    assert(sid_a != 0, "sid created");
    assert_eq(strlen(sid_a), 32, "sid is 32 hex chars");
    assert_eq(session_store_active_count(store), 1, "one session");
    var s = session_store_validate(store, sid_a);
    assert(s != 0, "validate returns session");
    assert(streq(mcp_session_protocol_version(s), "2025-11-25") == 1, "session proto");
    assert_eq(session_store_validate(store, "nonexistent_id"), 0, "unknown sid -> 0");

    var sid_b = session_store_create(store, "2024-11-05");
    assert_eq(session_store_active_count(store), 2, "two sessions");
    assert(streq(sid_a, sid_b) == 0, "session ids unique");

    assert_eq(session_store_remove(store, sid_a), 1, "remove returns 1");
    assert_eq(session_store_active_count(store), 1, "one left");
    assert_eq(session_store_remove(store, sid_a), 0, "remove again returns 0");
    assert_eq(session_store_remove(store, sid_b), 1, "remove last");
    assert_eq(session_store_active_count(store), 0, "store empty");

    # ---------------- session: prune_expired ----------------
    var short_store = session_store_new(1);
    session_store_create(short_store, "2025-11-25");
    session_store_create(short_store, "2025-11-25");
    sleep_ms(10);
    var pruned = session_store_prune_expired(short_store);
    assert_eq(pruned, 2, "pruned 2");
    assert_eq(session_store_active_count(short_store), 0, "after prune empty");

    # ---------------- HTTP: header parsing helpers ----------------
    var fake = alloc(512);
    var fake_n = 0;
    memcpy(fake, "POST /mcp HTTP/1.1", 18); fake_n = 18;
    store8(fake + fake_n, 13); store8(fake + fake_n + 1, 10); fake_n = fake_n + 2;
    memcpy(fake + fake_n, "Host: localhost:9999", 20); fake_n = fake_n + 20;
    store8(fake + fake_n, 13); store8(fake + fake_n + 1, 10); fake_n = fake_n + 2;
    memcpy(fake + fake_n, "Content-Length: 5", 17); fake_n = fake_n + 17;
    store8(fake + fake_n, 13); store8(fake + fake_n + 1, 10); fake_n = fake_n + 2;
    memcpy(fake + fake_n, "Origin: http://x", 16); fake_n = fake_n + 16;
    store8(fake + fake_n, 13); store8(fake + fake_n + 1, 10); fake_n = fake_n + 2;
    store8(fake + fake_n, 13); store8(fake + fake_n + 1, 10); fake_n = fake_n + 2;
    memcpy(fake + fake_n, "hello", 5); fake_n = fake_n + 5;
    store8(fake + fake_n, 0);

    assert(streq(http_get_method(fake, fake_n), "POST") == 1, "http method");
    assert(streq(http_get_path(fake, fake_n), "/mcp") == 1, "http path");
    assert_eq(http_content_length(fake, fake_n), 5, "content-length 5");
    assert(streq(http_find_header(fake, fake_n, "Origin"), "http://x") == 1, "origin parsed");
    assert(streq(http_find_header(fake, fake_n, "Host"), "localhost:9999") == 1, "host parsed");
    assert(streq(http_find_header(fake, fake_n, "content-length"), "5") == 1, "case-insensitive");
    assert_eq(http_find_header(fake, fake_n, "Missing"), 0, "missing header -> 0");
    var bo = http_body_offset(fake, fake_n);
    assert(bo > 0, "body offset > 0");
    assert(memeq(fake + bo, "hello", 5) == 1, "body bytes match");

    # ---------------- discovery: announcement JSON ----------------
    var disc_tools = vec_new();
    var disc_sa = schema_new("object", 0, vec_new());
    vec_push(disc_tools, tool_def_new("svc_alpha", "alpha tool", disc_sa));
    vec_push(disc_tools, tool_def_with_version(tool_def_new("svc_beta", "beta tool", disc_sa), "2.0"));
    var ann = announcement_new("node-1", disc_tools);
    assert(streq(announcement_node_id(ann), "node-1") == 1, "ann node id");
    assert_eq(vec_len(announcement_tools(ann)), 2, "ann two tools");

    var ann_json = announcement_to_json(ann);
    assert_eq(jsonx_has(ann_json, "node_id"), 1, "ann json has node_id");
    assert_eq(jsonx_has(ann_json, "tools"), 1, "ann json has tools");
    assert(streq(jsonx_get_str(ann_json, "node_id"), "node-1") == 1, "ann json node-1");

    # ---------------- discovery: service publish (via EventSink) ----------------
    _ev_reset();
    var disc_sink = event_sink_new(&test_event_publish, 0);
    var disc = discovery_new("node-x", disc_sink);
    assert(streq(discovery_node_id(disc), "node-x") == 1, "disc node id");
    assert(streq(discovery_topic(disc), "bote/tool/announce") == 1, "disc topic");

    var emitted = discovery_announce(disc, disc_tools);
    assert(emitted != 0, "announce returns json");
    assert_eq(vec_len(_ev_topics), 1, "sink got 1");
    assert(streq(vec_get(_ev_topics, 0), "bote/tool/announce") == 1, "topic right");
    assert(streq(jsonx_get_str(vec_get(_ev_payloads, 0), "node_id"), "node-x") == 1, "payload node-x");

    var disc_quiet = discovery_new("node-q", 0);
    var quiet_json = discovery_announce(disc_quiet, disc_tools);
    assert(quiet_json != 0, "quiet still builds json");
    assert_eq(vec_len(_ev_topics), 1, "quiet didn't publish");

    # ---------------- discovery: receiver queue ----------------
    var rx = discovery_receiver_new();
    assert_eq(discovery_receiver_len(rx), 0, "empty receiver");
    assert_eq(discovery_receiver_try_recv(rx), 0, "empty try_recv -> 0");

    discovery_receiver_push(rx, "ann1");
    discovery_receiver_push(rx, "ann2");
    assert_eq(discovery_receiver_len(rx), 2, "two queued");
    assert(streq(discovery_receiver_try_recv(rx), "ann1") == 1, "fifo head ann1");
    assert(streq(discovery_receiver_try_recv(rx), "ann2") == 1, "fifo head ann2");
    assert_eq(discovery_receiver_try_recv(rx), 0, "drained -> 0");

    # ---------------- bridge: wrap_tool_result ----------------
    var wr_raw = wrap_tool_result("{\"answer\":42}");
    assert_eq(jsonx_has(wr_raw, "content"), 1, "raw wrapped has content");
    var wr_content = jsonx_get_raw(wr_raw, "content");
    assert(wr_content != 0, "content present");
    assert_eq(load8(wr_content), 91, "content is array");

    var wr_str = wrap_tool_result("\"just a string\"");
    assert_eq(jsonx_has(wr_str, "content"), 1, "string wrapped");

    var wr_null = wrap_tool_result(0);
    assert_eq(jsonx_has(wr_null, "content"), 1, "null wrapped to envelope");

    # Already-shaped result with content array → pass through verbatim
    var formatted = "{\"content\":[{\"type\":\"text\",\"text\":\"hello\"}]}";
    var wr_pt = wrap_tool_result(formatted);
    assert(streq(wr_pt, formatted) == 1, "passthrough preserves bytes");

    # ---------------- bridge: wrap_error_result ----------------
    var werr = wrap_error_result("something failed");
    assert_eq(jsonx_has(werr, "content"), 1, "err has content");
    assert_eq(jsonx_has(werr, "isError"), 1, "err has isError");
    var is_err_v = jsonx_get_raw(werr, "isError");
    assert(streq(is_err_v, "true") == 1, "isError true");

    # ---------------- bridge: process_message wraps tools/call ----------------
    var bdreg = registry_new();
    var bs = schema_new("object", 0, vec_new());
    registry_register(bdreg, tool_def_new("svc_echo", "echo", bs));
    var bd = dispatcher_new(bdreg);
    dispatcher_handle(bd, "svc_echo", &h_echo);

    var bp_call = bridge_process_message(
        "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/call\",\"params\":{\"name\":\"svc_echo\",\"arguments\":{\"k\":\"v\"}}}",
        bd);
    assert(bp_call != 0, "bridge tools/call returns json");
    var bp_result = jsonx_get_raw(bp_call, "result");
    assert(bp_result != 0, "result present");
    assert_eq(jsonx_has(bp_result, "content"), 1, "result wrapped in MCP envelope");

    # Non-tools-call methods pass through unchanged.
    var bp_init = bridge_process_message(
        "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\"}", bd);
    assert(bp_init != 0, "init returns json");
    var bp_init_result = jsonx_get_raw(bp_init, "result");
    assert_eq(jsonx_has(bp_init_result, "protocolVersion"), 1, "init has protocolVersion (not wrapped)");
    assert_eq(jsonx_has(bp_init_result, "content"), 0, "init not wrapped");

    # Tool-call error → wrapped as success + isError.
    var bp_unknown = bridge_process_message(
        "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"missing_tool\",\"arguments\":{}}}",
        bd);
    assert(bp_unknown != 0, "unknown returns json");
    var bp_un_result = jsonx_get_raw(bp_unknown, "result");
    assert(bp_un_result != 0, "error mapped to result");
    assert_eq(jsonx_has(bp_un_result, "isError"), 1, "isError flag");
    assert_eq(jsonx_has(bp_unknown, "error"), 0, "no top-level error obj");

    # Notification still produces no response.
    assert_eq(bridge_process_message("{\"jsonrpc\":\"2.0\",\"method\":\"notify\"}", bd), 0,
              "bridge notif -> 0");

    # ---------------- bridge: cors origin selection ----------------
    var cors_a = vec_new();
    vec_push(cors_a, "*");
    assert(streq(_bridge_cors_origin(cors_a, "http://anything"), "*") == 1, "cors wildcard");

    var cors_b = vec_new();
    vec_push(cors_b, "http://localhost:3000");
    vec_push(cors_b, "http://localhost:8080");
    assert(streq(_bridge_cors_origin(cors_b, "http://localhost:8080"), "http://localhost:8080") == 1, "cors exact match returned");
    # Unmatched origin → fall back to first allowed origin
    assert(streq(_bridge_cors_origin(cors_b, "http://evil.com"), "http://localhost:3000") == 1, "cors unmatched -> first");
    assert_eq(_bridge_cors_origin(0, "http://x"), "*", "cors null vec -> wildcard");

    # ---------------- review punch: schema bounds at exact min/max ----------------
    var ps_b1 = vec_new();
    vec_push(ps_b1, schema_prop_new("age", "{\"type\":\"integer\",\"minimum\":0,\"maximum\":150}"));
    var c_b1 = compiled_compile(schema_new("object", ps_b1, vec_new()));
    assert_eq(vec_len(compiled_validate(c_b1, "{\"age\":0}")), 0, "exact min ok");
    assert_eq(vec_len(compiled_validate(c_b1, "{\"age\":150}")), 0, "exact max ok");
    assert_eq(vec_len(compiled_validate(c_b1, "{\"age\":-1}")), 1, "min - 1 fails");
    assert_eq(vec_len(compiled_validate(c_b1, "{\"age\":151}")), 1, "max + 1 fails");

    # ---------------- review punch: codec pure-notification batch -> 0 ----------------
    var pure_notifs = codec_process_message(
        "[{\"jsonrpc\":\"2.0\",\"method\":\"a\"},{\"jsonrpc\":\"2.0\",\"method\":\"b\"},{\"jsonrpc\":\"2.0\",\"method\":\"c\"}]",
        bd);
    assert_eq(pure_notifs, 0, "pure-notification batch returns 0");

    # ================================================================
    # v1.1.0: audit + events + dispatcher wire-up
    # ================================================================

    # ---------------- events: topic constants ----------------
    assert(streq(TOPIC_TOOL_COMPLETED(), "bote/tool/completed") == 1, "topic completed");
    assert(streq(TOPIC_TOOL_FAILED(), "bote/tool/failed") == 1, "topic failed");
    assert(streq(TOPIC_TOOL_REGISTERED(), "bote/tool/registered") == 1, "topic registered");
    assert(streq(TOPIC_TOOL_DEREGISTERED(), "bote/tool/deregistered") == 1, "topic deregistered");
    assert(streq(TOPIC_TOOL_DEPRECATED(), "bote/tool/deprecated") == 1, "topic deprecated");
    assert(streq(TOPIC_TOOL_ANNOUNCE(), "bote/tool/announce") == 1, "topic announce");

    # ---------------- events: noop sink is safe ----------------
    var noop_ev = event_sink_noop();
    event_sink_publish(noop_ev, "any/topic", "{}");
    event_sink_publish(0, "any/topic", "{}");
    assert(noop_ev != 0, "noop sink is allocated");
    assert_eq(event_sink_publish_fp(noop_ev), 0, "noop fp is 0");

    # ---------------- events: real sink invocation ----------------
    _ev_reset();
    var live_ev = event_sink_new(&test_event_publish, 0);
    event_sink_publish(live_ev, "topic.a", "{\"k\":1}");
    event_sink_publish(live_ev, "topic.b", "[1,2]");
    assert_eq(vec_len(_ev_topics), 2, "two events");
    assert(streq(vec_get(_ev_topics, 0), "topic.a") == 1, "first topic");
    assert(streq(vec_get(_ev_payloads, 1), "[1,2]") == 1, "second payload");

    # ---------------- audit: ToolCallEvent + JSON ----------------
    var ev_ok = tool_call_event_new("echo", 42, 1, 0, "agent-1");
    assert(streq(tool_call_event_tool_name(ev_ok), "echo") == 1, "ev tool_name");
    assert_eq(tool_call_event_duration_ms(ev_ok), 42, "ev duration");
    assert_eq(tool_call_event_success(ev_ok), 1, "ev success");
    var json_ok = tool_call_event_to_json(ev_ok);
    assert(streq(json_ok, "{\"tool_name\":\"echo\",\"duration_ms\":42,\"success\":true,\"caller_id\":\"agent-1\"}") == 1, "ev json ok");

    var ev_fail = tool_call_event_new("broken", 5, 0, "handler crashed", 0);
    var json_fail = tool_call_event_to_json(ev_fail);
    assert(streq(json_fail, "{\"tool_name\":\"broken\",\"duration_ms\":5,\"success\":false,\"error\":\"handler crashed\"}") == 1, "ev json fail");
    # error and caller_id both omitted when 0
    var ev_min = tool_call_event_new("plain", 1, 1, 0, 0);
    var json_min = tool_call_event_to_json(ev_min);
    assert(streq(json_min, "{\"tool_name\":\"plain\",\"duration_ms\":1,\"success\":true}") == 1, "ev json min");

    # ---------------- audit: noop sink is safe ----------------
    audit_sink_log(0, ev_ok);
    audit_sink_log(audit_sink_noop(), ev_ok);

    # ---------------- audit: real sink invocation ----------------
    _audit_reset();
    var alive = audit_sink_new(&test_audit_log, 0);
    audit_sink_log(alive, ev_ok);
    audit_sink_log(alive, ev_fail);
    assert_eq(vec_len(_audit_events), 2, "audit got 2");
    assert(streq(tool_call_event_tool_name(vec_get(_audit_events, 0)), "echo") == 1, "audit[0] echo");
    assert(streq(tool_call_event_tool_name(vec_get(_audit_events, 1)), "broken") == 1, "audit[1] broken");

    # ---------------- dispatcher: wire-up audit + events ----------------
    _ev_reset();
    _audit_reset();
    var wreg = registry_new();
    registry_register(wreg, tool_def_new("svc_echo", "echo", schema_new("object", 0, vec_new())));
    var wd = dispatcher_new(wreg);
    dispatcher_handle(wd, "svc_echo", &h_echo);
    dispatcher_set_audit(wd, audit_sink_new(&test_audit_log, 0));
    dispatcher_set_events(wd, event_sink_new(&test_event_publish, 0));

    # tools/call success → audit + bote/tool/completed
    var w_call = req_with_params(req_new("1", "tools/call"),
        "{\"name\":\"svc_echo\",\"arguments\":{\"k\":\"v\"},\"caller_id\":\"agent-x\"}");
    var w_resp = dispatcher_dispatch(wd, w_call);
    assert(w_resp != 0, "wire call returns response");
    assert_eq(vec_len(_audit_events), 1, "1 audit event");
    var w_ev = vec_get(_audit_events, 0);
    assert(streq(tool_call_event_tool_name(w_ev), "svc_echo") == 1, "wire audit name");
    assert_eq(tool_call_event_success(w_ev), 1, "wire audit success");
    assert(streq(tool_call_event_caller_id(w_ev), "agent-x") == 1, "wire caller_id");
    assert_eq(vec_len(_ev_topics), 1, "1 event topic");
    assert(streq(vec_get(_ev_topics, 0), "bote/tool/completed") == 1, "completed topic");

    # tools/call where the tool is registered but its handler isn't
    # → audit + bote/tool/failed (validate_params catches truly-unknown names
    #   earlier without emitting; that path mirrors the Rust behavior).
    _ev_reset();
    _audit_reset();
    registry_register(wreg, tool_def_new("svc_unhandled", "no handler",
                                         schema_new("object", 0, vec_new())));
    var w_unk = dispatcher_dispatch(wd, req_with_params(req_new("2", "tools/call"),
        "{\"name\":\"svc_unhandled\",\"arguments\":{}}"));
    assert(resp_error_obj(w_unk) != 0, "unhandled tool returns error");
    assert_eq(vec_len(_audit_events), 1, "fail logged");
    assert_eq(tool_call_event_success(vec_get(_audit_events, 0)), 0, "fail success=0");
    assert_eq(vec_len(_ev_topics), 1, "fail emitted");
    assert(streq(vec_get(_ev_topics, 0), "bote/tool/failed") == 1, "failed topic");

    # And: truly-unknown tool name (caught by validate_params) does NOT emit
    # — matches Rust which only audits at the handler-lookup boundary.
    _ev_reset();
    _audit_reset();
    var w_miss = dispatcher_dispatch(wd, req_with_params(req_new("2b", "tools/call"),
        "{\"name\":\"never_existed\",\"arguments\":{}}"));
    assert(resp_error_obj(w_miss) != 0, "missing tool returns error");
    assert_eq(vec_len(_audit_events), 0, "validate-stage err: no audit");
    assert_eq(vec_len(_ev_topics), 0, "validate-stage err: no event");

    # initialize + tools/list do NOT emit tool-call events
    _ev_reset();
    _audit_reset();
    dispatcher_dispatch(wd, req_new("3", "initialize"));
    dispatcher_dispatch(wd, req_new("4", "tools/list"));
    assert_eq(vec_len(_audit_events), 0, "init/list no audit");
    assert_eq(vec_len(_ev_topics), 0, "init/list no events");

    # ---------------- dispatcher: register/deregister emit topics ----------------
    _ev_reset();
    var ok_reg2 = dispatcher_register_tool(wd,
        tool_def_new("svc_dyn", "dyn", schema_new("object", 0, vec_new())), &h_echo);
    assert_eq(ok_reg2, 0, "dyn register ok");
    assert_eq(vec_len(_ev_topics), 1, "register emitted");
    assert(streq(vec_get(_ev_topics, 0), "bote/tool/registered") == 1, "registered topic");
    assert(streq(jsonx_get_str(vec_get(_ev_payloads, 0), "tool_name"), "svc_dyn") == 1, "register payload");

    _ev_reset();
    dispatcher_deregister_tool(wd, "svc_dyn");
    assert_eq(vec_len(_ev_topics), 1, "dereg emitted");
    assert(streq(vec_get(_ev_topics, 0), "bote/tool/deregistered") == 1, "deregistered topic");

    # ---------------- dispatcher: deprecated tool emits TOPIC_TOOL_DEPRECATED on call ----------------
    _ev_reset();
    _audit_reset();
    registry_register(wreg, tool_def_with_deprecated(
        tool_def_new("svc_old", "old", schema_new("object", 0, vec_new())),
        "use svc_new instead"));
    dispatcher_handle(wd, "svc_old", &h_echo);
    dispatcher_dispatch(wd, req_with_params(req_new("5", "tools/call"),
        "{\"name\":\"svc_old\",\"arguments\":{}}"));
    # Expect: bote/tool/deprecated then bote/tool/completed
    assert_eq(vec_len(_ev_topics), 2, "two events on deprecated call");
    assert(streq(vec_get(_ev_topics, 0), "bote/tool/deprecated") == 1, "deprecated first");
    assert(streq(vec_get(_ev_topics, 1), "bote/tool/completed") == 1, "completed second");
    assert(streq(jsonx_get_str(vec_get(_ev_payloads, 0), "message"), "use svc_new instead") == 1, "deprecation message");

    # ---------------- dispatcher: noop sinks (default) don't break anything ----------------
    var bare = dispatcher_new(registry_new());
    registry_register(dispatcher_registry(bare),
        tool_def_new("svc_bare", "bare", schema_new("object", 0, vec_new())));
    dispatcher_handle(bare, "svc_bare", &h_echo);
    var bare_resp = dispatcher_dispatch(bare, req_with_params(req_new("9", "tools/call"),
        "{\"name\":\"svc_bare\",\"arguments\":{\"x\":1}}"));
    assert(bare_resp != 0, "bare dispatch still works");
    assert_eq(resp_error_obj(bare_resp), 0, "bare success no error");

    # ================================================================
    # v1.2.x: LibroAudit + MajraEvents adapter SHAPES
    # ================================================================
    # Live chain growth + pubsub deliver paths are exercised in the
    # standalone examples/audit_demo.cyr program (runs as a separate
    # binary because libro+majra+full-test cross-product trips a heap
    # heisenbug — see programs/README in v1.2.1).

    # ---------------- audit_libro: struct + accessors ----------------
    var la = libro_audit_new(99);
    assert_eq(libro_audit_chain(la), 99, "la chain stored");
    assert(streq(libro_audit_source(la), "bote") == 1, "la default source");
    assert_eq(libro_audit_agent_id(la), 0, "la default agent_id");
    libro_audit_with_source(la, "my-server");
    libro_audit_with_agent_id(la, "default-agent");
    assert(streq(libro_audit_source(la), "my-server") == 1, "custom source");
    assert(streq(libro_audit_agent_id(la), "default-agent") == 1, "configured agent_id");

    # ---------------- audit_libro: AuditSink wire-up shape ----------------
    var libro_sink = audit_sink_new(&libro_audit_log, la);
    assert(audit_sink_log_fp(libro_sink) != 0, "libro audit fp wired");
    assert_eq(audit_sink_ctx(libro_sink), la, "libro audit ctx is LibroAudit");
    # NB: live chain growth still triggers the v1.2.1 heap heisenbug here
    # despite the freed function-count budget — see CHANGELOG. Adapter
    # itself is correct (proved in isolated probes).

    # ================================================================
    # v1.4.0: streamable HTTP transport — data layer
    # ================================================================

    # ---------------- EventIdGenerator ----------------
    var gen = event_id_gen_new();
    var id0 = event_id_gen_next(gen);
    var id1 = event_id_gen_next(gen);
    var id2 = event_id_gen_next(gen);
    assert(streq(id0, "evt-0") == 1, "first id evt-0");
    assert(streq(id1, "evt-1") == 1, "second id evt-1");
    assert(streq(id2, "evt-2") == 1, "third id evt-2");

    # ---------------- StreamEvent + wire format ----------------
    var ev1 = stream_event_new("evt-7", "{\"hello\":\"world\"}");
    assert(streq(stream_event_id(ev1), "evt-7") == 1, "ev id");
    assert(streq(stream_event_type(ev1), "message") == 1, "ev type default");
    assert(streq(stream_event_data(ev1), "{\"hello\":\"world\"}") == 1, "ev data");
    var wire = stream_event_to_wire(ev1);
    assert(streq(wire, "id: evt-7\nevent: message\ndata: {\"hello\":\"world\"}\n\n") == 1,
           "ev wire format");

    var primer = stream_event_primer("evt-0");
    var primer_wire = stream_event_to_wire(primer);
    assert(streq(primer_wire, "id: evt-0\nevent: message\ndata: \n\n") == 1,
           "primer wire (empty data)");

    # ---------------- ResumptionBuffer ----------------
    var rb = resumption_buffer_new(3);
    assert_eq(resumption_buffer_len(rb), 0, "buffer empty");
    resumption_buffer_push(rb, stream_event_new("evt-1", "a"));
    resumption_buffer_push(rb, stream_event_new("evt-2", "b"));
    resumption_buffer_push(rb, stream_event_new("evt-3", "c"));
    assert_eq(resumption_buffer_len(rb), 3, "buffer 3");
    # Push one more — evicts evt-1
    resumption_buffer_push(rb, stream_event_new("evt-4", "d"));
    assert_eq(resumption_buffer_len(rb), 3, "buffer still 3 (capped)");
    var first = vec_get(resumption_buffer_events(rb), 0);
    assert(streq(stream_event_id(first), "evt-2") == 1, "evt-1 evicted, head = evt-2");

    # events_after — present id
    var after2 = resumption_buffer_events_after(rb, "evt-2");
    assert_eq(vec_len(after2), 2, "after evt-2 → 2 events");
    assert(streq(stream_event_id(vec_get(after2, 0)), "evt-3") == 1, "next is evt-3");
    assert(streq(stream_event_id(vec_get(after2, 1)), "evt-4") == 1, "then evt-4");

    # events_after — absent id (returns empty, caller must full-resync)
    var after_missing = resumption_buffer_events_after(rb, "evt-99");
    assert_eq(vec_len(after_missing), 0, "missing id → empty");

    # events_after — defensive guards (p(-1) hardening)
    assert_eq(vec_len(resumption_buffer_events_after(rb, 0)), 0, "null id → empty (no segfault)");
    assert_eq(vec_len(resumption_buffer_events_after(rb, "")), 0, "empty id → empty");

    # ---------------- StreamableConfig ----------------
    var scfg = streamable_config_new("/mcp", 0x0100007F, 8392);
    assert(streq(streamable_config_path(scfg), "/mcp") == 1, "scfg path");
    assert_eq(streamable_config_addr(scfg), 0x0100007F, "scfg addr");
    assert_eq(streamable_config_port(scfg), 8392, "scfg port");
    assert_eq(streamable_config_retry_ms(scfg), 5000, "scfg default retry_ms");
    assert_eq(streamable_config_session_store(scfg), 0, "scfg no default session");

    streamable_config_with_retry_ms(scfg, 1000);
    assert_eq(streamable_config_retry_ms(scfg), 1000, "scfg custom retry_ms");

    # ---------------- POST/GET path matching uses http_path_only ----------------
    # Sanity that the transport's path check ignores the query string —
    # exercises the same stdlib helper but at our usage site.
    assert(streq(http_path_only("/mcp?lastEventId=evt-7"), "/mcp") == 1,
           "path strips query for routing");

    # ---------------- events_majra: EventSink wire-up shape ----------------
    var majra_fp = &majra_events_publish;
    assert(majra_fp != 0, "majra events fp addressable");
    var majra_sink = event_sink_new(majra_fp, 0);     # ctx=0 → adapter no-ops
    event_sink_publish(majra_sink, "any/topic", "{}");  # safe with ctx=0

    # v1.5.0: WebSocket transport — config + handler wire-up
    var wcfg = ws_config_new("/mcp", 0x0100007F, 8393);
    assert(streq(ws_config_path(wcfg), "/mcp") == 1, "wcfg path");
    assert_eq(ws_config_addr(wcfg), 0x0100007F, "wcfg addr");
    assert_eq(ws_config_port(wcfg), 8393, "wcfg port");
    assert_eq(ws_config_allowed_origins(wcfg), 0, "wcfg no default origins");
    assert_eq(ws_config_require_protocol(wcfg), 0, "wcfg protocol not required");
    assert_eq(ws_config_dispatcher(wcfg), 0, "wcfg dispatcher unset pre-run");
    var worigins = vec_new();
    vec_push(worigins, "http://localhost");
    ws_config_with_allowed_origins(wcfg, worigins);
    assert_eq(ws_config_allowed_origins(wcfg), worigins, "wcfg origins wired");
    ws_config_with_require_protocol(wcfg, 1);
    assert_eq(ws_config_require_protocol(wcfg), 1, "wcfg require_protocol");
    assert(&_bote_ws_handler != 0, "_bote_ws_handler fp");
    var wdisp = dispatcher_new(registry_new());
    store64(wcfg + 40, wdisp);
    assert_eq(ws_config_dispatcher(wcfg), wdisp, "wcfg dispatcher wired");

    # v1.6.0: libro_tools tests live in tests/bote_libro_tools.tcyr
    # (splitting to stay under the cyrius 4.5.1 parser identifier-buffer cap).

    return assert_summary();
}

var rc = main();
syscall(SYS_EXIT, rc);
