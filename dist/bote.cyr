    var r = alloc(32);
    store64(r, "2.0");
    store64(r + 8, 0);
    store64(r + 16, method);
    store64(r + 24, "null");
    return r;
}

fn req_with_params(r, params) {
    store64(r + 24, params);
    return r;
}

fn req_jsonrpc(r) { return load64(r); }
fn req_id(r) { return load64(r + 8); }
fn req_method(r) { return load64(r + 16); }
fn req_params(r) { return load64(r + 24); }

fn req_is_notification(r) {
    if (load64(r + 8) == 0) { return 1; }
    return 0;
}

# JsonRpcError (24 bytes):
#   +0  code    i64 (i32 in Rust; cyrius is i64 always)
#   +8  message cstr
#   +16 data    cstr or 0 (raw JSON literal)

