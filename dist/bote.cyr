# bote::registry — Tool registration, discovery, and parameter validation
# Mirrors rust-old/src/registry.rs
#
# CompiledSchema integration is deferred until src/schema.cyr lands.
# For now, validate_params performs:
#   1. "params is JSON object" check (leading non-ws byte == '{')
#   2. Required-field-present check via lib/json.cyr (flat parse)

include "lib/hashmap.cyr"
include "lib/bayan.cyr"

# ================================================================
# ToolAnnotations — tri-state hint flags (MCP 2025-11-25)
# ================================================================
#
# Each hint is i64: 0 = unset, 1 = true, 2 = false.
# Serialization: skip when unset; emit "true" or "false" otherwise.
#
# Layout (32 bytes):
#   +0  read_only_hint
#   +8  destructive_hint
#   +16 idempotent_hint
#   +24 open_world_hint

enum AnnHint {
    HINT_UNSET = 0;
    HINT_TRUE = 1;
    HINT_FALSE = 2;
}

fn ann_new() {
    var a = alloc(32);
    store64(a, HINT_UNSET);
    store64(a + 8, HINT_UNSET);
    store64(a + 16, HINT_UNSET);
    store64(a + 24, HINT_UNSET);
    return a;
}

fn ann_read_only_hint(a) { return load64(a); }
fn ann_destructive_hint(a) { return load64(a + 8); }
fn ann_idempotent_hint(a) { return load64(a + 16); }
fn ann_open_world_hint(a) { return load64(a + 24); }

fn ann_set_read_only(a, v) { store64(a, v); return a; }
fn ann_set_destructive(a, v) { store64(a + 8, v); return a; }
fn ann_set_idempotent(a, v) { store64(a + 16, v); return a; }
fn ann_set_open_world(a, v) { store64(a + 24, v); return a; }

# Preset: read-only tool (no side effects).
fn ann_read_only() {
    var a = ann_new();
    store64(a, HINT_TRUE);
    store64(a + 8, HINT_FALSE);
    store64(a + 16, HINT_TRUE);
    store64(a + 24, HINT_FALSE);
    return a;
}

# Preset: destructive tool.
fn ann_destructive() {
    var a = ann_new();
    store64(a, HINT_FALSE);
    store64(a + 8, HINT_TRUE);
    store64(a + 16, HINT_FALSE);
    store64(a + 24, HINT_TRUE);
    return a;
}

# ================================================================
# ToolSchema — JSON Schema subset
# ================================================================
#
# Layout (24 bytes):
#   +0  schema_type cstr ("object", "string", ...)
#   +8  properties  vec of {key_cstr, value_cstr_raw_json} pairs (16 bytes each) or 0
#   +16 required    vec of cstr or 0

fn schema_new(schema_type, properties_vec, required_vec) {
    var s = alloc(24);
    store64(s, schema_type);
    store64(s + 8, properties_vec);
    store64(s + 16, required_vec);
    return s;
}

fn schema_type(s) { return load64(s); }
fn schema_properties(s) { return load64(s + 8); }
fn schema_required(s) { return load64(s + 16); }

# Property pair (16 bytes): key_cstr, value_cstr (raw JSON literal)
fn schema_prop_new(key, value) {
    var p = alloc(16);
    store64(p, key);
    store64(p + 8, value);
    return p;
}
fn schema_prop_key(p) { return load64(p); }
fn schema_prop_value(p) { return load64(p + 8); }

# ================================================================
# ToolDef
# ================================================================
#
# Layout (64 bytes):
#   +0  name         cstr
#   +8  description  cstr
#   +16 input_schema ptr to ToolSchema
#   +24 version      cstr or 0
#   +32 deprecated   cstr or 0 (deprecation message)
#   +40 annotations  ptr to ToolAnnotations or 0
#   +48 compiled     ptr to CompiledSchema or 0 (set by tool_def_with_compiled)
#   +56 profiles     vec of cstr tags or 0 (set by tool_def_with_profiles)
#
# Profiles are opaque consumer-defined tags (e.g. "security", "web", "full")
# used to expose curated tool subsets via a `profile` filter on tools/list.
# bote does no interpretation — membership is exact-match; an untagged tool
# (profiles == 0) is in no profile. See _build_tools_list_result in dispatch.

fn tool_def_new(name, description, input_schema) {
    var d = alloc(64);
    store64(d, name);
    store64(d + 8, description);
    store64(d + 16, input_schema);
    store64(d + 24, 0);
    store64(d + 32, 0);
    store64(d + 40, 0);
    store64(d + 48, 0);
    store64(d + 56, 0);
    return d;
}

fn tool_def_with_version(d, version) { store64(d + 24, version); return d; }
fn tool_def_with_deprecated(d, msg) { store64(d + 32, msg); return d; }
fn tool_def_with_annotations(d, ann) { store64(d + 40, ann); return d; }
fn tool_def_with_compiled(d, c) { store64(d + 48, c); return d; }
fn tool_def_with_profiles(d, profiles) { store64(d + 56, profiles); return d; }

fn tool_def_name(d) { return load64(d); }
fn tool_def_description(d) { return load64(d + 8); }
fn tool_def_input_schema(d) { return load64(d + 16); }
fn tool_def_version(d) { return load64(d + 24); }
fn tool_def_deprecated(d) { return load64(d + 32); }
fn tool_def_annotations(d) { return load64(d + 40); }
fn tool_def_compiled(d) { return load64(d + 48); }
fn tool_def_profiles(d) { return load64(d + 56); }

# Exact-match membership: 1 if `profile` (non-null) is one of the tool's
# profile tags, else 0. A null profile or an untagged tool returns 0.
fn tool_def_has_profile(d, profile) {
    if (profile == 0) { return 0; }
    var profs = tool_def_profiles(d);
    if (profs == 0) { return 0; }
    var n = vec_len(profs);
    var i = 0;
    while (i < n) {
        if (streq(vec_get(profs, i), profile) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# ToolRegistry
# ================================================================
#
# Layout (24 bytes):
#   +0  entries  hashmap: name_cstr -> ToolDef ptr
#   +8  versions hashmap: name_cstr -> vec of ToolDef ptrs
#   +16 names    vec of name_cstr (insertion order, for list())

fn tool_registry_new() {
    var r = alloc(24);
    store64(r, map_new());
    store64(r + 8, map_new());
    store64(r + 16, vec_new());
    return r;
}

fn registry_entries(r) { return load64(r); }
fn registry_versions_map(r) { return load64(r + 8); }
fn registry_names(r) { return load64(r + 16); }

fn registry_register(r, tool_def) {
    var name = tool_def_name(tool_def);
    var entries = registry_entries(r);
    var names = registry_names(r);
    if (map_has(entries, name) == 0) {
        vec_push(names, name);
    }
    map_set(entries, name, tool_def);

    var ver = tool_def_version(tool_def);
    if (ver != 0) {
        var vmap = registry_versions_map(r);
        var bucket = map_get(vmap, name);
        if (bucket == 0) {
            bucket = vec_new();
            map_set(vmap, name, bucket);
        }
        vec_push(bucket, tool_def);
    }
    return 0;
}

fn registry_get(r, name) {
    return map_get(registry_entries(r), name);
}

fn registry_contains(r, name) {
    return map_has(registry_entries(r), name);
}

fn registry_len(r) {
    return map_count(registry_entries(r));
}

fn registry_is_empty(r) {
    if (registry_len(r) == 0) { return 1; }
    return 0;
}

# Return a vec of ToolDef pointers in insertion order.
fn registry_list(r) {
    var out = vec_new();
    var names = registry_names(r);
    var entries = registry_entries(r);
    var n = vec_len(names);
    var i = 0;
    while (i < n) {
        var name = vec_get(names, i);
        if (map_has(entries, name) == 1) {
            vec_push(out, map_get(entries, name));
        }
        i = i + 1;
    }
    return out;
}

fn registry_get_versioned(r, name, version) {
    var bucket = map_get(registry_versions_map(r), name);
    if (bucket == 0) { return 0; }
    var n = vec_len(bucket);
    var i = 0;
    while (i < n) {
        var t = vec_get(bucket, i);
        var v = tool_def_version(t);
        if (v != 0 && streq(v, version) == 1) { return t; }
        i = i + 1;
    }
    return 0;
}

fn registry_list_versions(r, name) {
    var bucket = map_get(registry_versions_map(r), name);
    if (bucket == 0) { return vec_new(); }
    return bucket;
}

# Remove a tool. Returns the removed ToolDef ptr or 0 if absent.
fn registry_deregister(r, name) {
    var entries = registry_entries(r);
    var existing = map_get(entries, name);
    if (existing == 0) { return 0; }
    map_delete(entries, name);
    map_delete(registry_versions_map(r), name);
    # Compact the names vec.
    var names = registry_names(r);
    var n = vec_len(names);
    var i = 0;
    while (i < n) {
        if (streq(vec_get(names, i), name) == 1) {
            vec_remove(names, i);
            i = n;
        }
        i = i + 1;
    }
    return existing;
}

# Mark a tool deprecated with a message. No-op if tool absent.
fn registry_deprecate(r, name, message) {
    var t = registry_get(r, name);
    if (t == 0) { return 0; }
    tool_def_with_deprecated(t, message);
    return 0;
}

# ================================================================
# validate_params
# ================================================================
#
# Returns 0 on success, or a BoteError ptr on failure.
# Caller checks `bote_err_tag(err)` for the specific failure mode.

# Trim leading whitespace; return first non-ws byte (0 if EOS).
fn _vp_first_nonws(s) {
    if (s == 0) { return 0; }
    var i = 0;
    while (1 == 1) {
        var c = load8(s + i);
        if (c == 0) { return 0; }
        if (c == 32 || c == 9 || c == 10 || c == 13) { i = i + 1; }
        else { return c; }
    }
    return 0;
}

fn registry_validate_params(r, name, params_cstr) {
    if (registry_contains(r, name) == 0) {
        return bote_err_new(ERR_TOOL_NOT_FOUND, name, 0);
    }
    var t = registry_get(r, name);

    # 1. params must be a JSON object.
    if (_vp_first_nonws(params_cstr) != 123) {
        return bote_err_new(ERR_INVALID_PARAMS, name, "params must be an object");
    }

    # 2. Compiled schema path (preferred — full type/enum/bounds/nested checks).
    var compiled = tool_def_compiled(t);
    if (compiled != 0) {
        var violations = compiled_validate(compiled, params_cstr);
        if (vec_len(violations) > 0) {
            return bote_err_with_violations(ERR_SCHEMA_VIOLATION, name, violations);
        }
        return 0;
    }

    # 3. Fallback: required-field-present check via lib/json.cyr.
    var schema = tool_def_input_schema(t);
    var required = schema_required(schema);
    if (required == 0) { return 0; }
    var nreq = vec_len(required);
    if (nreq == 0) { return 0; }

    var pairs = json_parse(str_from(params_cstr));
    var i = 0;
    while (i < nreq) {
        var req_key = vec_get(required, i);
        if (json_get(pairs, str_from(req_key)) == 0) {
            var sb = str_builder_new();
            str_builder_add_cstr(sb, "missing required field: ");
            str_builder_add_cstr(sb, req_key);
            var msg = str_builder_build(sb);
            return bote_err_new(ERR_INVALID_PARAMS, name, str_data(msg));
        }
        i = i + 1;
    }
    return 0;
}

# --- prompts.cyr ---

# bote::prompts — MCP prompts capability (prompts/list + prompts/get)
#
# Mirrors the tool registry (src/registry.cyr): a PromptRegistry holds
# prompt metadata (for prompts/list) plus a name→handler map (for
# prompts/get generation). The dispatcher owns an optional PromptRegistry;
# the `prompts` capability is advertised at initialize iff one is present
# (see src/dispatch.cyr _build_capabilities). JSON serialization lives in
# dispatch.cyr alongside the other MCP method builders.
#
# Prompt handler ABI (mirrors the 2.0 tool ABI):
#   fn h(arguments_cstr, claims) → result_cstr
# where `arguments_cstr` is the prompts/get `arguments` object (JSON) and
# the returned cstr is the full prompts/get result body, e.g.
#   {"description":"...","messages":[{"role":"user","content":{...}}]}
#
# Requires (entry point includes, before this module): hashmap (pulled by
# src/registry.cyr), vec, str, string. No local includes — matches dispatch.

# ================================================================
# PromptArgument — one declared argument (surfaced in prompts/list)
# ================================================================
#
# Layout (24 bytes):
#   +0  name        cstr
#   +8  description cstr or 0
#   +16 required    i64 (0 = optional, 1 = required)

fn prompt_arg_new(name, description, required) {
    var a = alloc(24);
    store64(a, name);
    store64(a + 8, description);
    store64(a + 16, required);
    return a;
}

fn prompt_arg_name(a) { return load64(a); }
fn prompt_arg_description(a) { return load64(a + 8); }
fn prompt_arg_required(a) { return load64(a + 16); }

# ================================================================
# PromptDef — prompt metadata
# ================================================================
#
# Layout (24 bytes):
#   +0  name        cstr
#   +8  description cstr or 0
#   +16 arguments   vec of PromptArgument ptrs or 0

fn prompt_def_new(name, description, arguments) {
    var p = alloc(24);
    store64(p, name);
    store64(p + 8, description);
    store64(p + 16, arguments);
    return p;
}

fn prompt_def_name(p) { return load64(p); }
fn prompt_def_description(p) { return load64(p + 8); }
fn prompt_def_arguments(p) { return load64(p + 16); }

# ================================================================
# PromptRegistry
# ================================================================
#
# Layout (24 bytes):
#   +0  entries  hashmap: name_cstr -> PromptDef ptr
#   +8  names    vec of name_cstr (insertion order, for list())
#   +16 handlers hashmap: name_cstr -> handler fn ptr

fn prompt_registry_new() {
    var r = alloc(24);
    store64(r, map_new());
    store64(r + 8, vec_new());
    store64(r + 16, map_new());
    return r;
}

fn prompt_registry_entries(r) { return load64(r); }
fn prompt_registry_names(r) { return load64(r + 8); }
fn prompt_registry_handlers(r) { return load64(r + 16); }

# Register (or replace) a prompt + its generator handler. Returns 0.
fn prompt_registry_register(r, prompt_def, handler_fp) {
    var name = prompt_def_name(prompt_def);
    var entries = prompt_registry_entries(r);
    if (map_has(entries, name) == 0) {
        vec_push(prompt_registry_names(r), name);
    }
    map_set(entries, name, prompt_def);
    map_set(prompt_registry_handlers(r), name, handler_fp);
    return 0;
}

fn prompt_registry_get(r, name) {
    return map_get(prompt_registry_entries(r), name);
}

fn prompt_registry_contains(r, name) {
    return map_has(prompt_registry_entries(r), name);
}

# Handler fn ptr for `name`, or 0 if the prompt is unknown.
fn prompt_registry_handler(r, name) {
    if (map_has(prompt_registry_handlers(r), name) == 0) { return 0; }
    return map_get(prompt_registry_handlers(r), name);
}

fn prompt_registry_len(r) {
    return map_count(prompt_registry_entries(r));
}

# Return a vec of PromptDef pointers in insertion order.
fn prompt_registry_list(r) {
    var out = vec_new();
    var names = prompt_registry_names(r);
    var entries = prompt_registry_entries(r);
    var n = vec_len(names);
    var i = 0;
    while (i < n) {
        var name = vec_get(names, i);
        if (map_has(entries, name) == 1) {
            vec_push(out, map_get(entries, name));
        }
        i = i + 1;
    }
    return out;
}

# --- resources.cyr ---

# bote::resources — MCP resources capability (resources/list + resources/read)
#
# Mirrors src/prompts.cyr: a ResourceRegistry holds resource metadata (for
# resources/list) plus a uri→handler map (for resources/read). The
# dispatcher owns an optional ResourceRegistry; the `resources` capability
# is advertised at initialize iff one is present (see src/dispatch.cyr
# _build_capabilities). JSON serialization for the listing lives in
# dispatch.cyr; read bodies are produced by the handler.
#
# Resource read-handler ABI (mirrors the 2.0 tool ABI):
#   fn h(uri_cstr, claims) → result_cstr
# where `uri_cstr` is the requested resource URI and the returned cstr is
# the full resources/read result body, e.g.
#   {"contents":[{"uri":"...","mimeType":"...","text":"..."}]}
# (MCP ResourceContents — bare uri/mimeType/text|blob, NOT a content block).
#
# subscribe / listChanged are intentionally out until a server→client push
# path exists (they need the notification channel that is not yet wired).
#
# Requires (entry point includes, before this module): hashmap (pulled by
# src/registry.cyr), vec, str, string. No local includes — matches dispatch.

# ================================================================
# ResourceDef — resource metadata (surfaced in resources/list)
# ================================================================
#
# Layout (32 bytes):
#   +0  uri         cstr
#   +8  name        cstr
#   +16 description cstr or 0
#   +24 mime_type   cstr or 0

fn resource_def_new(uri, name, description, mime_type) {
    var r = alloc(32);
    store64(r, uri);
    store64(r + 8, name);
    store64(r + 16, description);
    store64(r + 24, mime_type);
    return r;
}

fn resource_def_uri(r) { return load64(r); }
fn resource_def_name(r) { return load64(r + 8); }
fn resource_def_description(r) { return load64(r + 16); }
fn resource_def_mime_type(r) { return load64(r + 24); }

# ================================================================
# ResourceRegistry
# ================================================================
#
# Layout (24 bytes):
#   +0  entries  hashmap: uri_cstr -> ResourceDef ptr
#   +8  uris     vec of uri_cstr (insertion order, for list())
#   +16 handlers hashmap: uri_cstr -> handler fn ptr

fn resource_registry_new() {
    var r = alloc(24);
    store64(r, map_new());
    store64(r + 8, vec_new());
    store64(r + 16, map_new());
    return r;
}

fn resource_registry_entries(r) { return load64(r); }
fn resource_registry_uris(r) { return load64(r + 8); }
fn resource_registry_handlers(r) { return load64(r + 16); }

# Register (or replace) a resource + its read handler. Returns 0.
fn resource_registry_register(r, resource_def, handler_fp) {
    var uri = resource_def_uri(resource_def);
    var entries = resource_registry_entries(r);
    if (map_has(entries, uri) == 0) {
        vec_push(resource_registry_uris(r), uri);
    }
    map_set(entries, uri, resource_def);
    map_set(resource_registry_handlers(r), uri, handler_fp);
    return 0;
}

fn resource_registry_get(r, uri) {
    return map_get(resource_registry_entries(r), uri);
}

fn resource_registry_contains(r, uri) {
    return map_has(resource_registry_entries(r), uri);
}

# Read-handler fn ptr for `uri`, or 0 if the resource is unknown.
fn resource_registry_handler(r, uri) {
    if (map_has(resource_registry_handlers(r), uri) == 0) { return 0; }
    return map_get(resource_registry_handlers(r), uri);
}

fn resource_registry_len(r) {
    return map_count(resource_registry_entries(r));
}

# Return a vec of ResourceDef pointers in insertion order.
fn resource_registry_list(r) {
    var out = vec_new();
    var uris = resource_registry_uris(r);
    var entries = resource_registry_entries(r);
    var n = vec_len(uris);
    var i = 0;
    while (i < n) {
        var uri = vec_get(uris, i);
        if (map_has(entries, uri) == 1) {
            vec_push(out, map_get(entries, uri));
        }
        i = i + 1;
    }
    return out;
}

# --- events.cyr ---

# bote::events — event topic constants + EventSink abstraction
# Mirrors rust-old/src/events.rs (trait + topic constants).
#
# Cyrius has no traits, so EventSink is a (publish_fp, ctx) struct.
# Backends (e.g. MajraEvents in src/events_majra.cyr — v1.2) wrap their state
# in `ctx` and provide a publish function pointer with signature:
#
#   fn my_publish(ctx, topic_cstr, payload_json_cstr) → 0

# ================================================================
# Topic constants (cstr literals)
# ================================================================
fn TOPIC_TOOL_COMPLETED()    { return "bote/tool/completed"; }
fn TOPIC_TOOL_FAILED()       { return "bote/tool/failed"; }
fn TOPIC_TOOL_REGISTERED()   { return "bote/tool/registered"; }
fn TOPIC_TOOL_ANNOUNCE()     { return "bote/tool/announce"; }
fn TOPIC_TOOL_DISCOVERED()   { return "bote/tool/discovered"; }
fn TOPIC_TOOL_DEPRECATED()   { return "bote/tool/deprecated"; }
fn TOPIC_TOOL_DEREGISTERED() { return "bote/tool/deregistered"; }
fn TOPIC_SANDBOX_CREATED()   { return "bote/sandbox/created"; }
fn TOPIC_SANDBOX_DESTROYED() { return "bote/sandbox/destroyed"; }
fn TOPIC_SANDBOX_ERROR()     { return "bote/sandbox/error"; }

# ================================================================
# EventSink (16 bytes):
#   +0  publish_fp  function pointer (or 0 for no-op sink)
#   +8  ctx         opaque pointer passed to publish_fp
# ================================================================

fn event_sink_new(publish_fp, ctx) {
    var s = alloc(16);
    store64(s, publish_fp);
    store64(s + 8, ctx);
    return s;
}

# A no-op sink: publish_fp = 0, ctx = 0. Equivalent to "events disabled".
fn event_sink_noop() {
    return event_sink_new(0, 0);
}

fn event_sink_publish_fp(sink) { return load64(sink); }
fn event_sink_ctx(sink) { return load64(sink + 8); }

# Publish an event. Safe to call with sink==0 or noop sink (both no-op).
# topic and payload are cstrs; payload is a raw JSON literal (e.g. "{...}").
fn event_sink_publish(sink, topic, payload) {
    if (sink == 0) { return 0; }
    var fp = load64(sink);
    if (fp == 0) { return 0; }
    var ctx = load64(sink + 8);
    fncall3(fp, ctx, topic, payload);
    return 0;
}

# --- audit.cyr ---

# bote::audit — tool-call audit logging
# Mirrors rust-old/src/audit.rs (trait + ToolCallEvent).
#
# Cyrius has no traits, so AuditSink is a (log_fp, ctx) struct.
# Backends (e.g. LibroAudit in src/audit_libro.cyr — v1.2) wrap their state
# in `ctx` and provide a log function pointer with signature:
#
#   fn my_log(ctx, event_ptr) → 0

# ================================================================
# ToolCallEvent (40 bytes):
#   +0  tool_name     cstr
#   +8  duration_ms   i64
#   +16 success       0/1
#   +24 error         cstr or 0 (only set when success == 0)
#   +32 caller_id     cstr or 0
# ================================================================

fn tool_call_event_new(tool_name, duration_ms, success, error, caller_id) {
    var e = alloc(40);
    store64(e, tool_name);
    store64(e + 8, duration_ms);
    store64(e + 16, success);
    store64(e + 24, error);
    store64(e + 32, caller_id);
    return e;
}

fn tool_call_event_tool_name(e)   { return load64(e); }
fn tool_call_event_duration_ms(e) { return load64(e + 8); }
fn tool_call_event_success(e)     { return load64(e + 16); }
fn tool_call_event_error(e)       { return load64(e + 24); }
fn tool_call_event_caller_id(e)   { return load64(e + 32); }

# Serialize a ToolCallEvent to a JSON cstr. Skips error/caller_id when 0.
# Mirrors Rust's `#[serde(skip_serializing_if = "Option::is_none")]`.
fn tool_call_event_to_json(e) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"tool_name\":\"");
    _json_emit_escaped(sb, tool_call_event_tool_name(e));
    str_builder_add_cstr(sb, "\",\"duration_ms\":");
    str_builder_add_int(sb, tool_call_event_duration_ms(e));
    str_builder_add_cstr(sb, ",\"success\":");
    if (tool_call_event_success(e) == 1) { str_builder_add_cstr(sb, "true"); }
    else { str_builder_add_cstr(sb, "false"); }
    var err = tool_call_event_error(e);
    if (err != 0) {
        str_builder_add_cstr(sb, ",\"error\":\"");
        _json_emit_escaped(sb, err);
        str_builder_add_cstr(sb, "\"");
    }
    var cid = tool_call_event_caller_id(e);
    if (cid != 0) {
        str_builder_add_cstr(sb, ",\"caller_id\":\"");
        _json_emit_escaped(sb, cid);
        str_builder_add_cstr(sb, "\"");
    }
    str_builder_add_cstr(sb, "}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# AuditSink (16 bytes):
#   +0  log_fp  function pointer (or 0 for no-op sink)
#   +8  ctx     opaque pointer passed to log_fp
# ================================================================

fn audit_sink_new(log_fp, ctx) {
    var s = alloc(16);
    store64(s, log_fp);
    store64(s + 8, ctx);
    return s;
}

fn audit_sink_noop() { return audit_sink_new(0, 0); }
fn audit_sink_log_fp(sink) { return load64(sink); }
fn audit_sink_ctx(sink) { return load64(sink + 8); }

# Log an event. Safe to call with sink==0 or noop sink (both no-op).
fn audit_sink_log(sink, event) {
    if (sink == 0) { return 0; }
    var fp = load64(sink);
    if (fp == 0) { return 0; }
    var ctx = load64(sink + 8);
    fncall2(fp, ctx, event);
    return 0;
}

# --- audit_libro.cyr ---

# bote::audit::libro — LibroAudit adapter
# Mirrors rust-old/src/audit.rs::libro_impl::LibroAudit.
#
# Wraps a libro audit chain with bote's AuditSink contract:
#   - Severity: SEV_INFO on success, SEV_ERROR on failure
#   - Action:   "tool.completed" on success, "tool.failed" on failure
#   - Source:   "bote" by default (override via libro_audit_with_source)
#   - Agent:    caller_id from the event takes precedence over configured agent_id
#   - Details:  serialized ToolCallEvent JSON
#
# REQUIRED INIT (caller's main, before any chain operations):
#   alloc_init();   # bump allocator
#   fl_init();      # freelist (libro entries live here)
#   ed25519_init(); # sigil signing constants
#
# Wire-up:
#   var chain = chain_new();
#   var la = libro_audit_new(chain);
#   var sink = audit_sink_new(&libro_audit_log, la);
#   dispatcher_set_audit(d, sink);
#
# IMPORTANT: libro's chain_append* takes `Str` (fat strings), not raw cstrs.
# This adapter wraps every cstr boundary value via str_from before calling
# into libro. Callers should pass plain cstrs in ToolCallEvent — the wrap
# happens here.
#
# Known issue (v1.2.1): when libro + majra + the full bote test/demo binary
# are linked together, the libro_audit_log path triggers a heap heisenbug
# (main re-entry / infinite loop). The adapter shape is correct (works in
# isolated probes); live integration in a multi-include binary needs cyrius
# investigation — tracked for v1.3.0.

# LibroAudit (24 bytes):
#   +0  chain     libro chain ptr
#   +8  source    cstr (default "bote")
#   +16 agent_id  cstr or 0 (default 0)

fn libro_audit_new(chain) {
    var la = alloc(24);
    store64(la, chain);
    store64(la + 8, "bote");
    store64(la + 16, 0);
    return la;
}

fn libro_audit_with_source(la, source)     { store64(la + 8, source);   return la; }
fn libro_audit_with_agent_id(la, agent_id) { store64(la + 16, agent_id); return la; }

fn libro_audit_chain(la)    { return load64(la); }
fn libro_audit_source(la)   { return load64(la + 8); }
fn libro_audit_agent_id(la) { return load64(la + 16); }

# AuditSink-compatible log function.
# ctx is a LibroAudit ptr.
#
# IMPORTANT: libro's chain_append* expects `Str` (fat strings) for source /
# action / details / agent, NOT raw cstrs. Bote stores tool names and
# similar as cstrs, so we wrap them via str_from at the boundary.
fn libro_audit_log(ctx, event) {
    if (ctx == 0 || event == 0) { return 0; }
    var chain = libro_audit_chain(ctx);
    if (chain == 0) { return 0; }

    var success = tool_call_event_success(event);
    var severity = SEV_INFO;
    var action_cstr = "tool.completed";
    if (success == 0) { severity = SEV_ERROR; action_cstr = "tool.failed"; }

    var source_str  = str_from(libro_audit_source(ctx));
    var action_str  = str_from(action_cstr);
    var details_str = str_from(tool_call_event_to_json(event));

    # caller_id takes precedence over configured agent_id
    var agent_cstr = tool_call_event_caller_id(event);
    if (agent_cstr == 0) { agent_cstr = libro_audit_agent_id(ctx); }

    if (agent_cstr != 0) {
        chain_append_with_agent(chain, severity, source_str, action_str,
        details_str, str_from(agent_cstr));
    } else {
        chain_append(chain, severity, source_str, action_str, details_str);
    }
    return 0;
}

# --- events_majra.cyr ---

# bote::events::majra — MajraEvents adapter
# Mirrors rust-old/src/events.rs::majra_impl::MajraEvents.
#
# Wraps a majra PubSub instance with bote's EventSink contract.
# topic and payload are passed straight through to pubsub_publish.
#
# Wire-up:
#   var ps = pubsub_new();
#   var sink = event_sink_new(&majra_events_publish, ps);
#   dispatcher_set_events(d, sink);
#
# Subscribe to bote topics from your own code:
#   var rx = pubsub_subscribe(ps, "bote/tool/#");

# EventSink-compatible publish function.
# ctx is a majra PubSub ptr.
fn majra_events_publish(ctx, topic, payload) {
    if (ctx == 0) { return 0; }
    pubsub_publish(ctx, topic, payload);
    return 0;
}

# --- dispatch.cyr ---

# bote::dispatch — JSON-RPC tool dispatcher
# Mirrors rust-old/src/dispatch.rs (sync path; streaming/audit/events deferred)
#
# Requires (entry point includes):
#   string, fmt, alloc, vec, str, hashmap, fnptr,
#   src/error.cyr, src/protocol.cyr, src/registry.cyr, src/jsonx.cyr

# ================================================================
# Supported MCP protocol versions
# ================================================================

fn _mcp_is_supported(v) {
    if (v == 0) { return 0; }
    if (streq(v, "2024-11-05") == 1) { return 1; }
    if (streq(v, "2025-03-26") == 1) { return 1; }
    if (streq(v, "2025-11-25") == 1) { return 1; }
    return 0;
}

fn _mcp_latest_version() { return "2025-11-25"; }

fn _bote_server_version() { return "2.9.0"; }

# ================================================================
# Tool name validation (project_tool convention)
# ================================================================
#
# Returns 0 if valid, BoteError ptr otherwise.

fn _is_alnum_or_under(c) {
    if (c >= 48 && c <= 57) { return 1; }
    if (c >= 65 && c <= 90) { return 1; }
    if (c >= 97 && c <= 122) { return 1; }
    if (c == 95) { return 1; }
    return 0;
}

fn validate_tool_name(name) {
    if (name == 0) {
        return bote_err_new(ERR_INVALID_PARAMS, "", "tool name must be 1-256 characters");
    }
    var n = strlen(name);
    if (n == 0 || n > 256) {
        return bote_err_new(ERR_INVALID_PARAMS, "", "tool name must be 1-256 characters");
    }
    var i = 0;
    var has_under = 0;
    while (i < n) {
        var c = load8(name + i);
        if (_is_alnum_or_under(c) == 0) {
            return bote_err_new(ERR_INVALID_PARAMS, name, "tool name must be alphanumeric + underscore");
        }
        if (c == 95) { has_under = 1; }
        i = i + 1;
    }
    if (has_under == 0) {
        return bote_err_new(ERR_INVALID_PARAMS, name,
        "tool name must contain at least one underscore (project_tool format)");
    }
    return 0;
}

# ================================================================
# Dispatcher struct (48 bytes):
#   +0  registry            ptr
#   +8  handlers            hashmap: name_cstr -> fn ptr (sync handler)
#   +16 streaming_handlers  hashmap: name_cstr -> fn ptr (reserved for v1.3)
#   +24 audit_sink          AuditSink ptr or 0 (no-op when 0)
#   +32 event_sink          EventSink ptr or 0 (no-op when 0)
#   +40 prompt_registry     PromptRegistry ptr or 0 (prompts capability off
#                           when 0; created lazily by dispatcher_register_prompt)
#   +48 resource_registry   ResourceRegistry ptr or 0 (resources capability off
#                           when 0; created lazily by dispatcher_register_resource)
#   +56 completion_handler  fn ptr or 0 (completions capability off when 0;
#                           set via dispatcher_set_completion)
# ================================================================

fn dispatcher_new(reg) {
    var d = alloc(64);
    store64(d, reg);
    store64(d + 8, map_new());
    store64(d + 16, map_new());
    store64(d + 24, 0);
    store64(d + 32, 0);
    store64(d + 40, 0);
    store64(d + 48, 0);
    store64(d + 56, 0);
    return d;
}

fn dispatcher_registry(d)   { return load64(d); }
fn dispatcher_handlers(d)   { return load64(d + 8); }
fn dispatcher_streaming(d)  { return load64(d + 16); }
fn dispatcher_audit_sink(d) { return load64(d + 24); }
fn dispatcher_event_sink(d) { return load64(d + 32); }
fn dispatcher_prompts(d)    { return load64(d + 40); }
fn dispatcher_resources(d)  { return load64(d + 48); }
fn dispatcher_completion(d) { return load64(d + 56); }

fn dispatcher_set_audit(d, sink) { store64(d + 24, sink); return d; }
fn dispatcher_set_events(d, sink) { store64(d + 32, sink); return d; }
fn dispatcher_set_prompts(d, preg) { store64(d + 40, preg); return d; }
fn dispatcher_set_resources(d, rreg) { store64(d + 48, rreg); return d; }

# Set the completion handler. ABI: fn h(params_cstr, claims) → result_cstr,
# where params is the completion/complete params ({ref, argument, ...}) and
# the result is the full {"completion":{"values":[...]}} body. Setting it
# flips the `completions` capability on at initialize.
fn dispatcher_set_completion(d, handler_fp) { store64(d + 56, handler_fp); return d; }

# Register a sync tool handler. **2.0 ABI**: handler signature is
#   fn h(args_cstr, claims) → result_cstr (claims always 0 today)
fn dispatcher_handle(d, name, handler_fp) {
    map_set(dispatcher_handlers(d), name, handler_fp);
    return 0;
}

# Register a streaming tool handler (placeholder — dispatch_streaming not yet ported).
fn dispatcher_handle_streaming(d, name, handler_fp) {
    map_set(dispatcher_streaming(d), name, handler_fp);
    return 0;
}

fn dispatcher_is_streaming_tool(d, name) {
    return map_has(dispatcher_streaming(d), name);
}

# Build {"tool_name":"<name>"} for a register/dereg/deprecate event payload.
fn _emit_tool_name_payload(name) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"tool_name\":\"");
    _json_emit_escaped(sb, name);
    str_builder_add_cstr(sb, "\"}");
    return str_data(str_builder_build(sb));
}

# Dynamic registration: validates the tool name, registers in registry,
# inserts handler. Returns 0 on success, BoteError ptr on failure.
# Emits TOPIC_TOOL_REGISTERED on success.
fn dispatcher_register_tool(d, tool_def, handler_fp) {
    var name = tool_def_name(tool_def);
    var verr = validate_tool_name(name);
    if (verr != 0) { return verr; }
    registry_register(dispatcher_registry(d), tool_def);
    map_set(dispatcher_handlers(d), name, handler_fp);
    event_sink_publish(dispatcher_event_sink(d), TOPIC_TOOL_REGISTERED(),
    _emit_tool_name_payload(name));
    return 0;
}

# Returns 0 on success, BoteError ptr on failure (tool not found).
# Emits TOPIC_TOOL_DEREGISTERED on success.
fn dispatcher_deregister_tool(d, name) {
    var removed = registry_deregister(dispatcher_registry(d), name);
    map_delete(dispatcher_handlers(d), name);
    map_delete(dispatcher_streaming(d), name);
    if (removed == 0) {
        return bote_err_new(ERR_TOOL_NOT_FOUND, name, 0);
    }
    event_sink_publish(dispatcher_event_sink(d), TOPIC_TOOL_DEREGISTERED(),
    _emit_tool_name_payload(name));
    return 0;
}

# Register an MCP prompt + its generator handler. Lazily stands up the
# dispatcher's PromptRegistry on first call — which is also what flips the
# `prompts` capability on at initialize (see _build_capabilities). Prompt
# names are freeform (no project_tool underscore convention). Returns 0.
fn dispatcher_register_prompt(d, prompt_def, handler_fp) {
    var preg = dispatcher_prompts(d);
    if (preg == 0) {
        preg = prompt_registry_new();
        dispatcher_set_prompts(d, preg);
    }
    prompt_registry_register(preg, prompt_def, handler_fp);
    return 0;
}

# Register an MCP resource + its read handler. Lazily stands up the
# dispatcher's ResourceRegistry on first call — which is also what flips the
# `resources` capability on at initialize (see _build_capabilities).
# Returns 0.
fn dispatcher_register_resource(d, resource_def, handler_fp) {
    var rreg = dispatcher_resources(d);
    if (rreg == 0) {
        rreg = resource_registry_new();
        dispatcher_set_resources(d, rreg);
    }
    resource_registry_register(rreg, resource_def, handler_fp);
    return 0;
}

# ================================================================
# JSON helpers — escape, build literals
# ================================================================

# Append `cstr` to sb, JSON-escaping " \ and control chars.
fn _json_emit_escaped(sb, cstr) {
    if (cstr == 0) { return 0; }
    var i = 0;
    while (1 == 1) {
        var c = load8(cstr + i);
        if (c == 0) { return 0; }
        if (c == 34) { str_builder_add_cstr(sb, "\\\""); }
        elif (c == 92) { str_builder_add_cstr(sb, "\\\\"); }
        elif (c == 10) { str_builder_add_cstr(sb, "\\n"); }
        elif (c == 13) { str_builder_add_cstr(sb, "\\r"); }
        elif (c == 9) { str_builder_add_cstr(sb, "\\t"); }
        else {
            var one[2];
            store8(&one, c);
            store8(&one + 1, 0);
            str_builder_add_cstr(sb, &one);
        }
        i = i + 1;
    }
    return 0;
}

# Append "key":"value" (value JSON-escaped). Caller responsible for commas.
fn _json_emit_str_field(sb, key, value) {
    str_builder_add_cstr(sb, "\"");
    str_builder_add_cstr(sb, key);
    str_builder_add_cstr(sb, "\":\"");
    _json_emit_escaped(sb, value);
    str_builder_add_cstr(sb, "\"");
    return 0;
}

# Append "key":raw  where raw is already JSON-formatted.
fn _json_emit_raw_field(sb, key, raw) {
    str_builder_add_cstr(sb, "\"");
    str_builder_add_cstr(sb, key);
    str_builder_add_cstr(sb, "\":");
    str_builder_add_cstr(sb, raw);
    return 0;
}

# Build a JSON object representation of a ToolSchema.
fn _emit_schema(sb, schema) {
    str_builder_add_cstr(sb, "{\"type\":\"");
    var t = schema_type(schema);
    if (t != 0) { _json_emit_escaped(sb, t); }
    str_builder_add_cstr(sb, "\"");

    var props = schema_properties(schema);
    if (props != 0 && vec_len(props) > 0) {
        str_builder_add_cstr(sb, ",\"properties\":{");
        var n = vec_len(props);
        var i = 0;
        while (i < n) {
            if (i > 0) { str_builder_add_cstr(sb, ","); }
            var p = vec_get(props, i);
            str_builder_add_cstr(sb, "\"");
            _json_emit_escaped(sb, schema_prop_key(p));
            str_builder_add_cstr(sb, "\":");
            str_builder_add_cstr(sb, schema_prop_value(p));
            i = i + 1;
        }
        str_builder_add_cstr(sb, "}");
    }

    var req = schema_required(schema);
    if (req != 0 && vec_len(req) > 0) {
        str_builder_add_cstr(sb, ",\"required\":[");
        var nr = vec_len(req);
        var ri = 0;
        while (ri < nr) {
            if (ri > 0) { str_builder_add_cstr(sb, ","); }
            str_builder_add_cstr(sb, "\"");
            _json_emit_escaped(sb, vec_get(req, ri));
            str_builder_add_cstr(sb, "\"");
            ri = ri + 1;
        }
        str_builder_add_cstr(sb, "]");
    }
    str_builder_add_cstr(sb, "}");
    return 0;
}

# Append a single tri-state annotation hint as "key":true/false.
# `first` is 1 when no hint has been emitted yet (suppresses the leading
# comma); returns the updated `first` flag. HINT_UNSET emits nothing.
fn _emit_hint_field(sb, first, key, hint) {
    if (hint == HINT_UNSET) { return first; }
    if (first == 0) { str_builder_add_cstr(sb, ","); }
    str_builder_add_cstr(sb, "\"");
    str_builder_add_cstr(sb, key);
    if (hint == HINT_TRUE) { str_builder_add_cstr(sb, "\":true"); }
    else { str_builder_add_cstr(sb, "\":false"); }
    return 0;
}

# Append ,"annotations":{...} for a ToolDef's ToolAnnotations ptr.
# Emits nothing when `ann` is 0 or every hint is unset (so the leading
# comma is only produced when at least one hint is serialized). MCP
# 2025-11-25 ToolAnnotations: readOnlyHint/destructiveHint/idempotentHint/
# openWorldHint, each an optional boolean (skip when unset).
fn _emit_annotations(sb, ann) {
    if (ann == 0) { return 0; }
    var r = ann_read_only_hint(ann);
    var dd = ann_destructive_hint(ann);
    var idem = ann_idempotent_hint(ann);
    var ow = ann_open_world_hint(ann);
    if (r == HINT_UNSET && dd == HINT_UNSET && idem == HINT_UNSET && ow == HINT_UNSET) {
        return 0;
    }
    str_builder_add_cstr(sb, ",\"annotations\":{");
    var first = 1;
    first = _emit_hint_field(sb, first, "readOnlyHint", r);
    first = _emit_hint_field(sb, first, "destructiveHint", dd);
    first = _emit_hint_field(sb, first, "idempotentHint", idem);
    first = _emit_hint_field(sb, first, "openWorldHint", ow);
    str_builder_add_cstr(sb, "}");
    return 0;
}

# ================================================================
# Method handlers
# ================================================================

# Does bote emit `notifications/tools/list_changed` to the client?
#
# The registry emits internal EventSink topics (TOPIC_TOOL_REGISTERED /
# _DEREGISTERED) on register/deregister, but those go to bote's OWN event
# bus — they are NOT MCP client notifications. There is no server→client
# push path yet (dispatch is strictly request→response; the streamable SSE
# GET closes immediately), so we cannot deliver `notifications/tools/
# list_changed`. Advertising `listChanged:true` would make the client wait
# for notifications that never arrive, so we return 0 (⇒ omit the flag,
# which defaults to false). Flip this to 1 AND wire the notification
# together once a persistent push channel lands.
fn _server_emits_tool_list_changed() { return 0; }

# Append the MCP `capabilities` object advertised at initialize.
#
# Advertised keys are DERIVED from what bote actually implements, so we
# never advertise a capability we can't honor:
#   - `tools`: always — bote is a tool server (an empty registry is still
#     tool-capable). `listChanged` gated on _server_emits_tool_list_changed.
#   - `prompts`: advertised iff the dispatcher has a PromptRegistry (i.e. at
#     least one prompt was registered — see dispatcher_register_prompt).
#   - `resources`: advertised iff the dispatcher has a ResourceRegistry (see
#     dispatcher_register_resource). `subscribe`/`listChanged` omitted — no
#     server→client push path yet.
#   - `completions`: advertised iff a completion handler is set (see
#     dispatcher_set_completion).
#   - logging: NOT YET — it exists only to gate `notifications/message`
#     (server→client push), which is not wired; advertising it would promise
#     log messages that never arrive. Lands with the notification path.
#
# Version policy: every capability below exists across all supported
# protocol versions (2024-11-05 … 2025-11-25), so none is gated on the
# negotiated version. A version-exclusive capability would branch on the
# negotiated version passed in here.
fn _build_capabilities(sb, d) {
    str_builder_add_cstr(sb, "{\"tools\":{");
    if (_server_emits_tool_list_changed() == 1) {
        str_builder_add_cstr(sb, "\"listChanged\":true");
    }
    str_builder_add_cstr(sb, "}");
    if (dispatcher_prompts(d) != 0) {
        str_builder_add_cstr(sb, ",\"prompts\":{}");
    }
    if (dispatcher_resources(d) != 0) {
        str_builder_add_cstr(sb, ",\"resources\":{}");
    }
    if (dispatcher_completion(d) != 0) {
        str_builder_add_cstr(sb, ",\"completions\":{}");
    }
    str_builder_add_cstr(sb, "}");
    return 0;
}

# Build the initialize response result body.
fn _build_initialize_result(d, params_cstr) {
    var requested = jsonx_get_str(params_cstr, "protocolVersion");
    var negotiated = _mcp_latest_version();
    if (_mcp_is_supported(requested) == 1) { negotiated = requested; }

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"protocolVersion\":\"");
    str_builder_add_cstr(sb, negotiated);
    str_builder_add_cstr(sb, "\",\"capabilities\":");
    _build_capabilities(sb, d);
    str_builder_add_cstr(sb, ",\"serverInfo\":{\"name\":\"bote\",\"version\":\"");
    str_builder_add_cstr(sb, _bote_server_version());
    str_builder_add_cstr(sb, "\"}}");
    return str_data(str_builder_build(sb));
}

# Build the prompts/list response result body.
fn _build_prompts_list_result(preg) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"prompts\":[");
    var lst = prompt_registry_list(preg);
    var n = vec_len(lst);
    var i = 0;
    while (i < n) {
        if (i > 0) { str_builder_add_cstr(sb, ","); }
        var p = vec_get(lst, i);
        str_builder_add_cstr(sb, "{");
        _json_emit_str_field(sb, "name", prompt_def_name(p));
        var pd = prompt_def_description(p);
        if (pd != 0) {
            str_builder_add_cstr(sb, ",");
            _json_emit_str_field(sb, "description", pd);
        }
        var pargs = prompt_def_arguments(p);
        if (pargs != 0 && vec_len(pargs) > 0) {
            str_builder_add_cstr(sb, ",\"arguments\":[");
            var na = vec_len(pargs);
            var ai = 0;
            while (ai < na) {
                if (ai > 0) { str_builder_add_cstr(sb, ","); }
                var a = vec_get(pargs, ai);
                str_builder_add_cstr(sb, "{");
                _json_emit_str_field(sb, "name", prompt_arg_name(a));
                var ad = prompt_arg_description(a);
                if (ad != 0) {
                    str_builder_add_cstr(sb, ",");
                    _json_emit_str_field(sb, "description", ad);
                }
                if (prompt_arg_required(a) == 1) {
                    str_builder_add_cstr(sb, ",\"required\":true");
                }
                str_builder_add_cstr(sb, "}");
                ai = ai + 1;
            }
            str_builder_add_cstr(sb, "]");
        }
        str_builder_add_cstr(sb, "}");
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return str_data(str_builder_build(sb));
}

# Does tool `t` belong in a `profile`-filtered listing? A null profile means
# no filter was requested, so every tool matches (full listing, unchanged).
fn _tool_matches_profile(t, profile) {
    if (profile == 0) { return 1; }
    return tool_def_has_profile(t, profile);
}

# Build the tools/list response result body.
#
# `profile` (cstr or 0) is an OPTIONAL bote extension: when a client passes
# {"profile":"<tag>"} in tools/list params, only tools tagged with that
# profile are returned (exact-match). When absent (0), the full tool list is
# returned — byte-identical to pre-extension behavior.
fn _build_tools_list_result(reg, profile) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"tools\":[");
    var lst = registry_list(reg);
    var n = vec_len(lst);
    var i = 0;
    var emitted = 0;
    while (i < n) {
        var t = vec_get(lst, i);
        if (_tool_matches_profile(t, profile) == 0) {
            i = i + 1;
            continue;
        }
        if (emitted > 0) { str_builder_add_cstr(sb, ","); }
        emitted = emitted + 1;
        str_builder_add_cstr(sb, "{");
        _json_emit_str_field(sb, "name", tool_def_name(t));
        str_builder_add_cstr(sb, ",");
        _json_emit_str_field(sb, "description", tool_def_description(t));
        str_builder_add_cstr(sb, ",\"inputSchema\":");
        _emit_schema(sb, tool_def_input_schema(t));
        var v = tool_def_version(t);
        if (v != 0) {
            str_builder_add_cstr(sb, ",");
            _json_emit_str_field(sb, "version", v);
        }
        var dep = tool_def_deprecated(t);
        if (dep != 0) {
            str_builder_add_cstr(sb, ",");
            _json_emit_str_field(sb, "deprecated", dep);
        }
        _emit_annotations(sb, tool_def_annotations(t));
        str_builder_add_cstr(sb, "}");
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return str_data(str_builder_build(sb));
}

# Extract and validate the tool name from a tools/call request's params.
# Returns cstr (name) or 0; sets *err_out (BoteError ptr) on failure.
fn _extract_tool_name(params_cstr, err_out) {
    var name = jsonx_get_str(params_cstr, "name");
    if (name == 0 || strlen(name) == 0) {
        store64(err_out, bote_err_new(ERR_INVALID_PARAMS, "", "missing or empty 'name' field"));
        return 0;
    }
    store64(err_out, 0);
    return name;
}

# Build the resources/list response result body.
fn _build_resources_list_result(rreg) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"resources\":[");
    var lst = resource_registry_list(rreg);
    var n = vec_len(lst);
    var i = 0;
    while (i < n) {
        if (i > 0) { str_builder_add_cstr(sb, ","); }
        var r = vec_get(lst, i);
        str_builder_add_cstr(sb, "{");
        _json_emit_str_field(sb, "uri", resource_def_uri(r));
        str_builder_add_cstr(sb, ",");
        _json_emit_str_field(sb, "name", resource_def_name(r));
        var rd = resource_def_description(r);
        if (rd != 0) {
            str_builder_add_cstr(sb, ",");
            _json_emit_str_field(sb, "description", rd);
        }
        var rm = resource_def_mime_type(r);
        if (rm != 0) {
            str_builder_add_cstr(sb, ",");
            _json_emit_str_field(sb, "mimeType", rm);
        }
        str_builder_add_cstr(sb, "}");
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# dispatch — main entry
# ================================================================
#
# Returns a JsonRpcResponse ptr, or 0 if the request is a notification.

fn dispatcher_dispatch(d, request, claims) {
    if (req_is_notification(request) == 1) { return 0; }

    var id = req_id(request);
    var method = req_method(request);
    var params = req_params(request);
    var reg = dispatcher_registry(d);
    var handlers = dispatcher_handlers(d);

    if (streq(method, "initialize") == 1) {
        return resp_success(id, _build_initialize_result(d, params));
    }

    if (streq(method, "tools/list") == 1) {
        var lprofile = 0;
        if (params != 0) { lprofile = jsonx_get_str(params, "profile"); }
        return resp_success(id, _build_tools_list_result(reg, lprofile));
    }

    # prompts/* only when the prompts capability is enabled (a PromptRegistry
    # is present). Otherwise fall through to method-not-found (-32601), which
    # matches the un-advertised capability.
    if (streq(method, "prompts/list") == 1 && dispatcher_prompts(d) != 0) {
        return resp_success(id, _build_prompts_list_result(dispatcher_prompts(d)));
    }

    if (streq(method, "prompts/get") == 1 && dispatcher_prompts(d) != 0) {
        var pname = jsonx_get_str(params, "name");
        if (pname == 0 || strlen(pname) == 0) {
            var pe = bote_err_new(ERR_INVALID_PARAMS, "", "missing or empty 'name' field");
            return resp_error(id, bote_err_rpc_code(bote_err_tag(pe)), str_data(bote_err_format(pe)));
        }
        var phandler = prompt_registry_handler(dispatcher_prompts(d), pname);
        if (phandler == 0) {
            var nf = bote_err_new(ERR_INVALID_PARAMS, pname, "prompt not found");
            return resp_error(id, bote_err_rpc_code(bote_err_tag(nf)), str_data(bote_err_format(nf)));
        }
        var pargs = jsonx_get_raw(params, "arguments");
        if (pargs == 0) { pargs = "{}"; }
        var presult = fncall2(phandler, pargs, claims);
        if (presult == 0) { presult = "{\"messages\":[]}"; }
        return resp_success(id, presult);
    }

    # resources/* only when the resources capability is enabled (a
    # ResourceRegistry is present). Otherwise fall through to -32601.
    if (streq(method, "resources/list") == 1 && dispatcher_resources(d) != 0) {
        return resp_success(id, _build_resources_list_result(dispatcher_resources(d)));
    }

    if (streq(method, "resources/read") == 1 && dispatcher_resources(d) != 0) {
        var ruri = jsonx_get_str(params, "uri");
        if (ruri == 0 || strlen(ruri) == 0) {
            var re = bote_err_new(ERR_INVALID_PARAMS, "", "missing or empty 'uri' field");
            return resp_error(id, bote_err_rpc_code(bote_err_tag(re)), str_data(bote_err_format(re)));
        }
        var rhandler = resource_registry_handler(dispatcher_resources(d), ruri);
        if (rhandler == 0) {
            var rnf = bote_err_new(ERR_INVALID_PARAMS, ruri, "resource not found");
            return resp_error(id, bote_err_rpc_code(bote_err_tag(rnf)), str_data(bote_err_format(rnf)));
        }
        var rresult = fncall2(rhandler, ruri, claims);
        if (rresult == 0) { rresult = "{\"contents\":[]}"; }
        return resp_success(id, rresult);
    }

    # completion/complete only when a completion handler is set. The handler
    # receives the raw params ({ref, argument, ...}) and returns the full
    # {"completion":{"values":[...]}} body. Otherwise fall through to -32601.
    if (streq(method, "completion/complete") == 1 && dispatcher_completion(d) != 0) {
        var cparams = params;
        if (cparams == 0) { cparams = "{}"; }
        var cresult = fncall2(dispatcher_completion(d), cparams, claims);
        if (cresult == 0) { cresult = "{\"completion\":{\"values\":[]}}"; }
        return resp_success(id, cresult);
    }

    if (streq(method, "tools/call") == 1) {
        var err_slot[8];
        store64(&err_slot, 0);
        var name = _extract_tool_name(params, &err_slot);
        if (name == 0) {
            var ne = load64(&err_slot);
            return resp_error(id, bote_err_rpc_code(bote_err_tag(ne)), str_data(bote_err_format(ne)));
        }

        # Optional: version negotiation
        var ver = jsonx_get_str(params, "version");
        if (ver != 0 && registry_get_versioned(reg, name, ver) == 0) {
            var sb = str_builder_new();
            str_builder_add_cstr(sb, "version '");
            str_builder_add_cstr(sb, ver);
            str_builder_add_cstr(sb, "' not found");
            var verr = bote_err_new(ERR_INVALID_PARAMS, name, str_data(str_builder_build(sb)));
            return resp_error(id, bote_err_rpc_code(bote_err_tag(verr)), str_data(bote_err_format(verr)));
        }

        # Extract arguments (default to "{}" if absent), caller_id (optional)
        var args = jsonx_get_raw(params, "arguments");
        if (args == 0) { args = "{}"; }
        var caller_id = jsonx_get_str(params, "caller_id");

        # Validate
        var verr2 = registry_validate_params(reg, name, args);
        if (verr2 != 0) {
            return resp_error(id, bote_err_rpc_code(bote_err_tag(verr2)), str_data(bote_err_format(verr2)));
        }

        # Deprecation event (best-effort; never blocks dispatch)
        var t = registry_get(reg, name);
        if (t != 0) {
            var dep = tool_def_deprecated(t);
            if (dep != 0) {
                var ds = str_builder_new();
                str_builder_add_cstr(ds, "{\"tool_name\":\"");
                _json_emit_escaped(ds, name);
                str_builder_add_cstr(ds, "\",\"message\":\"");
                _json_emit_escaped(ds, dep);
                str_builder_add_cstr(ds, "\"}");
                event_sink_publish(dispatcher_event_sink(d), TOPIC_TOOL_DEPRECATED(),
                str_data(str_builder_build(ds)));
            }
        }

        # Dispatch with timing + audit + event hooks
        var t_start = clock_now_ns();
        if (map_has(handlers, name) == 0) {
            var dur_nh = (clock_now_ns() - t_start) / 1000000;
            var nf = bote_err_new(ERR_TOOL_NOT_FOUND, name, 0);
            var msg_nh = str_data(bote_err_format(nf));
            var ev_nh = tool_call_event_new(name, dur_nh, 0, msg_nh, caller_id);
            audit_sink_log(dispatcher_audit_sink(d), ev_nh);
            event_sink_publish(dispatcher_event_sink(d), TOPIC_TOOL_FAILED(),
            tool_call_event_to_json(ev_nh));
            return resp_error(id, bote_err_rpc_code(bote_err_tag(nf)), msg_nh);
        }
        var fp = map_get(handlers, name);
        # 2.0 ABI: fncall2 with claims (always 0 in 2.0; populated in 2.x)
        var result = fncall2(fp, args, claims);
        var dur_ms = (clock_now_ns() - t_start) / 1000000;
        if (result == 0) { result = "null"; }
        var ev_ok = tool_call_event_new(name, dur_ms, 1, 0, caller_id);
        audit_sink_log(dispatcher_audit_sink(d), ev_ok);
        event_sink_publish(dispatcher_event_sink(d), TOPIC_TOOL_COMPLETED(),
        tool_call_event_to_json(ev_ok));
        return resp_success(id, result);
    }

    # Unknown method — JSON-RPC §5.1
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "method not found: ");
    str_builder_add_cstr(sb, method);
    return resp_error(id, 0 - 32601, str_data(str_builder_build(sb)));
}

# --- codec.cyr ---

# bote::codec — JSON-RPC parse, serialize, batch dispatch
# Mirrors rust-old/src/transport/codec.rs

# Hard cap on JSON-RPC batch length. Defends against the 1.9.4 audit's
# "no batch-size cap" amplification DoS — a 1 MiB body of `[{},{},...]`
# would otherwise spin allocating per-element responses until OOM.
# 100 is generous; real clients batch single-digit calls.
var CODEC_MAX_BATCH = 100;

# ================================================================
# Helpers
# ================================================================

# Slice n bytes from src starting at off into a new null-terminated cstr.
fn _slice_cstr(src, off, n) {
    var out = alloc(n + 1);
    memcpy(out, src + off, n);
    store8(out + n, 0);
    return out;
}

# Skip whitespace; return new index.
fn _cdc_skip_ws(buf, len, i) {
    while (i < len) {
        var c = load8(buf + i);
        if (c == 32 || c == 9 || c == 10 || c == 13) { i = i + 1; }
        else { return i; }
    }
    return i;
}

# Parse a JSON-RPC request object (cstr) into a JsonRpcRequest ptr.
# Returns 0 on failure.
fn codec_parse_request(line) {
    if (line == 0) { return 0; }
    if (jsonx_is_object(line) == 0) { return 0; }

    var jsonrpc = jsonx_get_str(line, "jsonrpc");
    if (jsonrpc == 0) { return 0; }
    var method = jsonx_get_str(line, "method");
    if (method == 0) { return 0; }

    # id is a raw JSON literal (may be number, string-with-quotes, null);
    # 0 means absent → notification.
    var id_raw = jsonx_get_raw(line, "id");
    var params = jsonx_get_raw(line, "params");
    if (params == 0) { params = "null"; }

    var r = alloc(32);
    store64(r, jsonrpc);
    store64(r + 8, id_raw);
    store64(r + 16, method);
    store64(r + 24, params);
    return r;
}

# Serialize a JsonRpcResponse to a cstr.
fn codec_serialize_response(resp) {
    if (resp == 0) { return ""; }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"jsonrpc\":\"");
    str_builder_add_cstr(sb, resp_jsonrpc(resp));
    str_builder_add_cstr(sb, "\",\"id\":");
    var id = resp_id(resp);
    if (id == 0) { str_builder_add_cstr(sb, "null"); }
    else { str_builder_add_cstr(sb, id); }

    var err = resp_error_obj(resp);
    if (err != 0) {
        str_builder_add_cstr(sb, ",\"error\":{\"code\":");
        str_builder_add_int(sb, rpc_err_code(err));
        str_builder_add_cstr(sb, ",\"message\":\"");
        _json_emit_escaped(sb, rpc_err_message(err));
        str_builder_add_cstr(sb, "\"");
        var data = rpc_err_data(err);
        if (data != 0) {
            str_builder_add_cstr(sb, ",\"data\":");
            str_builder_add_cstr(sb, data);
        }
        str_builder_add_cstr(sb, "}}");
        return str_data(str_builder_build(sb));
    }
    str_builder_add_cstr(sb, ",\"result\":");
    var result = resp_result(resp);
    if (result == 0) { str_builder_add_cstr(sb, "null"); }
    else { str_builder_add_cstr(sb, result); }
    str_builder_add_cstr(sb, "}");
    return str_data(str_builder_build(sb));
}

# Build a JSON-RPC parse-error response and return its serialized form.
fn _cdc_parse_error(reason) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "parse error: ");
    str_builder_add_cstr(sb, reason);
    return codec_serialize_response(resp_error("null", 0 - 32700, str_data(str_builder_build(sb))));
}

fn _cdc_invalid_request(reason) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "invalid request: ");
    str_builder_add_cstr(sb, reason);
    return codec_serialize_response(resp_error("null", 0 - 32600, str_data(str_builder_build(sb))));
}

# Process a single request body. Returns serialized response cstr or 0 (notif).
fn _cdc_process_single(line, dispatcher, claims) {
    var req = codec_parse_request(line);
    if (req == 0) { return _cdc_invalid_request("malformed object"); }
    if (streq(req_jsonrpc(req), "2.0") == 0) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "unsupported jsonrpc version '");
        str_builder_add_cstr(sb, req_jsonrpc(req));
        str_builder_add_cstr(sb, "'");
        var id = req_id(req);
        if (id == 0) { id = "null"; }
        return codec_serialize_response(resp_error(id, 0 - 32600, str_data(str_builder_build(sb))));
    }
    var resp = dispatcher_dispatch(dispatcher, req, claims);
    if (resp == 0) { return 0; }
    return codec_serialize_response(resp);
}

# Walk a top-level JSON array (cstr starting with `[`); for each element,
# extract its raw bytes and append to the returned vec of cstrs.
# Caller verifies non-empty.
fn _cdc_split_array(buf) {
    var out = vec_new();
    var len = strlen(buf);
    var i = _cdc_skip_ws(buf, len, 0);
    if (i >= len) { return out; }
    if (load8(buf + i) != 91) { return out; }
    i = i + 1;
    while (i < len) {
        i = _cdc_skip_ws(buf, len, i);
        if (i >= len) { return out; }
        if (load8(buf + i) == 93) { return out; }
        var start = i;
        var end = _jx_skip_value(buf, len, i);
        vec_push(out, _slice_cstr(buf, start, end - start));
        i = _cdc_skip_ws(buf, len, end);
        if (i < len) { if (load8(buf + i) == 44) { i = i + 1; } }
    }
    return out;
}

# Process a raw JSON-RPC message. Returns serialized response cstr or 0.
fn codec_process_message(input, dispatcher, claims) {
    if (input == 0) { return _cdc_parse_error("empty input"); }
    var len = strlen(input);
    var i = _cdc_skip_ws(input, len, 0);
    if (i >= len) { return _cdc_parse_error("empty input"); }
    var first = load8(input + i);

    if (first == 91) {
        # Array (batch)
        var elems = _cdc_split_array(input);
        var n = vec_len(elems);
        if (n == 0) { return _cdc_invalid_request("empty batch"); }
        # DoS guard: cap batch size. A pathological client sending a
        # 1 MiB body of `[{},{},...]` (~300k elements) would otherwise
        # process each, build a per-element response, and accumulate
        # bump-allocated buffers until OOM. 100 is generous for any
        # legitimate batch use case (real clients batch <10 calls).
        if (n > CODEC_MAX_BATCH) {
            return _cdc_invalid_request("batch too large");
        }
        var responses = vec_new();
        var ei = 0;
        while (ei < n) {
            var elem = vec_get(elems, ei);
            # Each element must be an object
            if (jsonx_is_object(elem) == 0) {
                vec_push(responses, _cdc_invalid_request("batch element is not an object"));
            } else {
                var single = _cdc_process_single(elem, dispatcher, claims);
                if (single != 0) { vec_push(responses, single); }
            }
            ei = ei + 1;
        }
        var nr = vec_len(responses);
        if (nr == 0) { return 0; }
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "[");
        var ri = 0;
        while (ri < nr) {
            if (ri > 0) { str_builder_add_cstr(sb, ","); }
            str_builder_add_cstr(sb, vec_get(responses, ri));
            ri = ri + 1;
        }
        str_builder_add_cstr(sb, "]");
        return str_data(str_builder_build(sb));
    }

    if (first == 123) {
        return _cdc_process_single(input, dispatcher, claims);
    }

    return _cdc_invalid_request("expected object or array");
}

# --- schema.cyr ---

# bote::schema — JSON Schema compilation and validation
# Mirrors rust-old/src/schema.rs
#
# Cyrius limitations vs Rust:
#   - No floats. Number and Integer both validated as i64 (Number bounds use ints).
#   - apply_defaults is not yet implemented (would need JSON object mutation).

# ================================================================
# SchemaTypeTag
# ================================================================

enum SchemaTypeTag {
    SCH_STRING = 0;
    SCH_NUMBER = 1;
    SCH_INTEGER = 2;
    SCH_BOOLEAN = 3;
    SCH_ARRAY = 4;
    SCH_OBJECT = 5;
    SCH_ANY = 6;
}

# ================================================================
# PropertyDef (80 bytes):
#   +0  type_tag         i64
#   +8  description      cstr or 0
#   +16 enum_values      vec of cstrs (string only) or 0
#   +24 default          cstr (raw JSON literal) or 0
#   +32 has_min          0/1
#   +40 minimum          i64
#   +48 has_max          0/1
#   +56 maximum          i64
#   +64 items            PropertyDef ptr (array element type) or 0
#   +72 nested_compiled  CompiledSchema ptr (object nested schema) or 0
# ================================================================

fn prop_new(tag) {
    var p = alloc(80);
    store64(p, tag);
    store64(p + 8, 0);
    store64(p + 16, 0);
    store64(p + 24, 0);
    store64(p + 32, 0);
    store64(p + 40, 0);
    store64(p + 48, 0);
    store64(p + 56, 0);
    store64(p + 64, 0);
    store64(p + 72, 0);
    return p;
}

fn prop_tag(p) { return load64(p); }
fn prop_description(p) { return load64(p + 8); }
fn prop_enum_values(p) { return load64(p + 16); }
fn prop_default(p) { return load64(p + 24); }
fn prop_has_min(p) { return load64(p + 32); }
fn prop_min(p) { return load64(p + 40); }
fn prop_has_max(p) { return load64(p + 48); }
fn prop_max(p) { return load64(p + 56); }
fn prop_items(p) { return load64(p + 64); }
fn prop_nested(p) { return load64(p + 72); }

# ================================================================
# CompiledSchema (24 bytes):
#   +0  properties  hashmap: name_cstr -> PropertyDef ptr
#   +8  required    vec of name_cstrs
#   +16 names       vec of name_cstrs (insertion order)
# ================================================================

fn compiled_new() {
    var c = alloc(24);
    store64(c, map_new());
    store64(c + 8, vec_new());
    store64(c + 16, vec_new());
    return c;
}

fn compiled_properties(c) { return load64(c); }
fn compiled_required(c) { return load64(c + 8); }
fn compiled_names(c) { return load64(c + 16); }

fn compiled_get_property(c, name) {
    return map_get(compiled_properties(c), name);
}

fn compiled_add_property(c, name, prop) {
    map_set(compiled_properties(c), name, prop);
    vec_push(compiled_names(c), name);
    return 0;
}

fn compiled_set_required(c, required_vec) {
    store64(c + 8, required_vec);
    return 0;
}

# ================================================================
# Helpers — JSON value type detection on raw cstr
# ================================================================

# Returns the first non-whitespace byte of `s`, or 0 if EOS.
fn _sch_first_nonws(s) {
    if (s == 0) { return 0; }
    var i = 0;
    while (1 == 1) {
        var c = load8(s + i);
        if (c == 0) { return 0; }
        if (c == 32 || c == 9 || c == 10 || c == 13) { i = i + 1; }
        else { return c; }
    }
    return 0;
}

# Type-detection predicates on raw JSON value cstrs.
fn _sch_is_string(v) { if (_sch_first_nonws(v) == 34) { return 1; } return 0; }
fn _sch_is_array(v)  { if (_sch_first_nonws(v) == 91) { return 1; } return 0; }
fn _sch_is_object(v) { if (_sch_first_nonws(v) == 123) { return 1; } return 0; }
fn _sch_is_boolean(v) {
    var c = _sch_first_nonws(v);
    if (c == 116 || c == 102) { return 1; }
    return 0;
}
fn _sch_is_null(v) { if (_sch_first_nonws(v) == 110) { return 1; } return 0; }

# Number: starts with '-' or digit. Integer: no '.' anywhere in token.
fn _sch_is_number(v) {
    var c = _sch_first_nonws(v);
    if (c == 45) { return 1; }
    if (c >= 48 && c <= 57) { return 1; }
    return 0;
}

fn _sch_is_integer(v) {
    if (_sch_is_number(v) == 0) { return 0; }
    var i = 0;
    while (load8(v + i) != 0) {
        if (load8(v + i) == 46) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Strip surrounding quotes from a JSON-string cstr ("hello" → hello).
# Caller guarantees v is a string literal. Returns alloc'd cstr.
fn _sch_unquote(v) {
    var len = strlen(v);
    if (len < 2) { return ""; }
    var inner = len - 2;
    var out = alloc(inner + 1);
    memcpy(out, v + 1, inner);
    store8(out + inner, 0);
    return out;
}

# Parse a JSON integer cstr to i64 (handles leading '-').
# Stops at the first non-digit. Caller is expected to pass a JSON-number
# literal extracted by jsonx_get_raw, so non-digits beyond the prefix are not
# diagnosed (silent truncation of suffixes by design).
fn _sch_parse_int(v) {
    if (v == 0) { return 0; }
    var i = 0;
    var neg = 0;
    if (load8(v) == 45) { neg = 1; i = 1; }
    var n = 0;
    while (load8(v + i) != 0) {
        var c = load8(v + i);
        if (c < 48) { break; }
        if (c > 57) { break; }
        n = n * 10 + (c - 48);
        i = i + 1;
    }
    if (neg == 1) { return 0 - n; }
    return n;
}

# Walk a top-level JSON array (cstr starting with `[`); push each raw element
# bytes into a returned vec of cstrs.
fn _sch_split_array(buf) {
    var out = vec_new();
    if (buf == 0) { return out; }
    var len = strlen(buf);
    var i = _cdc_skip_ws(buf, len, 0);
    if (i >= len) { return out; }
    if (load8(buf + i) != 91) { return out; }
    i = i + 1;
    while (i < len) {
        i = _cdc_skip_ws(buf, len, i);
        if (i >= len) { return out; }
        if (load8(buf + i) == 93) { return out; }
        var start = i;
        var end = _jx_skip_value(buf, len, i);
        var elen = end - start;
        var elem = alloc(elen + 1);
        memcpy(elem, buf + start, elen);
        store8(elem + elen, 0);
        vec_push(out, elem);
        i = _cdc_skip_ws(buf, len, end);
        if (i < len) { if (load8(buf + i) == 44) { i = i + 1; } }
    }
    return out;
}

# ================================================================
# parse_property — JSON Schema property → PropertyDef
# ================================================================

fn parse_property(raw_json) {
    var type_str = jsonx_get_str(raw_json, "type");
    var tag = SCH_ANY;
    if (type_str != 0) {
        if (streq(type_str, "string") == 1) { tag = SCH_STRING; }
        elif (streq(type_str, "number") == 1) { tag = SCH_NUMBER; }
        elif (streq(type_str, "integer") == 1) { tag = SCH_INTEGER; }
        elif (streq(type_str, "boolean") == 1) { tag = SCH_BOOLEAN; }
        elif (streq(type_str, "array") == 1) { tag = SCH_ARRAY; }
        elif (streq(type_str, "object") == 1) { tag = SCH_OBJECT; }
    }
    var p = prop_new(tag);
    store64(p + 8, jsonx_get_str(raw_json, "description"));

    if (tag == SCH_STRING) {
        var enum_raw = jsonx_get_raw(raw_json, "enum");
        if (enum_raw != 0) {
            var vals = vec_new();
            var elems = _sch_split_array(enum_raw);
            var ne = vec_len(elems);
            var ei = 0;
            while (ei < ne) {
                var ev = vec_get(elems, ei);
                if (_sch_is_string(ev) == 1) {
                    vec_push(vals, _sch_unquote(ev));
                }
                ei = ei + 1;
            }
            store64(p + 16, vals);
        }
        var def_s = jsonx_get_str(raw_json, "default");
        if (def_s != 0) { store64(p + 24, def_s); }
    } elif (tag == SCH_NUMBER) {
        var min_s = jsonx_get_raw(raw_json, "minimum");
        if (min_s != 0) { store64(p + 32, 1); store64(p + 40, _sch_parse_int(min_s)); }
        var max_s = jsonx_get_raw(raw_json, "maximum");
        if (max_s != 0) { store64(p + 48, 1); store64(p + 56, _sch_parse_int(max_s)); }
        var def_n = jsonx_get_raw(raw_json, "default");
        if (def_n != 0) { store64(p + 24, def_n); }
    } elif (tag == SCH_INTEGER) {
        var imin = jsonx_get_raw(raw_json, "minimum");
        if (imin != 0) { store64(p + 32, 1); store64(p + 40, _sch_parse_int(imin)); }
        var imax = jsonx_get_raw(raw_json, "maximum");
        if (imax != 0) { store64(p + 48, 1); store64(p + 56, _sch_parse_int(imax)); }
        var def_i = jsonx_get_raw(raw_json, "default");
        if (def_i != 0) { store64(p + 24, def_i); }
    } elif (tag == SCH_BOOLEAN) {
        var def_b = jsonx_get_raw(raw_json, "default");
        if (def_b != 0) { store64(p + 24, def_b); }
    } elif (tag == SCH_ARRAY) {
        var items_raw = jsonx_get_raw(raw_json, "items");
        if (items_raw != 0) { store64(p + 64, parse_property(items_raw)); }
    } elif (tag == SCH_OBJECT) {
        store64(p + 72, _compile_object_body(raw_json));
    }
    return p;
}

# Compile an object schema's body (its `properties` + `required`) into
# a fresh CompiledSchema.
fn _compile_object_body(raw_json) {
    var c = compiled_new();
    var props_raw = jsonx_get_raw(raw_json, "properties");
    if (props_raw != 0) {
        # Parse {"key1": <prop1>, "key2": <prop2>, ...}
        var len = strlen(props_raw);
        var i = _cdc_skip_ws(props_raw, len, 0);
        if (i < len) {
            if (load8(props_raw + i) == 123) {
                i = i + 1;
                while (i < len) {
                    i = _cdc_skip_ws(props_raw, len, i);
                    if (i >= len) { i = len; }
                    else {
                        if (load8(props_raw + i) == 125) { i = len; }
                        else {
                            if (load8(props_raw + i) != 34) { i = len; }
                            else {
                                var ks = i + 1;
                                var ke = _jx_skip_string(props_raw, len, i);
                                var key_len = ke - ks - 1;
                                var key = alloc(key_len + 1);
                                memcpy(key, props_raw + ks, key_len);
                                store8(key + key_len, 0);
                                i = _cdc_skip_ws(props_raw, len, ke);
                                if (i < len) {
                                    if (load8(props_raw + i) == 58) {
                                        i = _cdc_skip_ws(props_raw, len, i + 1);
                                        var vs = i;
                                        var ve = _jx_skip_value(props_raw, len, i);
                                        var vlen = ve - vs;
                                        var val = alloc(vlen + 1);
                                        memcpy(val, props_raw + vs, vlen);
                                        store8(val + vlen, 0);
                                        compiled_add_property(c, key, parse_property(val));
                                        i = _cdc_skip_ws(props_raw, len, ve);
                                        if (i < len) {
                                            if (load8(props_raw + i) == 44) { i = i + 1; }
                                        }
                                    } else { i = len; }
                                } else { i = len; }
                            }
                        }
                    }
                }
            }
        }
    }
    var req_raw = jsonx_get_raw(raw_json, "required");
    if (req_raw != 0) {
        var req_vec = vec_new();
        var elems = _sch_split_array(req_raw);
        var ne = vec_len(elems);
        var ei = 0;
        while (ei < ne) {
            var ev = vec_get(elems, ei);
            if (_sch_is_string(ev) == 1) {
                vec_push(req_vec, _sch_unquote(ev));
            }
            ei = ei + 1;
        }
        compiled_set_required(c, req_vec);
    }
    return c;
}

# ================================================================
# compile — ToolSchema → CompiledSchema
# ================================================================

fn compiled_compile(schema) {
    var c = compiled_new();
    var props = schema_properties(schema);
    if (props != 0) {
        var n = vec_len(props);
        var i = 0;
        while (i < n) {
            var pair = vec_get(props, i);
            compiled_add_property(c, schema_prop_key(pair), parse_property(schema_prop_value(pair)));
            i = i + 1;
        }
    }
    var req = schema_required(schema);
    if (req != 0) {
        store64(c + 8, req);
    }
    return c;
}

# ================================================================
# validate — params (raw JSON cstr) against CompiledSchema
# ================================================================
#
# Returns vec of violation cstrs. Empty vec == ok.

fn _violation(violations, path, msg) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, path);
    str_builder_add_cstr(sb, ": ");
    str_builder_add_cstr(sb, msg);
    vec_push(violations, str_data(str_builder_build(sb)));
    return 0;
}

fn _validate_value(path, value, prop, violations) {
    var tag = prop_tag(prop);
    if (tag == SCH_ANY) { return 0; }

    if (tag == SCH_STRING) {
        if (_sch_is_string(value) == 0) {
            _violation(violations, path, "expected string");
            return 0;
        }
        var allowed = prop_enum_values(prop);
        if (allowed != 0) {
            var raw_str = _sch_unquote(value);
            var n = vec_len(allowed);
            var i = 0;
            var found = 0;
            while (i < n) {
                if (streq(vec_get(allowed, i), raw_str) == 1) { found = 1; }
                i = i + 1;
            }
            if (found == 0) {
                var sb = str_builder_new();
                str_builder_add_cstr(sb, "value '");
                str_builder_add_cstr(sb, raw_str);
                str_builder_add_cstr(sb, "' not in enum");
                _violation(violations, path, str_data(str_builder_build(sb)));
            }
        }
        return 0;
    }

    if (tag == SCH_NUMBER) {
        if (_sch_is_number(value) == 0) {
            _violation(violations, path, "expected number");
            return 0;
        }
        var nv = _sch_parse_int(value);
        if (prop_has_min(prop) == 1) {
            if (nv < prop_min(prop)) { _violation(violations, path, "less than minimum"); }
        }
        if (prop_has_max(prop) == 1) {
            if (nv > prop_max(prop)) { _violation(violations, path, "greater than maximum"); }
        }
        return 0;
    }

    if (tag == SCH_INTEGER) {
        if (_sch_is_integer(value) == 0) {
            _violation(violations, path, "expected integer");
            return 0;
        }
        var iv = _sch_parse_int(value);
        if (prop_has_min(prop) == 1) {
            if (iv < prop_min(prop)) { _violation(violations, path, "less than minimum"); }
        }
        if (prop_has_max(prop) == 1) {
            if (iv > prop_max(prop)) { _violation(violations, path, "greater than maximum"); }
        }
        return 0;
    }

    if (tag == SCH_BOOLEAN) {
        if (_sch_is_boolean(value) == 0) {
            _violation(violations, path, "expected boolean");
        }
        return 0;
    }

    if (tag == SCH_ARRAY) {
        if (_sch_is_array(value) == 0) {
            _violation(violations, path, "expected array");
            return 0;
        }
        var items_prop = prop_items(prop);
        if (items_prop != 0) {
            var elems = _sch_split_array(value);
            var n = vec_len(elems);
            var i = 0;
            while (i < n) {
                var sb = str_builder_new();
                str_builder_add_cstr(sb, path);
                str_builder_add_cstr(sb, "[");
                str_builder_add_int(sb, i);
                str_builder_add_cstr(sb, "]");
                _validate_value(str_data(str_builder_build(sb)), vec_get(elems, i), items_prop, violations);
                i = i + 1;
            }
        }
        return 0;
    }

    if (tag == SCH_OBJECT) {
        if (_sch_is_object(value) == 0) {
            _violation(violations, path, "expected object");
            return 0;
        }
        var nested = prop_nested(prop);
        if (nested != 0) {
            _validate_against(path, value, nested, violations);
        }
        return 0;
    }
    return 0;
}

# Validate `value_cstr` (a JSON object) against `compiled` schema, prefixing
# all violations with `path` (use "" for top-level).
fn _validate_against(path, value_cstr, compiled, violations) {
    if (_sch_is_object(value_cstr) == 0) {
        _violation(violations, path, "expected object");
        return 0;
    }
    # Required fields
    var req = compiled_required(compiled);
    if (req != 0) {
        var nr = vec_len(req);
        var ri = 0;
        while (ri < nr) {
            var rkey = vec_get(req, ri);
            if (jsonx_has(value_cstr, rkey) == 0) {
                var sb = str_builder_new();
                str_builder_add_cstr(sb, "missing required field: ");
                str_builder_add_cstr(sb, rkey);
                if (strlen(path) > 0) {
                    _violation(violations, path, str_data(str_builder_build(sb)));
                } else {
                    vec_push(violations, str_data(str_builder_build(sb)));
                }
            }
            ri = ri + 1;
        }
    }
    # Type-check provided fields against properties (extra fields permitted)
    var names = compiled_names(compiled);
    var nn = vec_len(names);
    var ni = 0;
    while (ni < nn) {
        var name = vec_get(names, ni);
        if (jsonx_has(value_cstr, name) == 1) {
            var raw_val = jsonx_get_raw(value_cstr, name);
            var prop = compiled_get_property(compiled, name);
            var sub_path = name;
            if (strlen(path) > 0) {
                var sbp = str_builder_new();
                str_builder_add_cstr(sbp, path);
                str_builder_add_cstr(sbp, ".");
                str_builder_add_cstr(sbp, name);
                sub_path = str_data(str_builder_build(sbp));
            }
            _validate_value(sub_path, raw_val, prop, violations);
        }
        ni = ni + 1;
    }
    return 0;
}

# Public entry: validate `params_cstr` against `compiled`.
# Returns vec of violation cstrs (empty vec == ok).
fn compiled_validate(compiled, params_cstr) {
    var violations = vec_new();
    if (_sch_is_object(params_cstr) == 0) {
        vec_push(violations, "params must be an object");
        return violations;
    }
    _validate_against("", params_cstr, compiled, violations);
    return violations;
}

# --- stream.cyr ---

# bote::stream — progress + cancellation primitives
# Mirrors rust-old/src/stream.rs (data + JSON serialization;
# thread-spawning / mpsc-channel integration deferred until streaming dispatch
# is wired through a transport).
#
# Sentinel: total = 0 - 1 (i.e. -1) means "no total given".
# message = 0 means "no message".

# CancellationToken (8 bytes): pointer to a single i64 flag. Multiple clones
# share the same flag (they hold the same pointer).
fn cancel_token_new() {
    var flag = alloc(8);
    store64(flag, 0);
    return flag;
}

fn cancel_token_cancel(t) { store64(t, 1); return 0; }
fn cancel_token_is_cancelled(t) { return load64(t); }

# ProgressUpdate (24 bytes):
#   +0  progress  i64
#   +8  total     i64 (0 - 1 means "no total")
#   +16 message   cstr or 0

fn progress_update_new(progress, total, message) {
    var u = alloc(24);
    store64(u, progress);
    store64(u + 8, total);
    store64(u + 16, message);
    return u;
}

fn progress_update_progress(u) { return load64(u); }
fn progress_update_total(u) { return load64(u + 8); }
fn progress_update_message(u) { return load64(u + 16); }

fn progress_update_has_total(u) {
    if (load64(u + 8) == 0 - 1) { return 0; }
    return 1;
}

# ProgressSender (16 bytes):
#   +0  updates_vec  vec of ProgressUpdate ptrs (collected synchronously for now)
#   +8  closed       0/1 (1 = receiver dropped, send becomes no-op)
#
# When real channels arrive (lib/thread.cyr MPSC), swap the vec for a chan ptr.

fn progress_sender_new() {
    var s = alloc(16);
    store64(s, vec_new());
    store64(s + 8, 0);
    return s;
}

fn progress_sender_updates(s) { return load64(s); }
fn progress_sender_close(s) { store64(s + 8, 1); return 0; }
fn progress_sender_is_closed(s) { return load64(s + 8); }

fn progress_sender_send(s, update) {
    if (progress_sender_is_closed(s) == 1) { return 0; }
    vec_push(progress_sender_updates(s), update);
    return 0;
}

# Convenience: report progress out of total.
fn progress_sender_report(s, progress, total) {
    return progress_sender_send(s, progress_update_new(progress, total, 0));
}

# Convenience: report progress with a message.
fn progress_sender_report_msg(s, progress, total, message) {
    return progress_sender_send(s, progress_update_new(progress, total, message));
}

# StreamContext (16 bytes):
#   +0  progress     ProgressSender ptr
#   +8  cancellation CancellationToken ptr

fn stream_context_new() {
    var c = alloc(16);
    store64(c, progress_sender_new());
    store64(c + 8, cancel_token_new());
    return c;
}

fn stream_context_progress(c) { return load64(c); }
fn stream_context_cancellation(c) { return load64(c + 8); }

# ================================================================
# JSON-RPC notification wire builders
# ================================================================
#
# `notification_wire` is the generic server→client notification envelope:
#   {"jsonrpc":"2.0","method":<method>,"params":<params>}
# `method` is a plain string (JSON-escaped); `params` is a raw JSON literal
# cstr already shaped by the caller (0 ⇒ emit {}). These builders only
# produce the wire bytes — delivery is the transport's job (the streamable
# ResumptionBuffer; see src/transport_streamable.cyr).

fn notification_wire(method, params) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"jsonrpc\":\"2.0\",\"method\":\"");
    _json_emit_escaped(sb, method);
    str_builder_add_cstr(sb, "\",\"params\":");
    if (params == 0) { str_builder_add_cstr(sb, "{}"); }
    else { str_builder_add_cstr(sb, params); }
    str_builder_add_cstr(sb, "}");
    return str_data(str_builder_build(sb));
}

# `notifications/tools/list_changed` — the tool set changed.
fn tools_list_changed_notification() {
    return notification_wire("notifications/tools/list_changed", "{}");
}

# `notifications/prompts/list_changed` — the prompt set changed.
fn prompts_list_changed_notification() {
    return notification_wire("notifications/prompts/list_changed", "{}");
}

# `notifications/resources/list_changed` — the resource set changed.
fn resources_list_changed_notification() {
    return notification_wire("notifications/resources/list_changed", "{}");
}

# `notifications/resources/updated` — the resource at `uri` changed.
fn resource_updated_notification(uri) {
    var pb = str_builder_new();
    str_builder_add_cstr(pb, "{\"uri\":\"");
    _json_emit_escaped(pb, uri);
    str_builder_add_cstr(pb, "\"}");
    return notification_wire("notifications/resources/updated", str_data(str_builder_build(pb)));
}

# Build a JSON-RPC notification cstr for a progress update.
# request_id is a raw JSON literal cstr (e.g. "1", "\"abc\"", "null").
fn progress_notification(request_id, update) {
    var pb = str_builder_new();
    str_builder_add_cstr(pb, "{\"progressToken\":");
    if (request_id == 0) { str_builder_add_cstr(pb, "null"); }
    else { str_builder_add_cstr(pb, request_id); }
    str_builder_add_cstr(pb, ",\"progress\":");
    str_builder_add_int(pb, progress_update_progress(update));
    if (progress_update_has_total(update) == 1) {
        str_builder_add_cstr(pb, ",\"total\":");
        str_builder_add_int(pb, progress_update_total(update));
    }
    var msg = progress_update_message(update);
    if (msg != 0) {
        str_builder_add_cstr(pb, ",\"message\":\"");
        _json_emit_escaped(pb, msg);
        str_builder_add_cstr(pb, "\"");
    }
    str_builder_add_cstr(pb, "}");
    return notification_wire("notifications/progress", str_data(str_builder_build(pb)));
}

# --- session.cyr ---

# bote::session — MCP session lifecycle (MCP 2025-11-25)
# Mirrors rust-old/src/session.rs

# ================================================================
# Header name constants
# ================================================================
fn mcp_protocol_version_header() { return "MCP-Protocol-Version"; }
fn mcp_session_id_header() { return "MCP-Session-Id"; }

# ================================================================
# validate_protocol_version(version_cstr) → 0 ok / err_msg cstr
# ================================================================
fn validate_protocol_version(v) {
    if (v == 0) { return "unsupported MCP protocol version: (null)"; }
    if (streq(v, "2024-11-05") == 1) { return 0; }
    if (streq(v, "2025-03-26") == 1) { return 0; }
    if (streq(v, "2025-11-25") == 1) { return 0; }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "unsupported MCP protocol version: ");
    str_builder_add_cstr(sb, v);
    return str_data(str_builder_build(sb));
}

# ================================================================
# validate_origin(origin_cstr, allowed_origins_vec) → 0 ok / err_msg cstr
# ================================================================
fn validate_origin(origin, allowed_origins) {
    # Empty Origin header is allowed (same-origin requests omit it).
    if (origin == 0) { return 0; }
    if (strlen(origin) == 0) { return 0; }

    if (allowed_origins != 0) {
        var n = vec_len(allowed_origins);
        # Wildcard short-circuit.
        var i = 0;
        while (i < n) {
            if (streq(vec_get(allowed_origins, i), "*") == 1) { return 0; }
            i = i + 1;
        }
        if (n == 0) { return "no origins allowed (strict mode)"; }
        # Exact match.
        var j = 0;
        while (j < n) {
            if (streq(vec_get(allowed_origins, j), origin) == 1) { return 0; }
            j = j + 1;
        }
    } else {
        return "no origins allowed (strict mode)";
    }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "origin not allowed: ");
    str_builder_add_cstr(sb, origin);
    return str_data(str_builder_build(sb));
}

# ================================================================
# Session ID generation — 32 hex chars from /dev/urandom (16 random bytes)
# ================================================================

fn _hex_byte(b, out) {
    var hi = (b >> 4) & 15;
    var lo = b & 15;
    if (hi < 10) { store8(out, 48 + hi); } else { store8(out, 87 + hi); }
    if (lo < 10) { store8(out + 1, 48 + lo); } else { store8(out + 1, 87 + lo); }
    return 0;
}

fn _gen_session_id() {
    var raw = alloc(16);

    var out = alloc(33);
    var fd = syscall(SYS_OPEN, "/dev/urandom", 0, 0);
    if (fd < 0) {
        # 1.9.4 audit M2: clock-based fallback was predictable. There is
        # no acceptable substitute for /dev/urandom here — refuse to
        # mint a session ID rather than ship a guessable one.
        syscall(1, 2, "fatal: cannot open /dev/urandom for session id\n", 47);
        syscall(SYS_EXIT, 90);
    }
    # Loop until 16 bytes received. A short read is unusual but possible
    # on some environments; weak-RNG entropy in the tail bytes was an
    # audit finding.
    var got = 0;
    while (got < 16) {
        var r = syscall(SYS_READ, fd, raw + got, 16 - got);
        if (r <= 0) {
            syscall(SYS_CLOSE, fd);
            syscall(1, 2, "fatal: short read from /dev/urandom\n", 36);
            syscall(SYS_EXIT, 90);
        }
        got = got + r;
    }
    syscall(SYS_CLOSE, fd);
    var i = 0;
    while (i < 16) {
        _hex_byte(load8(raw + i), out + i * 2);
        i = i + 1;
    }
    store8(out + 32, 0);
    return out;
}

# ================================================================
# McpSession (40 bytes):
#   +0  session_id        cstr
#   +8  protocol_version  cstr
#   +16 created_at_ns     i64 (monotonic)
#   +24 last_active_ns    i64
#   +32 outbound          OPAQUE ptr or 0 — a per-session server→client
#                         notification bundle. session.cyr treats it as an
#                         opaque i64 and never dereferences or frees it: the
#                         buffer types (ResumptionBuffer / EventIdGenerator)
#                         live in transport_streamable.cyr, which is only in
#                         the bote-streamable binary — session.cyr is in all
#                         three, so it must stay type-agnostic. The streamable
#                         transport lazily allocs the bundle (see
#                         _strm_session_outbound); it drops with the session.
# ================================================================
fn mcp_session_new(sid, protocol_version, now_ns) {
    var s = alloc(40);
    store64(s, sid);
    store64(s + 8, protocol_version);
    store64(s + 16, now_ns);
    store64(s + 24, now_ns);
    store64(s + 32, 0);
    return s;
}

fn mcp_session_id(s) { return load64(s); }
fn mcp_session_protocol_version(s) { return load64(s + 8); }
fn mcp_session_created_at(s) { return load64(s + 16); }
fn mcp_session_last_active(s) { return load64(s + 24); }
fn mcp_session_touch(s, now_ns) { store64(s + 24, now_ns); return 0; }
fn mcp_session_outbound(s) { return load64(s + 32); }
fn mcp_session_set_outbound(s, ptr) { store64(s + 32, ptr); return 0; }

# ================================================================
# SessionStore (24 bytes):
#   +0  sessions    hashmap: sid_cstr -> McpSession ptr
#   +8  ids         vec of sid_cstrs (insertion order — for prune iteration)
#   +16 timeout_ns  i64
# ================================================================
fn session_store_new(timeout_ns) {
    var st = alloc(24);
    store64(st, map_new());
    store64(st + 8, vec_new());
    store64(st + 16, timeout_ns);
    return st;
}

# Default: 1 hour timeout (3600 * 1e9 ns).
fn session_store_default() {
    return session_store_new(3600000000000);
}

fn session_store_sessions(st) { return load64(st); }
fn session_store_ids(st) { return load64(st + 8); }
fn session_store_timeout_ns(st) { return load64(st + 16); }

# Create a new session and return its ID (cstr).
fn session_store_create(st, protocol_version) {
    var sid = _gen_session_id();
    var now = clock_now_ns();
    var session = mcp_session_new(sid, protocol_version, now);
    map_set(session_store_sessions(st), sid, session);
    vec_push(session_store_ids(st), sid);
    return sid;
}

# Validate and touch a session. Returns the session ptr or 0 if unknown.
fn session_store_validate(st, sid) {
    var s = map_get(session_store_sessions(st), sid);
    if (s == 0) { return 0; }
    mcp_session_touch(s, clock_now_ns());
    return s;
}

# Remove a session. Returns 1 if found, 0 if not.
fn session_store_remove(st, sid) {
    if (map_has(session_store_sessions(st), sid) == 0) { return 0; }
    map_delete(session_store_sessions(st), sid);
    var ids = session_store_ids(st);
    var n = vec_len(ids);
    var i = 0;
    while (i < n) {
        if (streq(vec_get(ids, i), sid) == 1) {
            vec_remove(ids, i);
            i = n;
        }
        i = i + 1;
    }
    return 1;
}

# Number of active sessions.
fn session_store_active_count(st) {
    return map_count(session_store_sessions(st));
}

# Prune sessions inactive longer than timeout. Returns the number pruned.
fn session_store_prune_expired(st) {
    var now = clock_now_ns();
    var timeout = session_store_timeout_ns(st);
    var sessions = session_store_sessions(st);
    var ids = session_store_ids(st);
    var pruned = 0;
    var i = 0;
    while (i < vec_len(ids)) {
        var sid = vec_get(ids, i);
        var s = map_get(sessions, sid);
        if (s == 0) {
            vec_remove(ids, i);
        } else {
            var age = now - mcp_session_last_active(s);
            if (age >= timeout) {
                map_delete(sessions, sid);
                vec_remove(ids, i);
                pruned = pruned + 1;
            } else {
                i = i + 1;
            }
        }
    }
    return pruned;
}

# --- discovery.cyr ---

# bote::discovery — cross-node tool announcements
# Mirrors rust-old/src/discovery.rs.
#
# The Rust version publishes announcements via majra pub/sub. Cyrius doesn't
# have a `lib/majra.cyr` port yet (will land with v0.2.0 events module), so
# this module ships the data layer + a callback-based announcement sink:
# callers register a function pointer that receives each announcement.
# When the events module lands, the publisher path becomes a one-line wire-up.

# ToolAnnouncement (16 bytes):
#   +0  node_id  cstr
#   +8  tools    vec of ToolDef ptrs
fn announcement_new(node_id, tools) {
    var a = alloc(16);
    store64(a, node_id);
    store64(a + 8, tools);
    return a;
}

fn announcement_node_id(a) { return load64(a); }
fn announcement_tools(a) { return load64(a + 8); }

# Serialize a ToolAnnouncement to JSON: {"node_id":"...","tools":[...]}
# Reuses dispatch's _emit_schema for each tool's inputSchema.
fn announcement_to_json(a) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"node_id\":\"");
    _json_emit_escaped(sb, announcement_node_id(a));
    str_builder_add_cstr(sb, "\",\"tools\":[");
    var tools = announcement_tools(a);
    if (tools != 0) {
        var n = vec_len(tools);
        var i = 0;
        while (i < n) {
            if (i > 0) { str_builder_add_cstr(sb, ","); }
            var t = vec_get(tools, i);
            str_builder_add_cstr(sb, "{");
            _json_emit_str_field(sb, "name", tool_def_name(t));
            str_builder_add_cstr(sb, ",");
            _json_emit_str_field(sb, "description", tool_def_description(t));
            str_builder_add_cstr(sb, ",\"inputSchema\":");
            _emit_schema(sb, tool_def_input_schema(t));
            var v = tool_def_version(t);
            if (v != 0) {
                str_builder_add_cstr(sb, ",");
                _json_emit_str_field(sb, "version", v);
            }
            var dep = tool_def_deprecated(t);
            if (dep != 0) {
                str_builder_add_cstr(sb, ",");
                _json_emit_str_field(sb, "deprecated", dep);
            }
            str_builder_add_cstr(sb, "}");
            i = i + 1;
        }
    }
    str_builder_add_cstr(sb, "]}");
    return str_data(str_builder_build(sb));
}

# DiscoveryService (24 bytes):
#   +0  node_id     cstr
#   +8  event_sink  EventSink ptr (or 0 — announcements then build-only)
#   +16 topic       cstr — TOPIC_TOOL_ANNOUNCE
#
# v1.0.0 used a bare publish_fp here; v1.1.0 unifies on EventSink so callers
# can plug in MajraEvents (v1.2.0) the same way they would for tool-call events.

fn discovery_topic_announce() { return TOPIC_TOOL_ANNOUNCE(); }

fn discovery_new(node_id, event_sink) {
    var d = alloc(24);
    store64(d, node_id);
    store64(d + 8, event_sink);
    store64(d + 16, discovery_topic_announce());
    return d;
}

fn discovery_node_id(d)    { return load64(d); }
fn discovery_event_sink(d) { return load64(d + 8); }
fn discovery_topic(d)      { return load64(d + 16); }

# Announce a vec of ToolDef ptrs. If no event_sink is configured, the
# announcement is built but not delivered (no-op). Returns the JSON string
# emitted (useful for tests + future SSE streams).
fn discovery_announce(d, tools) {
    var ann = announcement_new(discovery_node_id(d), tools);
    var json = announcement_to_json(ann);
    event_sink_publish(discovery_event_sink(d), discovery_topic(d), json);
    return json;
}

# DiscoveryReceiver — a vec-backed mailbox a test/consumer drains via try_recv.
# When events lands, this becomes a thin wrapper over a majra subscription.

fn discovery_receiver_new() {
    var r = alloc(8);
    store64(r, vec_new());
    return r;
}

fn discovery_receiver_queue(r) { return load64(r); }

# Push an announcement (JSON cstr) into the receiver's queue.
fn discovery_receiver_push(r, json) {
    vec_push(discovery_receiver_queue(r), json);
    return 0;
}

# Pop the next announcement JSON or 0 if empty.
fn discovery_receiver_try_recv(r) {
    var q = discovery_receiver_queue(r);
    if (vec_len(q) == 0) { return 0; }
    var head = vec_get(q, 0);
    vec_remove(q, 0);
    return head;
}

fn discovery_receiver_len(r) { return vec_len(discovery_receiver_queue(r)); }

# --- auth.cyr ---

# bote::auth — bearer-token middleware (RFC 6750).
#
# First slice of the roadmap `auth` item. OAuth 2.1 + PKCE follow in
# later releases; this one delivers the substrate they all sit on:
# extract `Authorization: Bearer <token>` from an HTTP request, hand
# the token to a caller-supplied validator function pointer, and emit
# a spec-compliant 401 if the token is missing or rejected.
#
# The middleware is **opt-in**: a transport config with no validator
# set behaves exactly as it did before this release. A config that
# does set one calls `auth_bearer_check` on every request and short-
# circuits with 401 when validation fails. Validator signature:
#
#     fn validator(token_cstr, ctx) → claims_ptr | 0
#
# A non-zero return is treated as success; the value is opaque to
# bote (today) — future releases will pass it down to handlers when
# request-scoped context lands. Returning 0 means "reject".
#
# Why fn pointer + ctx instead of a hardcoded scheme? Real deployments
# vary: static-list dev servers, JWT verifiers (HS256 / RS256), opaque
# tokens against a backend lookup, OAuth introspection. The shape lets
# each consumer drop in their own validator without bote knowing the
# crypto.

# ================================================================
# Authorization header → token cstr
# ================================================================

# Return a fresh alloc'd cstr containing the token after "Bearer ", or
# 0 if the header is absent or doesn't start with "Bearer ".
# Per RFC 6750 §2.1, the scheme name is case-insensitive.
fn auth_bearer_extract(buf, blen) {
    var hdr = sandhi_server_find_header(buf, blen, "Authorization");
    if (hdr == 0) { return 0; }

    # Match "Bearer " (7 chars) case-insensitively at the start
    if (strlen(hdr) < 7) { return 0; }
    var b0 = load8(hdr);     if (b0 != 66 && b0 != 98)  { return 0; }   # B/b
    var b1 = load8(hdr + 1); if (b1 != 101 && b1 != 69) { return 0; }   # E/e
    var b2 = load8(hdr + 2); if (b2 != 97 && b2 != 65)  { return 0; }   # A/a
    var b3 = load8(hdr + 3); if (b3 != 114 && b3 != 82) { return 0; }   # R/r
    var b4 = load8(hdr + 4); if (b4 != 101 && b4 != 69) { return 0; }   # E/e
    var b5 = load8(hdr + 5); if (b5 != 114 && b5 != 82) { return 0; }   # R/r
    if (load8(hdr + 6) != 32) { return 0; }                              # space

    # Skip leading optional whitespace (some clients double-space)
    var start = 7;
    while (load8(hdr + start) == 32) { start = start + 1; }
    if (load8(hdr + start) == 0) { return 0; }   # empty token

    # Find end of header (NUL).
    var end = start;
    while (load8(hdr + end) != 0) { end = end + 1; }

    # Trim trailing OWS (space or tab). sandhi_server_find_header already stripped
    # the CR; this guards against a stray space the caller left.
    var done = 0;
    while (done == 0 && end > start) {
        var c = load8(hdr + end - 1);
        if (c == 32 || c == 9) { end = end - 1; }
        else { done = 1; }
    }

    var token_len = end - start;
    if (token_len <= 0) { return 0; }
    var out = alloc(token_len + 1);
    memcpy(out, hdr + start, token_len);
    store8(out + token_len, 0);
    return out;
}

# ================================================================
# Validators (built-in shapes — consumers provide their own)
# ================================================================

# Always-pass validator. Only useful for tests / disabling auth checks
# in dev. ctx is ignored.
fn auth_validator_allow_all(token, ctx) {
    if (token == 0) { return 0; }
    if (load8(token) == 0) { return 0; }
    return token;
}

# Static-allowlist validator. ctx is a vec of cstr tokens. Returns the
# token cstr (truthy) on match, 0 otherwise.
#
# Constant-time inner comparison: lengths are checked first (leaks token
# length, unavoidable), then bytes are XOR-accumulated with no early
# exit. Outer vec walk also doesn't early-exit on match — defeats both
# the per-byte timing oracle (byte-by-byte token guessing) AND the
# match-position oracle (which entry matched). Fix for the 1.9.4 audit's
# H2 finding.
#
# CT-compare and vec walk are inlined here to stay under cyrius 4.7.1's
# function-table headroom for src/main.cyr.
fn auth_validator_allowlist(token, allowed_vec) {
    if (token == 0 || allowed_vec == 0) { return 0; }
    var tlen = strlen(token);
    var n = vec_len(allowed_vec);
    var matched = 0;
    var i = 0;
    while (i < n) {
        var cand = vec_get(allowed_vec, i);
        if (cand != 0) {
            if (strlen(cand) == tlen) {
                var diff = 0;
                var j = 0;
                while (j < tlen) {
                    diff = diff | (load8(token + j) ^ load8(cand + j));
                    j = j + 1;
                }
                if (diff == 0) { matched = 1; }
            }
        }
        i = i + 1;
    }
    if (matched == 1) { return token; }
    return 0;
}

# ================================================================
# 401 response builder
# ================================================================

# Send a spec-compliant 401 with WWW-Authenticate. `realm` is what
# clients display in their auth prompt (e.g. "mcp" or your app name).
fn auth_send_unauthorized(cfd, realm) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "WWW-Authenticate: Bearer realm=\"");
    if (realm == 0) { str_builder_add_cstr(sb, "mcp"); }
    else { str_builder_add_cstr(sb, realm); }
    str_builder_add_cstr(sb, "\"\r\n");
    var hdrs = str_data(str_builder_build(sb));
    # sandhi_server_send_response builds: status line + Content-Type + Content-Length
    # + extra hdrs + blank line + body. We want a 401 with our header.
    sandhi_server_send_response(cfd, HTTP_UNAUTHORIZED, "Unauthorized",
    "text/plain", "", 0, hdrs);
    return 0;
}

# ================================================================
# Middleware entry — call from each transport handler.
#
# Returns 0 on pass (no validator configured, or token validated).
# Returns HTTP_UNAUTHORIZED (401) on rejection — the response is
# already on the wire, caller should `return 0;` to its handler frame.
# ================================================================

fn auth_bearer_check(cfd, buf, blen, validator_fp, validator_ctx, claims_out) {
    if (validator_fp == 0) { return 0; }    # auth disabled

    var token = auth_bearer_extract(buf, blen);
    if (token == 0) {
        auth_send_unauthorized(cfd, 0);
        return HTTP_UNAUTHORIZED;
    }
    var claims = fncall2(validator_fp, token, validator_ctx);
    if (claims == 0) {
        auth_send_unauthorized(cfd, 0);
        return HTTP_UNAUTHORIZED;
    }
    # 2.5.0: surface validator's return so transport can thread to handler.
    if (claims_out != 0) { store64(claims_out, claims); }
    return 0;
}

# HTTP request smuggling mitigation: each HTTP-family transport inlines
# `if (sandhi_server_find_header(buf, n, "Transfer-Encoding") != 0) { 400 + return }`
# right after its Origin check. We don't dechunk; rejecting any inbound
# Transfer-Encoding eliminates the CL.TE / TE.CL smuggling class
# (RFC 9112 §6). Inlined rather than helper'd to stay under cyrius
# 4.7.1's function-table headroom for the production main.cyr build.

# --- transport_stdio.cyr ---

# bote::transport::stdio — line-oriented JSON-RPC over stdin/stdout
# Mirrors rust-old/src/transport/stdio.rs (sync path; streaming deferred)

# Buffer for in-flight stdin data (large enough for any reasonable JSON-RPC line).
# Heap-allocated to avoid the cyrius static-buffer size limit.
var STDIO_BUF_SIZE = 131072;
var _stdio_buf = 0;
var _stdio_buf_len = 0;

fn _stdio_init() {
    if (_stdio_buf == 0) {
        _stdio_buf = alloc(STDIO_BUF_SIZE);
    }
    _stdio_buf_len = 0;
    return 0;
}

# Process all complete (newline-terminated) lines in the stdio buffer.
# Returns 0 if no lines processed; 1 if at least one line was dispatched.
fn _stdio_process_lines(dispatcher) {
    var processed = 0;
    var scanned = 0;
    var line_start = 0;
    while (scanned < _stdio_buf_len) {
        if (load8(_stdio_buf + scanned) == 10) {
            # Replace newline with NUL → cstr
            var line_len = scanned - line_start;
            store8(_stdio_buf + scanned, 0);
            if (line_len > 0) {
                var line_ptr = _stdio_buf + line_start;
                var resp = codec_process_message(line_ptr, dispatcher, 0);
                if (resp != 0) {
                    syscall(SYS_WRITE, 1, resp, strlen(resp));
                    syscall(SYS_WRITE, 1, "\n", 1);
                }
                processed = 1;
            }
            line_start = scanned + 1;
        }
        scanned = scanned + 1;
    }
    # Shift leftover (partial line) to start of buffer
    if (line_start > 0) {
        var leftover = _stdio_buf_len - line_start;
        if (leftover > 0) {
            memcpy(_stdio_buf, _stdio_buf + line_start, leftover);
        }
        _stdio_buf_len = leftover;
    }
    return processed;
}

# Run the stdio transport loop. Reads stdin until EOF, dispatches each
# newline-terminated message, writes responses to stdout.
fn transport_stdio_run(dispatcher) {
    _stdio_init();
    while (1 == 1) {
        var space = STDIO_BUF_SIZE - _stdio_buf_len;
        if (space <= 0) {
            # Line too long — drop the buffer and continue
            _stdio_buf_len = 0;
            space = STDIO_BUF_SIZE;
        }
        var n = syscall(SYS_READ, 0, _stdio_buf + _stdio_buf_len, space);
        if (n <= 0) {
            # EOF — process any final line that lacks a trailing newline
            if (_stdio_buf_len > 0) {
                store8(_stdio_buf + _stdio_buf_len, 0);
                var resp = codec_process_message(_stdio_buf, dispatcher, 0);
                if (resp != 0) {
                    syscall(SYS_WRITE, 1, resp, strlen(resp));
                    syscall(SYS_WRITE, 1, "\n", 1);
                }
            }
            return 0;
        }
        _stdio_buf_len = _stdio_buf_len + n;
        _stdio_process_lines(dispatcher);
    }
    return 0;
}

# --- transport_http.cyr ---

# bote::transport::http — HTTP/1.1 transport for JSON-RPC
# Mirrors rust-old/src/transport/http.rs (sync, single-conn-at-a-time).
#
# Built on cyrius stdlib `lib/http_server.cyr` (4.5.0+) — request reading,
# parsing, and response builders all live there. This file just wires the
# MCP middleware (origin / protocol-version / session) and routes
# `POST <endpoint>` to codec_process_message.

# ================================================================
# HttpConfig (72 bytes):
#   +0  endpoint_path     cstr (e.g. "/mcp")
#   +8  bind_addr         i64 (network-order IPv4)
#   +16 port              i64
#   +24 allowed_origins   vec of cstrs or 0
#   +32 require_protocol  0/1
#   +40 session_store     SessionStore ptr or 0
#   +48 dispatcher        Dispatcher ptr (set by transport_http_run)
#   +56 bearer_validator  fn ptr (token, ctx) → claims | 0, or 0 to disable
#   +64 bearer_ctx        i64 ctx passed verbatim to validator
# ================================================================

fn http_config_new(path, addr, port) {
    var c = alloc(72);
    store64(c, path);
    store64(c + 8, addr);
    store64(c + 16, port);
    store64(c + 24, 0);
    store64(c + 32, 0);
    store64(c + 40, 0);
    store64(c + 48, 0);
    store64(c + 56, 0);
    store64(c + 64, 0);
    return c;
}

fn http_config_with_allowed_origins(c, vec) { store64(c + 24, vec); return c; }
fn http_config_with_require_protocol(c, r)  { store64(c + 32, r);   return c; }
fn http_config_with_session_store(c, st)    { store64(c + 40, st);  return c; }
fn http_config_with_bearer_validator(c, fp, ctx) {
    store64(c + 56, fp);
    store64(c + 64, ctx);
    return c;
}

fn http_config_path(c)             { return load64(c); }
fn http_config_addr(c)             { return load64(c + 8); }
fn http_config_port(c)             { return load64(c + 16); }
fn http_config_allowed_origins(c)  { return load64(c + 24); }
fn http_config_require_protocol(c) { return load64(c + 32); }
fn http_config_session_store(c)    { return load64(c + 40); }
fn http_config_dispatcher(c)       { return load64(c + 48); }
fn http_config_bearer_validator(c) { return load64(c + 56); }
fn http_config_bearer_ctx(c)       { return load64(c + 64); }

# ================================================================
# Middleware. Each returns 0 on pass, or the HTTP status code on rejection
# (and writes the rejection response on cfd).
# ================================================================

fn _http_check_origin(cfd, buf, blen, config) {
    var allowed = http_config_allowed_origins(config);
    if (allowed == 0) { return 0; }
    var origin = sandhi_server_find_header(buf, blen, "Origin");
    var orig = origin;
    if (orig == 0) { orig = ""; }
    if (validate_origin(orig, allowed) != 0) {
        sandhi_server_send_status(cfd, HTTP_FORBIDDEN, "Forbidden");
        return HTTP_FORBIDDEN;
    }
    return 0;
}

fn _http_check_protocol(cfd, buf, blen, config) {
    var v = sandhi_server_find_header(buf, blen, "MCP-Protocol-Version");
    if (v == 0) {
        if (http_config_require_protocol(config) == 1) {
            sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request");
            return HTTP_BAD_REQUEST;
        }
        return 0;
    }
    if (validate_protocol_version(v) != 0) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request");
        return HTTP_BAD_REQUEST;
    }
    return 0;
}

fn _http_check_session(cfd, buf, blen, config, method) {
    var st = http_config_session_store(config);
    if (st == 0) { return 0; }
    var sid = sandhi_server_find_header(buf, blen, "MCP-Session-Id");
    if (sid == 0) {
        if (streq(method, "initialize") == 1) { return 0; }
        sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
        return HTTP_NOT_FOUND;
    }
    if (session_store_validate(st, sid) == 0) {
        sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
        return HTTP_NOT_FOUND;
    }
    return 0;
}

fn _http_peek_method(body) {
    var m = jsonx_get_str(body, "method");
    if (m == 0) { return ""; }
    return m;
}

# ================================================================
# Request handler — invoked per connection by sandhi_server_run
# ================================================================

fn _http_handle(config, cfd, buf, n) {
    var method = sandhi_server_get_method(buf, n);
    var path   = sandhi_server_get_path(buf, n);

    if (streq(method, "POST") == 0) {
        sandhi_server_send_status(cfd, HTTP_METHOD_NOT_ALLOWED, "Method Not Allowed");
        return 0;
    }
    if (streq(sandhi_server_path_only(path), http_config_path(config)) == 0) {
        sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
        return 0;
    }

    if (_http_check_origin(cfd, buf, n, config) != 0) { return 0; }
    if (sandhi_server_find_header(buf, n, "Transfer-Encoding") != 0) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request"); return 0;
    }
    var claims_slot[8]; store64(&claims_slot, 0);
    if (auth_bearer_check(cfd, buf, n,
    http_config_bearer_validator(config),
    http_config_bearer_ctx(config),
    &claims_slot) != 0) { return 0; }
    if (_http_check_protocol(cfd, buf, n, config) != 0) { return 0; }

    var bo = sandhi_server_body_offset(buf, n);
    if (bo < 0 || bo > n) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request");
        return 0;
    }
    var clen = sandhi_server_content_length(buf, n);
    # 1.9.6 audit M1: 413 on oversized declared body (before clamp).
    if (clen > 61440) {
        sandhi_server_send_status(cfd, HTTP_PAYLOAD_TOO_LARGE, "Payload Too Large"); return 0;
    }
    if (clen <= 0) { clen = n - bo; }
    if (clen < 0) { clen = 0; }
    # Clamp to the bytes we actually received. Guards against a lying
    # Content-Length header declaring more body than arrived on the wire —
    # without this, memcpy would read past the request buffer.
    if (clen > n - bo) { clen = n - bo; }
    var body = alloc(clen + 1);
    memcpy(body, buf + bo, clen);
    store8(body + clen, 0);

    var rpc_method = _http_peek_method(body);
    if (_http_check_session(cfd, buf, n, config, rpc_method) != 0) { return 0; }

    # Initialize: optionally create a session, return MCP-Session-Id header.
    var extra = 0;
    var st = http_config_session_store(config);
    if (st != 0 && streq(rpc_method, "initialize") == 1) {
        var pv = jsonx_get_str(jsonx_get_raw(body, "params"), "protocolVersion");
        if (pv == 0) { pv = "2025-11-25"; }
        var sid = session_store_create(st, pv);
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "MCP-Session-Id: ");
        str_builder_add_cstr(sb, sid);
        str_builder_add_cstr(sb, "\r\n");
        extra = str_data(str_builder_build(sb));
    }

    var resp = codec_process_message(body, http_config_dispatcher(config), load64(&claims_slot));
    if (resp == 0) {
        sandhi_server_send_204(cfd, extra);
        return 0;
    }
    sandhi_server_send_response(cfd, HTTP_OK, "OK", "application/json",
    resp, strlen(resp), extra);
    return 0;
}

# ================================================================
# Server entry — defers to stdlib sandhi_server_run
# ================================================================

fn transport_http_run(dispatcher, config) {
    store64(config + 48, dispatcher);
    return sandhi_server_run(http_config_addr(config),
    http_config_port(config),
    &_http_handle,
    config);
}

# --- transport_unix.cyr ---

# bote::transport::unix — line-oriented JSON-RPC over a Unix domain socket.
# Mirrors rust-old/src/transport/unix.rs (sync, single-connection-at-a-time).
#
# net.cyr only has AF_INET helpers, so we open the AF_UNIX socket directly.

var AF_UNIX = 1;

# Build a sockaddr_un (110 bytes) at addr_buf with `path` (cstr).
# Returns the actual struct length to pass to bind() (sun_family + path + NUL).
fn _unix_sockaddr(addr_buf, path) {
    memset(addr_buf, 0, 110);
    store16(addr_buf, AF_UNIX);
    var plen = strlen(path);
    if (plen > 107) { plen = 107; }
    memcpy(addr_buf + 2, path, plen);
    store8(addr_buf + 2 + plen, 0);
    return 2 + plen + 1;
}

# Process complete (newline-terminated) lines in the per-connection buffer.
# Returns 1 if any was processed.
fn _unix_process_lines(cfd, dispatcher, buf, blen_ptr) {
    var blen = load64(blen_ptr);
    var processed = 0;
    var scanned = 0;
    var line_start = 0;
    while (scanned < blen) {
        if (load8(buf + scanned) == 10) {
            store8(buf + scanned, 0);
            var line_len = scanned - line_start;
            if (line_len > 0) {
                var resp = codec_process_message(buf + line_start, dispatcher, 0);
                if (resp != 0) {
                    sock_send(cfd, resp, strlen(resp));
                    sock_send(cfd, "\n", 1);
                }
                processed = 1;
            }
            line_start = scanned + 1;
        }
        scanned = scanned + 1;
    }
    if (line_start > 0) {
        var leftover = blen - line_start;
        if (leftover > 0) { memcpy(buf, buf + line_start, leftover); }
        store64(blen_ptr, leftover);
    }
    return processed;
}

var UNIX_BUF_SIZE = 131072;

fn _unix_handle_client(cfd, dispatcher) {
    var buf = alloc(UNIX_BUF_SIZE);
    var blen_slot = alloc(8);
    store64(blen_slot, 0);
    while (1 == 1) {
        var blen = load64(blen_slot);
        var space = UNIX_BUF_SIZE - blen;
        if (space <= 0) {
            store64(blen_slot, 0);
            blen = 0;
            space = UNIX_BUF_SIZE;
        }
        var n_r = sock_recv(cfd, buf + blen, space);
        if (is_err_result(n_r) == 1) { return 0; }
        var n = payload(n_r);
        if (n <= 0) {
            # EOF — flush any final unterminated line.
            if (blen > 0) {
                store8(buf + blen, 0);
                var resp = codec_process_message(buf, dispatcher, 0);
                if (resp != 0) {
                    sock_send(cfd, resp, strlen(resp));
                    sock_send(cfd, "\n", 1);
                }
            }
            return 0;
        }
        store64(blen_slot, blen + n);
        _unix_process_lines(cfd, dispatcher, buf, blen_slot);
    }
    return 0;
}

# Bind a Unix socket at `path` and accept connections, dispatching each
# newline-terminated message via codec_process_message. Removes any prior
# socket file at that path.
fn transport_unix_run(dispatcher, path) {
    #ifdef CYRIUS_TARGET_AGNOS
    # agnos has no AF_UNIX domain sockets — the Unix-socket transport
    # fail-closes there (bote's TCP / streamable / ws transports carry
    # traffic instead). Guarding the entry drops the whole AF_UNIX subtree
    # (SYS_SOCKET/BIND/CHMOD/LISTEN/ACCEPT — unrelated syscall numbers on
    # agnos) off the agnos target; mirrors majra's ipc AF_UNIX guard.
    return 1;
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    syscall(SYS_UNLINK, path);
    var sfd = syscall(SYS_SOCKET, AF_UNIX, SOCK_STREAM, 0);
    if (sfd < 0) { return 1; }
    var addr = alloc(110);
    var addrlen = _unix_sockaddr(addr, path);
    var br = syscall(SYS_BIND, sfd, addr, addrlen);
    if (br < 0) { syscall(SYS_CLOSE, sfd); return 1; }
    # 1.9.6 audit L1: restrict perms so only the owning UID can connect.
    # Without this the socket inherits the process umask (typically 0022 →
    # mode 0755) and any local user can dial it.
    syscall(SYS_CHMOD, path, 0x180);   # 0o600 = 384 decimal = 0x180
    var lr = syscall(SYS_LISTEN, sfd, 16);
    if (lr < 0) { syscall(SYS_CLOSE, sfd); return 1; }
    while (1 == 1) {
        var cfd = syscall(SYS_ACCEPT, sfd, 0, 0);
        if (cfd >= 0) {
            _unix_handle_client(cfd, dispatcher);
            syscall(SYS_CLOSE, cfd);
        }
    }
    return 0;
    #endif
}

# --- bridge.cyr ---

# bote::bridge — TypeScript-bridge HTTP transport with CORS + MCP envelope wrap
# Mirrors rust-old/src/bridge.rs.
#
# Reuses transport_http.cyr for socket/parsing/response plumbing. Adds:
#   - POST /            — JSON-RPC dispatch, wraps tools/call results in MCP envelope
#   - OPTIONS /         — CORS preflight (204 + headers)
#   - GET /health       — liveness check ("ok")
#   - CORS headers on every response
#
# An MCP envelope for a tool result looks like:
#   { "content": [{"type":"text","text":"..."}] }
# wrap_tool_result passes through if the value already has a "content" array.

# ================================================================
# BridgeConfig (48 bytes):
#   +0  bind_addr        i64 (network-order IPv4)
#   +8  port             i64
#   +16 allowed_origins  vec of cstrs or 0 (0 / empty / contains "*" → wildcard)
#   +24 dispatcher       Dispatcher ptr (set by transport_bridge_run)
#   +32 bearer_validator fn ptr (token, ctx) → claims | 0, or 0 to disable
#   +40 bearer_ctx       i64 ctx passed verbatim to validator
# ================================================================

fn bridge_config_new(addr, port) {
    var c = alloc(48);
    store64(c, addr);
    store64(c + 8, port);
    store64(c + 16, 0);
    store64(c + 24, 0);
    store64(c + 32, 0);
    store64(c + 40, 0);
    return c;
}

fn bridge_config_with_origins(c, vec)        { store64(c + 16, vec); return c; }
fn bridge_config_with_dispatcher(c, d)       { store64(c + 24, d);   return c; }
fn bridge_config_with_bearer_validator(c, fp, ctx) {
    store64(c + 32, fp);
    store64(c + 40, ctx);
    return c;
}
fn bridge_config_addr(c)             { return load64(c); }
fn bridge_config_port(c)             { return load64(c + 8); }
fn bridge_config_origins(c)          { return load64(c + 16); }
fn bridge_config_dispatcher(c)       { return load64(c + 24); }
fn bridge_config_bearer_validator(c) { return load64(c + 32); }
fn bridge_config_bearer_ctx(c)       { return load64(c + 40); }

# ================================================================
# Envelope wrappers
# ================================================================

# Wrap a raw tool result cstr (raw JSON literal) into the MCP envelope
# unless it already has a top-level `content` array.
#
# Three input shapes, three behaviours:
#   1. Object with a `content` array → pass through verbatim. Used by
#      handlers that pre-shape their own envelope.
#   2. Object with a `type` field (a single MCP content block, possibly
#      carrying annotations) → lift into a 1-element content array.
#      This preserves any block-level annotations the handler attached
#      via `content_with_annotations` (1.9.6); the block is spliced
#      verbatim rather than re-stringified as a `text` payload.
#   3. Anything else (scalar, string, non-block object, array) → wrap
#      the JSON-escaped text under a synthesised `text` block.
fn wrap_tool_result(result) {
    if (result == 0) { result = "null"; }
    if (jsonx_is_object(result) == 1) {
        # (1) Passthrough — has a `content` array.
        if (jsonx_has(result, "content") == 1) {
            var c = jsonx_get_raw(result, "content");
            if (c != 0) {
                var ci = 0;
                var clen = strlen(c);
                while (ci < clen) {
                    var cc = load8(c + ci);
                    if (cc == 32 || cc == 9 || cc == 10 || cc == 13) { ci = ci + 1; }
                    else {
                        if (cc == 91) { return result; }
                        ci = clen;
                    }
                }
            }
        }
        # (2) Single content block — lift into the envelope without
        # decomposing. Preserves annotations (1.9.6 → 2.7.0).
        if (jsonx_has(result, "type") == 1) {
            var sb_lift = str_builder_new();
            str_builder_add_cstr(sb_lift, "{\"content\":[");
            str_builder_add_cstr(sb_lift, result);
            str_builder_add_cstr(sb_lift, "]}");
            return str_data(str_builder_build(sb_lift));
        }
    }
    # (3) Else build a synthesised text-block envelope. The text payload
    # is the raw JSON, JSON-escaped.
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"content\":[{\"type\":\"text\",\"text\":\"");
    _json_emit_escaped(sb, result);
    str_builder_add_cstr(sb, "\"}]}");
    return str_data(str_builder_build(sb));
}

# Wrap an error message into an MCP envelope with isError: true.
fn wrap_error_result(message) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"content\":[{\"type\":\"text\",\"text\":\"");
    if (message != 0) { _json_emit_escaped(sb, message); }
    str_builder_add_cstr(sb, "\"}],\"isError\":true}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# Bridge-aware message processor
# ================================================================
#
# Like codec_process_message, but for tools/call responses:
#   - success: wrap result in MCP envelope (passthrough if already shaped)
#   - error:   convert to success(wrap_error_result(message)) per SY contract
#              (JSON-RPC 2.0 forbids both result+error; SY wants the envelope)
# Other methods (initialize, tools/list, batch elements) pass through unchanged.

fn _bridge_process_single(line, dispatcher, claims) {
    var req = codec_parse_request(line);
    if (req == 0) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "invalid request: malformed object");
        return codec_serialize_response(resp_error("null", 0 - 32600, str_data(str_builder_build(sb))));
    }
    if (streq(req_jsonrpc(req), "2.0") == 0) {
        var sb2 = str_builder_new();
        str_builder_add_cstr(sb2, "unsupported jsonrpc version '");
        str_builder_add_cstr(sb2, req_jsonrpc(req));
        str_builder_add_cstr(sb2, "'");
        var id_v = req_id(req);
        if (id_v == 0) { id_v = "null"; }
        return codec_serialize_response(resp_error(id_v, 0 - 32600, str_data(str_builder_build(sb2))));
    }
    var resp = dispatcher_dispatch(dispatcher, req, claims);
    if (resp == 0) { return 0; }

    # Bridge wrapping only applies to tools/call.
    if (streq(req_method(req), "tools/call") == 1) {
        var success_result = resp_result(resp);
        var err_obj = resp_error_obj(resp);
        if (success_result != 0) {
            var wrapped = wrap_tool_result(success_result);
            return codec_serialize_response(resp_success(resp_id(resp), wrapped));
        }
        if (err_obj != 0) {
            var wrapped_err = wrap_error_result(rpc_err_message(err_obj));
            return codec_serialize_response(resp_success(resp_id(resp), wrapped_err));
        }
    }
    return codec_serialize_response(resp);
}

fn bridge_process_message(input, dispatcher, claims) {
    if (input == 0) { return _cdc_parse_error("empty input"); }
    var len = strlen(input);
    var i = _cdc_skip_ws(input, len, 0);
    if (i >= len) { return _cdc_parse_error("empty input"); }
    var first = load8(input + i);

    # Batch arrays defer to the codec (no per-element wrapping; the bridge
    # contract is single-tool-call → MCP envelope).
    if (first == 91) { return codec_process_message(input, dispatcher, claims); }
    if (first == 123) { return _bridge_process_single(input, dispatcher, claims); }
    return _cdc_invalid_request("expected object or array");
}

# ================================================================
# CORS header builder
# ================================================================
#
# Returns a cstr of CORS headers (each line ending in CRLF) ready to splice
# into _http_send_* via the extra_headers slot. allowed_origins is a vec or 0.

fn _bridge_cors_origin(allowed_origins, request_origin) {
    if (allowed_origins == 0) { return "*"; }
    var n = vec_len(allowed_origins);
    var i = 0;
    while (i < n) {
        if (streq(vec_get(allowed_origins, i), "*") == 1) { return "*"; }
        i = i + 1;
    }
    if (n == 0) { return "*"; }
    if (request_origin != 0) {
        var j = 0;
        while (j < n) {
            if (streq(vec_get(allowed_origins, j), request_origin) == 1) {
                return request_origin;
            }
            j = j + 1;
        }
    }
    # 1.9.6 audit M3: don't echo allowed_origins[0] on miss. That would
    # leak the first allowed origin to any cross-origin requester.
    # `null` is a spec-compliant value — browser will block the response.
    return "null";
}

fn _bridge_cors_headers(allowed_origins, request_origin) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "Access-Control-Allow-Origin: ");
    str_builder_add_cstr(sb, _bridge_cors_origin(allowed_origins, request_origin));
    str_builder_add_cstr(sb, "\r\nAccess-Control-Allow-Methods: POST, GET, OPTIONS\r\n");
    str_builder_add_cstr(sb, "Access-Control-Allow-Headers: content-type\r\n");
    return str_data(str_builder_build(sb));
}

fn _bridge_send_health(cfd, allowed_origins, request_origin) {
    var cors = _bridge_cors_headers(allowed_origins, request_origin);
    sandhi_server_send_response(cfd, HTTP_OK, "OK", "text/plain", "ok", 2, cors);
    return 0;
}

# ================================================================
# Per-connection handler — invoked per connection by sandhi_server_run
# ================================================================
#
# BridgeConfig now carries the dispatcher in the +24 slot (see
# bridge_config_with_dispatcher below). We pass the config as ctx.

fn _bridge_handle(config, cfd, buf, n) {
    var allowed_origins = bridge_config_origins(config);
    var dispatcher      = bridge_config_dispatcher(config);

    var method = sandhi_server_get_method(buf, n);
    var path   = sandhi_server_get_path(buf, n);
    var origin = sandhi_server_find_header(buf, n, "Origin");
    var cors   = _bridge_cors_headers(allowed_origins, origin);

    # OPTIONS preflight
    if (streq(method, "OPTIONS") == 1) {
        sandhi_server_send_204(cfd, cors);
        return 0;
    }
    # GET /health
    if (streq(method, "GET") == 1) {
        if (streq(sandhi_server_path_only(path), "/health") == 1) {
            _bridge_send_health(cfd, allowed_origins, origin);
            return 0;
        }
        sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
        return 0;
    }
    # Anything other than POST is rejected.
    if (streq(method, "POST") == 0) {
        sandhi_server_send_status(cfd, HTTP_METHOD_NOT_ALLOWED, "Method Not Allowed");
        return 0;
    }
    # Only "/" is the bridge endpoint.
    if (streq(sandhi_server_path_only(path), "/") == 0) {
        sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
        return 0;
    }

    # Reject ambiguous Transfer-Encoding (HTTP smuggling guard, RFC 9112)
    if (sandhi_server_find_header(buf, n, "Transfer-Encoding") != 0) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request"); return 0;
    }
    # Bearer auth (no-op when no validator configured)
    var claims_slot[8]; store64(&claims_slot, 0);
    if (auth_bearer_check(cfd, buf, n,
    bridge_config_bearer_validator(config),
    bridge_config_bearer_ctx(config),
    &claims_slot) != 0) { return 0; }

    # 413 cap on oversized declared bodies (audit M1). 60 KB headroom
    # keeps us inside the 64 KB recv buffer with room for headers.
    var declared_clen = sandhi_server_content_length(buf, n);
    if (declared_clen > 61440) {
        sandhi_server_send_status(cfd, HTTP_PAYLOAD_TOO_LARGE, "Payload Too Large"); return 0;
    }

    var body_off = sandhi_server_body_offset(buf, n);
    if (body_off < 0 || body_off > n) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request");
        return 0;
    }
    var clen = sandhi_server_content_length(buf, n);
    if (clen <= 0) { clen = n - body_off; }
    if (clen < 0) { clen = 0; }
    if (clen > n - body_off) { clen = n - body_off; }
    var body = alloc(clen + 1);
    memcpy(body, buf + body_off, clen);
    store8(body + clen, 0);

    var resp = bridge_process_message(body, dispatcher, load64(&claims_slot));
    if (resp == 0) {
        sandhi_server_send_204(cfd, cors);
        return 0;
    }
    sandhi_server_send_response(cfd, HTTP_OK, "OK", "application/json",
    resp, strlen(resp), cors);
    return 0;
}

# ================================================================
# Server entry — defers to stdlib sandhi_server_run
# ================================================================

fn transport_bridge_run(dispatcher, config) {
    bridge_config_with_dispatcher(config, dispatcher);
    return sandhi_server_run(bridge_config_addr(config),
    bridge_config_port(config),
    &_bridge_handle,
    config);
}

# --- transport_streamable.cyr ---

# bote::transport::streamable — Streamable HTTP transport (MCP 2025-11-25)
# Mirrors rust-old/src/transport/streamable.rs.
#
# Single endpoint serves both POST (JSON-RPC) and GET (SSE).
# Built on stdlib lib/http_server.cyr (4.5.0+) chunked primitives.
#
# What's implemented in v1.4.0:
#   - POST <endpoint>  → JSON-RPC dispatch (identical to transport_http)
#   - GET  <endpoint>  → opens SSE stream, emits priming event + retry hint
#                        + replays buffered events if Last-Event-ID is set,
#                        then closes
#   - Origin / MCP-Protocol-Version / MCP-Session-Id middleware (from session.cyr)
#   - EventIdGenerator (monotonic "evt-N" counter)
#   - StreamEvent + ResumptionBuffer (bounded ring of recent events)
#
# What's deferred (waits on streaming dispatch / lib/thread.cyr v1.5+):
#   - Server-initiated push events on the GET stream (the resumption buffer
#     is wired in but stays empty until something publishes to it)
#   - $/cancelRequest mid-stream

# ================================================================
# EventIdGenerator (8 bytes): monotonic counter
# ================================================================

fn event_id_gen_new() {
    var g = alloc(8);
    store64(g, 0);
    return g;
}

# Returns a new alloc'd cstr "evt-N" and bumps the counter.
fn event_id_gen_next(g) {
    var n = load64(g);
    store64(g, n + 1);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "evt-");
    str_builder_add_int(sb, n);
    return str_data(str_builder_build(sb));
}

# ================================================================
# StreamEvent (24 bytes):
#   +0  id    cstr ("evt-N")
#   +8  type  cstr ("message")
#   +16 data  cstr (JSON payload, may be "")
# ================================================================

fn stream_event_new(id, data) {
    var e = alloc(24);
    store64(e, id);
    store64(e + 8, "message");
    store64(e + 16, data);
    return e;
}

# Primer event (empty data, sent on GET connect to confirm the stream).
fn stream_event_primer(id) { return stream_event_new(id, ""); }

fn stream_event_id(e)   { return load64(e); }
fn stream_event_type(e) { return load64(e + 8); }
fn stream_event_data(e) { return load64(e + 16); }

# Render a StreamEvent in SSE wire format:
#   id: <id>\n
#   event: <type>\n
#   data: <data>\n
#   \n
fn stream_event_to_wire(e) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "id: ");
    str_builder_add_cstr(sb, stream_event_id(e));
    str_builder_add_cstr(sb, "\nevent: ");
    str_builder_add_cstr(sb, stream_event_type(e));
    str_builder_add_cstr(sb, "\ndata: ");
    str_builder_add_cstr(sb, stream_event_data(e));
    str_builder_add_cstr(sb, "\n\n");
    return str_data(str_builder_build(sb));
}

# ================================================================
# ResumptionBuffer (24 bytes):
#   +0  events    vec of StreamEvent ptrs (insertion order)
#   +8  max_size  i64
#   +16 unused    reserved
# ================================================================

fn resumption_buffer_new(max_size) {
    var rb = alloc(24);
    store64(rb, vec_new());
    store64(rb + 8, max_size);
    store64(rb + 16, 0);
    return rb;
}

fn resumption_buffer_default() { return resumption_buffer_new(1000); }

fn resumption_buffer_events(rb)   { return load64(rb); }
fn resumption_buffer_max_size(rb) { return load64(rb + 8); }
fn resumption_buffer_len(rb)      { return vec_len(load64(rb)); }

# Push an event. Evicts oldest when over max_size.
fn resumption_buffer_push(rb, event) {
    var events = resumption_buffer_events(rb);
    if (vec_len(events) >= resumption_buffer_max_size(rb)) {
        vec_remove(events, 0);
    }
    vec_push(events, event);
    return 0;
}

# Return a vec of events whose IDs come after `last_event_id`.
# Returns empty vec if last_event_id isn't found (client missed too much),
# or if last_event_id is null/empty (streq on null would segfault;
# empty string never matches a real "evt-N" id).
fn resumption_buffer_events_after(rb, last_event_id) {
    var out = vec_new();
    if (last_event_id == 0) { return out; }
    if (load8(last_event_id) == 0) { return out; }
    var events = resumption_buffer_events(rb);
    var n = vec_len(events);
    var found_at = 0 - 1;
    var i = 0;
    while (i < n) {
        var e = vec_get(events, i);
        if (streq(stream_event_id(e), last_event_id) == 1) {
            found_at = i;
            i = n;
        }
        i = i + 1;
    }
    if (found_at < 0) { return out; }
    var j = found_at + 1;
    while (j < n) {
        vec_push(out, vec_get(events, j));
        j = j + 1;
    }
    return out;
}

# ================================================================
# SessionOutbound (16 bytes) — per-session server→client push state:
#   +0  buffer  ResumptionBuffer ptr (this session's pending notifications)
#   +8  id_gen  EventIdGenerator ptr — PER SESSION on purpose. IDs must never
#               straddle another session's: resumption_buffer_events_after
#               matches an EXACT id and returns empty on a miss, so a shared
#               global generator would let one session's Last-Event-ID land in
#               a gap (an id consumed by a different session) and silently
#               resume nothing. A per-session counter keeps each buffer's ids
#               dense and self-contained.
# ================================================================

fn session_outbound_new() {
    var so = alloc(16);
    store64(so, resumption_buffer_default());
    store64(so + 8, event_id_gen_new());
    return so;
}

fn session_outbound_buffer(so) { return load64(so); }
fn session_outbound_id_gen(so) { return load64(so + 8); }

# Lazily get (or create) the SessionOutbound bundle for an McpSession,
# stashing it in the session's opaque outbound slot (session.cyr keeps that
# slot type-agnostic). Returns the bundle. Wired into the GET drain (a later
# bite); ships unused so the buffer sits empty until a producer feeds it.
fn _strm_session_outbound(session) {
    var so = mcp_session_outbound(session);
    if (so == 0) {
        so = session_outbound_new();
        mcp_session_set_outbound(session, so);
    }
    return so;
}

# ================================================================
# StreamableConfig (80 bytes):
#   +0  endpoint_path     cstr (e.g. "/mcp")
#   +8  bind_addr         i64
#   +16 port              i64
#   +24 allowed_origins   vec of cstrs or 0
#   +32 require_protocol  0/1
#   +40 session_store     SessionStore ptr or 0
#   +48 retry_ms          i64 (SSE retry hint, default 5000)
#   +56 dispatcher        Dispatcher ptr (set by transport_streamable_run)
#   +64 bearer_validator  fn ptr (token, ctx) → claims | 0, or 0 to disable
#   +72 bearer_ctx        i64 ctx passed verbatim to validator
# ================================================================

fn streamable_config_new(path, addr, port) {
    var c = alloc(80);
    store64(c, path);
    store64(c + 8, addr);
    store64(c + 16, port);
    store64(c + 24, 0);
    store64(c + 32, 0);
    store64(c + 40, 0);
    store64(c + 48, 5000);
    store64(c + 56, 0);
    store64(c + 64, 0);
    store64(c + 72, 0);
    return c;
}

fn streamable_config_with_allowed_origins(c, vec) { store64(c + 24, vec); return c; }
fn streamable_config_with_require_protocol(c, r)  { store64(c + 32, r);   return c; }
fn streamable_config_with_session_store(c, st)    { store64(c + 40, st);  return c; }
fn streamable_config_with_retry_ms(c, ms)         { store64(c + 48, ms);  return c; }
fn streamable_config_with_bearer_validator(c, fp, ctx) {
    store64(c + 64, fp);
    store64(c + 72, ctx);
    return c;
}

fn streamable_config_path(c)             { return load64(c); }
fn streamable_config_addr(c)             { return load64(c + 8); }
fn streamable_config_port(c)             { return load64(c + 16); }
fn streamable_config_allowed_origins(c)  { return load64(c + 24); }
fn streamable_config_require_protocol(c) { return load64(c + 32); }
fn streamable_config_session_store(c)    { return load64(c + 40); }
fn streamable_config_retry_ms(c)         { return load64(c + 48); }
fn streamable_config_dispatcher(c)       { return load64(c + 56); }
fn streamable_config_bearer_validator(c) { return load64(c + 64); }
fn streamable_config_bearer_ctx(c)       { return load64(c + 72); }

# ================================================================
# Per-process resumption buffer + event-id generator (one per server)
# ================================================================

var _strm_event_ids = 0;
var _strm_resumption = 0;

fn _strm_init() {
    if (_strm_event_ids == 0)  { _strm_event_ids  = event_id_gen_new(); }
    if (_strm_resumption == 0) { _strm_resumption = resumption_buffer_default(); }
    return 0;
}

# ================================================================
# Middleware (reuses transport_http patterns; same checks)
# ================================================================

fn _strm_check_origin(cfd, buf, blen, config) {
    var allowed = streamable_config_allowed_origins(config);
    if (allowed == 0) { return 0; }
    var origin = sandhi_server_find_header(buf, blen, "Origin");
    var orig = origin;
    if (orig == 0) { orig = ""; }
    if (validate_origin(orig, allowed) != 0) {
        sandhi_server_send_status(cfd, HTTP_FORBIDDEN, "Forbidden");
        return HTTP_FORBIDDEN;
    }
    return 0;
}

# Streamable spec REQUIRES MCP-Protocol-Version on every request.
fn _strm_check_protocol(cfd, buf, blen) {
    var v = sandhi_server_find_header(buf, blen, "MCP-Protocol-Version");
    if (v == 0) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request");
        return HTTP_BAD_REQUEST;
    }
    if (validate_protocol_version(v) != 0) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request");
        return HTTP_BAD_REQUEST;
    }
    return 0;
}

fn _strm_check_session(cfd, buf, blen, config, method) {
    var st = streamable_config_session_store(config);
    if (st == 0) { return 0; }
    var sid = sandhi_server_find_header(buf, blen, "MCP-Session-Id");
    if (sid == 0) {
        if (streq(method, "initialize") == 1) { return 0; }
        sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
        return HTTP_NOT_FOUND;
    }
    if (session_store_validate(st, sid) == 0) {
        sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
        return HTTP_NOT_FOUND;
    }
    return 0;
}

fn _strm_peek_method(body) {
    var m = jsonx_get_str(body, "method");
    if (m == 0) { return ""; }
    return m;
}

# ================================================================
# POST handler — JSON-RPC dispatch (identical shape to transport_http)
# ================================================================

fn _strm_handle_post(cfd, buf, n, config) {
    var claims_slot[8]; store64(&claims_slot, 0);
    if (_strm_check_origin(cfd, buf, n, config) != 0) { return 0; }
    if (sandhi_server_find_header(buf, n, "Transfer-Encoding") != 0) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request"); return 0;
    }
    if (auth_bearer_check(cfd, buf, n,
    streamable_config_bearer_validator(config),
    streamable_config_bearer_ctx(config),
    &claims_slot) != 0) { return 0; }
    if (_strm_check_protocol(cfd, buf, n) != 0) { return 0; }

    var bo = sandhi_server_body_offset(buf, n);
    if (bo < 0 || bo > n) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request");
        return 0;
    }
    var clen = sandhi_server_content_length(buf, n);
    if (clen > 61440) {
        sandhi_server_send_status(cfd, HTTP_PAYLOAD_TOO_LARGE, "Payload Too Large"); return 0;
    }
    if (clen <= 0) { clen = n - bo; }
    if (clen < 0) { clen = 0; }
    if (clen > n - bo) { clen = n - bo; }
    var body = alloc(clen + 1);
    memcpy(body, buf + bo, clen);
    store8(body + clen, 0);

    var rpc_method = _strm_peek_method(body);
    if (_strm_check_session(cfd, buf, n, config, rpc_method) != 0) { return 0; }

    var extra = 0;
    var st = streamable_config_session_store(config);
    if (st != 0 && streq(rpc_method, "initialize") == 1) {
        var pv = jsonx_get_str(jsonx_get_raw(body, "params"), "protocolVersion");
        if (pv == 0) { pv = "2025-11-25"; }
        var sid = session_store_create(st, pv);
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "MCP-Session-Id: ");
        str_builder_add_cstr(sb, sid);
        str_builder_add_cstr(sb, "\r\n");
        extra = str_data(str_builder_build(sb));
    }

    var resp = codec_process_message(body, streamable_config_dispatcher(config), load64(&claims_slot));
    if (resp == 0) {
        sandhi_server_send_204(cfd, extra);
        return 0;
    }
    sandhi_server_send_response(cfd, HTTP_OK, "OK", "application/json",
    resp, strlen(resp), extra);
    return 0;
}

# ================================================================
# GET handler — open SSE stream
# ================================================================

# Send `retry: <ms>\n\n` over the chunked stream. Per SSE spec this hints
# the client at how long to wait before reconnecting.
fn _strm_send_retry(cfd, retry_ms) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "retry: ");
    str_builder_add_int(sb, retry_ms);
    str_builder_add_cstr(sb, "\n\n");
    var s = str_data(str_builder_build(sb));
    sandhi_server_send_chunk(cfd, s, strlen(s));
    return 0;
}

# Select the events to drain for a GET: strictly after a non-empty
# Last-Event-ID cursor, else everything currently buffered (the "deliver on
# next GET" model). Pure — returns a vec of StreamEvent ptrs; the handler
# renders + sends them. Split out so the drain is unit-testable without a
# live socket. An empty Last-Event-ID is treated as absent (drain-all) rather
# than passed to events_after, which would return empty on the empty string.
fn _strm_drain_events(rbuf, last_id) {
    if (last_id != 0 && load8(last_id) != 0) {
        return resumption_buffer_events_after(rbuf, last_id);
    }
    return resumption_buffer_events(rbuf);
}

fn _strm_handle_get(cfd, buf, n, config) {
    if (_strm_check_origin(cfd, buf, n, config) != 0) { return 0; }
    if (sandhi_server_find_header(buf, n, "Transfer-Encoding") != 0) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request"); return 0;
    }
    if (auth_bearer_check(cfd, buf, n,
    streamable_config_bearer_validator(config),
    streamable_config_bearer_ctx(config),
    0) != 0) { return 0; }
    if (_strm_check_protocol(cfd, buf, n) != 0) { return 0; }
    if (_strm_check_session(cfd, buf, n, config, "") != 0) { return 0; }

    # Resolve the drain source: the per-session outbound buffer when a
    # session store is configured and the client presented a valid
    # MCP-Session-Id, else the process-global buffer (back-compat for
    # storeless deployments — that buffer simply stays empty).
    var rbuf = _strm_resumption;
    var st = streamable_config_session_store(config);
    if (st != 0) {
        var sid = sandhi_server_find_header(buf, n, "MCP-Session-Id");
        if (sid != 0) {
            var session = session_store_validate(st, sid);
            if (session != 0) {
                rbuf = session_outbound_buffer(_strm_session_outbound(session));
            }
        }
    }

    # Open the SSE stream.
    sandhi_server_send_chunked_start(cfd, HTTP_OK, "text/event-stream", 0);

    # Primer — an SSE COMMENT (leading ':'), NOT an event. It confirms the
    # stream is up + flushes headers without carrying an `id:`, so per the SSE
    # spec it never becomes the client's Last-Event-ID. A synthetic primer id
    # would be fatal to resumption: it is in no buffer, so the client's next
    # events_after would miss and silently resume nothing.
    var primer = ": bote stream open\n\n";
    sandhi_server_send_chunk(cfd, primer, strlen(primer));

    # Drain buffered notifications (unconditional when there is no cursor).
    var last_id = sandhi_server_find_header(buf, n, "Last-Event-ID");
    var drain = _strm_drain_events(rbuf, last_id);
    var di = 0;
    var dn = vec_len(drain);
    while (di < dn) {
        var ev = vec_get(drain, di);
        var wire = stream_event_to_wire(ev);
        sandhi_server_send_chunk(cfd, wire, strlen(wire));
        di = di + 1;
    }

    # Retry hint + close. Real-time held-open push is a later (threaded)
    # phase; today the stream delivers the buffered drain and closes.
    _strm_send_retry(cfd, streamable_config_retry_ms(config));
    sandhi_server_send_chunked_end(cfd);
    return 0;
}

# ================================================================
# Top-level handler — dispatched by stdlib sandhi_server_run
# ================================================================

fn _strm_handle(config, cfd, buf, n) {
    var method = sandhi_server_get_method(buf, n);
    var path   = sandhi_server_get_path(buf, n);

    # Path must match the configured endpoint (strip query first).
    if (streq(sandhi_server_path_only(path), streamable_config_path(config)) == 0) {
        sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
        return 0;
    }

    if (streq(method, "POST") == 1) { return _strm_handle_post(cfd, buf, n, config); }
    if (streq(method, "GET") == 1)  { return _strm_handle_get(cfd, buf, n, config); }

    sandhi_server_send_status(cfd, HTTP_METHOD_NOT_ALLOWED, "Method Not Allowed");
    return 0;
}

# ================================================================
# Server entry
# ================================================================

fn transport_streamable_run(dispatcher, config) {
    _strm_init();
    store64(config + 56, dispatcher);
    return sandhi_server_run(streamable_config_addr(config),
    streamable_config_port(config),
    &_strm_handle,
    config);
}

# --- transport_ws.cyr ---

# bote::transport::ws — MCP over WebSocket (RFC 6455)
#
# Built on stdlib lib/http_server.cyr (HTTP routing, 4.5.0+) and
# lib/ws_server.cyr (WS upgrade + frame I/O, 4.5.1+).
#
# ws_server is pulled out of [deps] stdlib auto-inject so other test
# files don't carry its weight — include it here directly. 2.7.2.
#
# COMPAT SHIM (cyrius 6.3.x): lib/ws_server.cyr still calls the pre-6.x
# name `http_find_header`, but the stdlib's http_* header helpers were
# renamed to sandhi_server_* and ws_server.cyr was missed in the sweep,
# so the symbol dangles undefined. sandhi_server_find_header has the
# identical (buf, blen, name) → allocated-cstr-or-0 contract, so forward
# to it. Must precede the ws_server include (cyrius is single-pass).
# Upstream fix needed: stdlib lib/ws_server.cyr should call
# sandhi_server_find_header directly (cyrius bug — the http_*→sandhi_*
# rename missed it). Remove this shim once that lands.
fn http_find_header(buf, blen, name): i64 {
    return sandhi_server_find_header(buf, blen, name);
}
include "lib/ws_server.cyr"

# Wire format: each WebSocket TEXT frame is one JSON-RPC 2.0 message.
# Control frames (ping/pong/close) are handled transparently by
# ws_server_recv; this file is just the MCP-specific wire-up.
#
# Middleware (origin / protocol-version) runs on the HTTP upgrade request
# — same checks as transport_http. Session binding is deferred until
# streaming dispatch lands (v1.6+); the WS socket itself is the session.

# ================================================================
# WsConfig (64 bytes):
#   +0  endpoint_path     cstr (e.g. "/mcp")
#   +8  bind_addr         i64 (network-order IPv4)
#   +16 port              i64
#   +24 allowed_origins   vec of cstrs or 0
#   +32 require_protocol  0/1
#   +40 dispatcher        Dispatcher ptr (set by transport_ws_run)
#   +48 bearer_validator  fn ptr (token, ctx) → claims | 0, or 0 to disable
#   +56 bearer_ctx        i64 ctx passed verbatim to validator
#
# Bearer auth applies on the upgrade HTTP request only, not per-frame —
# WS has a single Upgrade and the connection's identity is fixed at
# that point.
# ================================================================

fn ws_config_new(path, addr, port) {
    var c = alloc(64);
    store64(c, path);
    store64(c + 8, addr);
    store64(c + 16, port);
    store64(c + 24, 0);
    store64(c + 32, 0);
    store64(c + 40, 0);
    store64(c + 48, 0);
    store64(c + 56, 0);
    return c;
}

fn ws_config_with_allowed_origins(c, vec) { store64(c + 24, vec); return c; }
fn ws_config_with_require_protocol(c, r)  { store64(c + 32, r);   return c; }
fn ws_config_with_bearer_validator(c, fp, ctx) {
    store64(c + 48, fp);
    store64(c + 56, ctx);
    return c;
}

fn ws_config_path(c)             { return load64(c); }
fn ws_config_addr(c)             { return load64(c + 8); }
fn ws_config_port(c)             { return load64(c + 16); }
fn ws_config_allowed_origins(c)  { return load64(c + 24); }
fn ws_config_require_protocol(c) { return load64(c + 32); }
fn ws_config_dispatcher(c)       { return load64(c + 40); }
fn ws_config_bearer_validator(c) { return load64(c + 48); }
fn ws_config_bearer_ctx(c)       { return load64(c + 56); }

# ================================================================
# Middleware — same shape as transport_http, run pre-upgrade
# ================================================================

fn _ws_check_origin(cfd, buf, blen, config) {
    var allowed = ws_config_allowed_origins(config);
    if (allowed == 0) { return 0; }
    var origin = sandhi_server_find_header(buf, blen, "Origin");
    var orig = origin;
    if (orig == 0) { orig = ""; }
    if (validate_origin(orig, allowed) != 0) {
        sandhi_server_send_status(cfd, HTTP_FORBIDDEN, "Forbidden");
        return HTTP_FORBIDDEN;
    }
    return 0;
}

fn _ws_check_protocol(cfd, buf, blen, config) {
    var v = sandhi_server_find_header(buf, blen, "MCP-Protocol-Version");
    if (v == 0) {
        if (ws_config_require_protocol(config) == 1) {
            sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request");
            return HTTP_BAD_REQUEST;
        }
        return 0;
    }
    if (validate_protocol_version(v) != 0) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request");
        return HTTP_BAD_REQUEST;
    }
    return 0;
}

# ================================================================
# Upgrade handler — invoked per connection by sandhi_server_run
# ================================================================

fn _bote_ws_handler(config, cfd, buf, n) {
    var method = sandhi_server_get_method(buf, n);
    var path   = sandhi_server_get_path(buf, n);

    # Only GET on the configured endpoint is valid for a WS upgrade.
    if (streq(method, "GET") == 0) {
        sandhi_server_send_status(cfd, HTTP_METHOD_NOT_ALLOWED, "Method Not Allowed");
        return 0;
    }
    if (streq(sandhi_server_path_only(path), ws_config_path(config)) == 0) {
        sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
        return 0;
    }

    if (_ws_check_origin(cfd, buf, n, config) != 0) { return 0; }
    if (sandhi_server_find_header(buf, n, "Transfer-Encoding") != 0) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request"); return 0;
    }
    var claims_slot[8]; store64(&claims_slot, 0);
    if (auth_bearer_check(cfd, buf, n,
    ws_config_bearer_validator(config),
    ws_config_bearer_ctx(config),
    &claims_slot) != 0) { return 0; }
    if (_ws_check_protocol(cfd, buf, n, config) != 0) { return 0; }

    var ws = ws_server_handshake(cfd, buf, n);
    if (ws == 0) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request");
        return 0;
    }
    var ws_claims = load64(&claims_slot);

    # Each frame is one JSON-RPC message. Loop until peer closes or the
    # socket errors out (ws_server_recv returns 0).
    while (1 == 1) {
        var msg = ws_server_recv(ws);
        if (msg == 0) { return 0; }
        var resp = codec_process_message(msg, ws_config_dispatcher(config), ws_claims);
        if (resp != 0) {
            ws_server_send_text(ws, resp);
        }
    }
    return 0;
}

# ================================================================
# Server entry — defers to stdlib sandhi_server_run
# ================================================================

fn transport_ws_run(dispatcher, config) {
    store64(config + 40, dispatcher);
    return sandhi_server_run(ws_config_addr(config),
    ws_config_port(config),
    &_bote_ws_handler,
    config);
}

# --- content.cyr ---

# bote::content — typed MCP content blocks (spec 2025-11-25).
#
# A tool handler that wants to return anything richer than a plain text
# result builds one or more blocks with the constructors below, collects
# them into a vec, and returns `content_array(blocks)` or
# `content_array_error(blocks)`. `src/bridge.cyr`'s `wrap_tool_result`
# is already a pass-through when a result has a top-level `content`
# array, so handlers can opt into blocks without any transport changes.
#
# Five block types per MCP:
#   text           {"type":"text","text":"..."}
#   image          {"type":"image","data":"<b64>","mimeType":"..."}
#   audio          {"type":"audio","data":"<b64>","mimeType":"..."}
#   resource       {"type":"resource","resource":{"uri":"...","mimeType":"...","text":"..."}}
#                  (embedded — the resource's text body travels in the envelope)
#   resource_link  {"type":"resource_link","uri":"...","name":"...","mimeType":"..."}
#                  (reference — the client fetches by URI)
#
# Convention: every constructor returns an alloc'd cstr. Every string
# argument is a cstr; `_json_emit_escaped` handles JSON quoting at the
# boundary (dispatched from src/dispatch.cyr). mimeType strings are
# passed through unchecked — the handler is responsible for RFC 6838
# compliance.

# ================================================================
# Text block
# ================================================================

fn content_text(text) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"type\":\"text\",\"text\":\"");
    if (text != 0) { _json_emit_escaped(sb, text); }
    str_builder_add_cstr(sb, "\"}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# Binary blocks (image, audio) — both take base64-encoded data +
# a mimeType. The constructors are structurally identical; factored
# through a private helper to keep the two spec variants obvious.
# ================================================================

fn _content_binary(kind, b64_data, mime) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"type\":\"");
    str_builder_add_cstr(sb, kind);
    str_builder_add_cstr(sb, "\",\"data\":\"");
    if (b64_data != 0) { _json_emit_escaped(sb, b64_data); }
    str_builder_add_cstr(sb, "\",\"mimeType\":\"");
    if (mime != 0) { _json_emit_escaped(sb, mime); }
    str_builder_add_cstr(sb, "\"}");
    return str_data(str_builder_build(sb));
}

fn content_image(b64_data, mime) { return _content_binary("image", b64_data, mime); }
fn content_audio(b64_data, mime) { return _content_binary("audio", b64_data, mime); }

# ================================================================
# Resource block — embedded resource contents travel in the envelope.
# Any of text / mime / uri may be 0 (omitted from the emitted object).
# Per MCP spec, `uri` is required and `text` is required for text
# resources; handlers should supply both. Binary resources use a
# different shape (blob) — add a constructor variant when needed.
# ================================================================

fn content_resource(uri, mime, text) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"type\":\"resource\",\"resource\":{\"uri\":\"");
    if (uri != 0) { _json_emit_escaped(sb, uri); }
    str_builder_add_cstr(sb, "\"");
    if (mime != 0) {
        str_builder_add_cstr(sb, ",\"mimeType\":\"");
        _json_emit_escaped(sb, mime);
        str_builder_add_cstr(sb, "\"");
    }
    if (text != 0) {
        str_builder_add_cstr(sb, ",\"text\":\"");
        _json_emit_escaped(sb, text);
        str_builder_add_cstr(sb, "\"");
    }
    str_builder_add_cstr(sb, "}}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# Resource link — reference only; client fetches the URI itself.
# ================================================================

fn content_resource_link(uri, name, mime) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"type\":\"resource_link\",\"uri\":\"");
    if (uri != 0) { _json_emit_escaped(sb, uri); }
    str_builder_add_cstr(sb, "\"");
    if (name != 0) {
        str_builder_add_cstr(sb, ",\"name\":\"");
        _json_emit_escaped(sb, name);
        str_builder_add_cstr(sb, "\"");
    }
    if (mime != 0) {
        str_builder_add_cstr(sb, ",\"mimeType\":\"");
        _json_emit_escaped(sb, mime);
        str_builder_add_cstr(sb, "\"");
    }
    str_builder_add_cstr(sb, "}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# Envelopes — collect blocks into a tool-result response.
# Each block in `blocks` is an already-built cstr (one of the
# constructors above, or any caller-supplied object).
# ================================================================

fn _content_blocks_array(sb, blocks) {
    str_builder_add_cstr(sb, "[");
    var n = vec_len(blocks);
    var i = 0;
    while (i < n) {
        if (i > 0) { str_builder_add_cstr(sb, ","); }
        str_builder_add_cstr(sb, vec_get(blocks, i));
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]");
    return 0;
}

# {"content":[...]}
fn content_array(blocks) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"content\":");
    _content_blocks_array(sb, blocks);
    str_builder_add_cstr(sb, "}");
    return str_data(str_builder_build(sb));
}

# {"content":[...],"isError":true} — marks a failed tool execution that
# still wants to return content (MCP spec: errors may carry explanation
# content, distinguished from protocol errors by the isError flag).
fn content_array_error(blocks) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"content\":");
    _content_blocks_array(sb, blocks);
    str_builder_add_cstr(sb, ",\"isError\":true}");
    return str_data(str_builder_build(sb));
}

# Single-block shorthand: wrap one already-built block cstr.
fn content_single(block) {
    var v = vec_new();
    vec_push(v, block);
    return content_array(v);
}

# Convenience: a plain text response (equivalent to
# content_single(content_text(s)), saves a vec alloc for the common case).
fn content_text_response(text) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"content\":[{\"type\":\"text\",\"text\":\"");
    if (text != 0) { _json_emit_escaped(sb, text); }
    str_builder_add_cstr(sb, "\"}]}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# Binary resource (blob) variant of content_resource. The MCP spec
# distinguishes text resources (carry a `text` field) from binary
# resources (carry a `blob` field with base64-encoded data). Use this
# constructor when the resource body isn't UTF-8.
# ================================================================

fn content_resource_blob(uri, mime, b64_data) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"type\":\"resource\",\"resource\":{\"uri\":\"");
    if (uri != 0) { _json_emit_escaped(sb, uri); }
    str_builder_add_cstr(sb, "\"");
    if (mime != 0) {
        str_builder_add_cstr(sb, ",\"mimeType\":\"");
        _json_emit_escaped(sb, mime);
        str_builder_add_cstr(sb, "\"");
    }
    if (b64_data != 0) {
        str_builder_add_cstr(sb, ",\"blob\":\"");
        _json_emit_escaped(sb, b64_data);
        str_builder_add_cstr(sb, "\"");
    }
    str_builder_add_cstr(sb, "}}");
    return str_data(str_builder_build(sb));
}

# Annotations (MCP spec optional metadata): take a pre-built block cstr
# and splice an `annotations` field in before the closing `}`. Either
# arg may be null/empty/-1; if both are absent the input is returned
# unchanged. Caller responsible for valid block input (any of the
# constructors above produces well-formed JSON).
fn content_with_annotations(block, audience, priority) {
    if (block == 0) { return block; }
    var has_a = 0;
    if (audience != 0) { if (vec_len(audience) > 0) { has_a = 1; } }
    var has_p = 0;
    if (priority >= 0) { has_p = 1; }
    if (has_a == 0 && has_p == 0) { return block; }
    var bn = strlen(block);
    if (bn < 2) { return block; }
    if (load8(block + bn - 1) != 125) { return block; }   # '}'
    var sb = str_builder_new();
    # copy block minus trailing '}' as a single buffer
    var pre = alloc(bn);
    memcpy(pre, block, bn - 1);
    store8(pre + bn - 1, 0);
    str_builder_add_cstr(sb, pre);
    str_builder_add_cstr(sb, ",\"annotations\":{");
    if (has_a == 1) {
        str_builder_add_cstr(sb, "\"audience\":[");
        var an = vec_len(audience);
        var ai = 0;
        while (ai < an) {
            if (ai > 0) { str_builder_add_cstr(sb, ","); }
            str_builder_add_cstr(sb, "\"");
            _json_emit_escaped(sb, vec_get(audience, ai));
            str_builder_add_cstr(sb, "\"");
            ai = ai + 1;
        }
        str_builder_add_cstr(sb, "]");
    }
    if (has_p == 1) {
        if (has_a == 1) { str_builder_add_cstr(sb, ","); }
        str_builder_add_cstr(sb, "\"priority\":");
        str_builder_add_int(sb, priority);
    }
    str_builder_add_cstr(sb, "}}");
    return str_data(str_builder_build(sb));
}

# --- host.cyr ---

# bote::host — HostRegistry + SSRF guard.
#
# Second slice of the roadmap `host` module (content blocks landed in
# 1.7.0). Registry holds named external hosts bote is allowed to route
# requests to (e.g. for `resource_link` fetches or tool-to-tool proxy);
# SSRF guard rejects URLs targeting loopback / link-local / private /
# cloud-metadata endpoints before any network call.
#
# Wire shapes:
#
#   HostEntry (32 bytes):
#     +0  name          cstr   logical identifier
#     +8  url           cstr   base URL (http:// or https://)
#     +16 headers       vec of cstrs (alternating key/value) or 0
#     +24 capabilities  vec of cstrs (e.g. "fetch", "tools/call") or 0
#
#   HostRegistry (16 bytes):
#     +0  entries       hashmap: name cstr → HostEntry ptr
#     +8  count         i64 (cached vec_len of map_keys — O(1) lookup)

# ================================================================
# HostEntry
# ================================================================

fn host_entry_new(name, url) {
    var e = alloc(32);
    store64(e, name);
    store64(e + 8, url);
    store64(e + 16, 0);
    store64(e + 24, 0);
    return e;
}

fn host_entry_with_headers(e, headers) { store64(e + 16, headers); return e; }
fn host_entry_with_capabilities(e, caps) { store64(e + 24, caps); return e; }

fn host_entry_name(e)         { return load64(e); }
fn host_entry_url(e)          { return load64(e + 8); }
fn host_entry_headers(e)      { return load64(e + 16); }
fn host_entry_capabilities(e) { return load64(e + 24); }

# Capability check: returns 1 if caps is null (no restriction) or if
# `cap` is present in the vec; 0 if the vec exists and doesn't contain it.
fn host_entry_allows(e, cap) {
    var caps = host_entry_capabilities(e);
    if (caps == 0) { return 1; }
    var n = vec_len(caps);
    var i = 0;
    while (i < n) {
        if (streq(vec_get(caps, i), cap) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# HostRegistry
# ================================================================

fn host_registry_new() {
    var r = alloc(16);
    store64(r, map_new());
    store64(r + 8, 0);
    return r;
}

fn host_registry_entries(r) { return load64(r); }
fn host_registry_count(r)   { return load64(r + 8); }

# Insert / replace. Bumps count only on fresh insert (replacement
# keeps the count stable so callers can trust it as a O(1) size hint).
fn host_registry_add(r, entry) {
    var name = host_entry_name(entry);
    var m = host_registry_entries(r);
    if (map_has(m, name) == 0) {
        store64(r + 8, host_registry_count(r) + 1);
    }
    map_set(m, name, entry);
    return 0;
}

fn host_registry_has(r, name) { return map_has(host_registry_entries(r), name); }
fn host_registry_get(r, name) { return map_get(host_registry_entries(r), name); }

fn host_registry_names(r) { return map_keys(host_registry_entries(r)); }

# Empty the registry in-place. Existing references to the registry
# pointer stay valid; the underlying entries map is replaced fresh
# (the old map becomes unreferenced and is left to the bump allocator
# — bote has no general-purpose free, and config reload is a rare
# operation; the leak is bounded by reload frequency × config size).
# Used by host_registry_reload before repopulating.
fn host_registry_clear(r) {
    store64(r, map_new());
    store64(r + 8, 0);
    return 0;
}

# ================================================================
# Hot-reload — JSON config format
# ================================================================
#
# 2.7.1. The wire format is a JSON array of host-entry objects:
#
#   [
#     {"name":"upstream-1","url":"https://api.example.com"},
#     {"name":"upstream-2","url":"https://other.example.com",
#      "capabilities":["fetch","tools/call"]}
#   ]
#
# Required fields: `name`, `url`. Optional: `capabilities` (array of
# cstrs; absent = no restriction, matching the in-memory semantics).
# `headers` parsing is deferred — header values may carry secrets
# and need a careful redaction/audit story before they can come
# through file config. Use the in-memory `host_entry_with_headers`
# setter for now if headers are needed.
#
# Limitations: the jsonx surface used to parse is whitespace-strict
# inside structured values (matches the rest of bote's JSON
# handling). Configs emitted by `jq -c` or a one-key-per-line
# pretty-printer both work; arbitrary indentation may not.

# Buffer size for `host_registry_load_from_file`. 64 KB is well
# above any plausible host-registry config (each entry is < 500 B
# typical). Files larger than this are truncated at read time and
# the parse will fail at the truncation boundary.
var HOST_CONFIG_BUF_MAX = 65536;

# Parse a single host-entry JSON object (cstr containing `{...}`)
# into a HostEntry. Returns 0 if the object is missing `name` or
# `url`, or if `capabilities` is present but malformed.
fn host_entry_from_json(obj_cstr) {
    if (obj_cstr == 0) { return 0; }
    if (jsonx_is_object(obj_cstr) == 0) { return 0; }
    var name = jsonx_get_str(obj_cstr, "name");
    var url  = jsonx_get_str(obj_cstr, "url");
    if (name == 0 || url == 0) { return 0; }
    var e = host_entry_new(name, url);
    if (jsonx_has(obj_cstr, "capabilities") == 1) {
        var caps_raw = jsonx_get_raw(obj_cstr, "capabilities");
        if (caps_raw == 0) { return 0; }
        var caps = _host_parse_str_array(caps_raw);
        if (caps == 0) { return 0; }
        host_entry_with_capabilities(e, caps);
    }
    return e;
}

# Walk a JSON array of strings and return a vec of cstrs. Each
# element is decoded into its own freshly-allocated cstr (no
# quotes). Returns 0 if the input is not an array or any element
# is not a string. Used by host_entry_from_json.
fn _host_parse_str_array(arr_cstr) {
    if (arr_cstr == 0) { return 0; }
    var len = strlen(arr_cstr);
    var i = _jx_skip_ws(arr_cstr, len, 0);
    if (i >= len || load8(arr_cstr + i) != 91) { return 0; }
    i = _jx_skip_ws(arr_cstr, len, i + 1);
    var out = vec_new();
    while (i < len) {
        var c = load8(arr_cstr + i);
        if (c == 93) { return out; }
        if (c != 34) { return 0; }
        var end = _jx_skip_string(arr_cstr, len, i);
        var inner = end - i - 2;
        if (inner < 0) { inner = 0; }
        var s = alloc(inner + 1);
        memcpy(s, arr_cstr + i + 1, inner);
        store8(s + inner, 0);
        vec_push(out, s);
        i = _jx_skip_ws(arr_cstr, len, end);
        if (i < len && load8(arr_cstr + i) == 44) {
            i = _jx_skip_ws(arr_cstr, len, i + 1);
        }
    }
    return 0;
}

# Parse a JSON array of host-entry objects into a fresh
# HostRegistry. Returns 0 on any parse failure.
fn host_registry_load_json(json_cstr) {
    if (json_cstr == 0) { return 0; }
    var len = strlen(json_cstr);
    var i = _jx_skip_ws(json_cstr, len, 0);
    if (i >= len || load8(json_cstr + i) != 91) { return 0; }
    i = _jx_skip_ws(json_cstr, len, i + 1);
    var r = host_registry_new();
    while (i < len) {
        var c = load8(json_cstr + i);
        if (c == 93) { return r; }
        if (c != 123) { return 0; }
        var end = _jx_skip_struct(json_cstr, len, i, 123, 125);
        if (end > len) { return 0; }
        var olen = end - i;
        var obj = alloc(olen + 1);
        memcpy(obj, json_cstr + i, olen);
        store8(obj + olen, 0);
        var entry = host_entry_from_json(obj);
        if (entry == 0) { return 0; }
        host_registry_add(r, entry);
        i = _jx_skip_ws(json_cstr, len, end);
        if (i < len && load8(json_cstr + i) == 44) {
            i = _jx_skip_ws(json_cstr, len, i + 1);
        }
    }
    return 0;
}

# Read path into memory and parse via host_registry_load_json.
# Returns 0 on open / read / parse failure. Buffer size is
# HOST_CONFIG_BUF_MAX (64 KB).
fn host_registry_load_from_file(path) {
    if (path == 0) { return 0; }
    var buf = alloc(HOST_CONFIG_BUF_MAX + 1);
    var n = file_read_all(path, buf, HOST_CONFIG_BUF_MAX);
    if (n <= 0) { return 0; }
    store8(buf + n, 0);
    return host_registry_load_json(buf);
}

# Reload an existing registry from a config file. On success the
# registry pointer stays valid; only the underlying entries map
# is swapped. Returns 0 on success, -1 on failure. The caller's
# registry is left unchanged on failure (fail-safe).
fn host_registry_reload(r, path) {
    if (r == 0 || path == 0) { return 0 - 1; }
    var fresh = host_registry_load_from_file(path);
    if (fresh == 0) { return 0 - 1; }
    store64(r,     host_registry_entries(fresh));
    store64(r + 8, host_registry_count(fresh));
    return 0;
}

# ================================================================
# SSRF guard
# ================================================================
#
# Return codes (ssrf_ok = pass, anything else = blocked with reason).
# Callers should treat a non-zero return as "do not make this request"
# and surface the code so audit logs can distinguish a block reason.

var SSRF_OK         = 0;
var SSRF_PARSE      = 1;
var SSRF_SCHEME     = 2;
var SSRF_LOOPBACK   = 3;
var SSRF_LINK_LOCAL = 4;
var SSRF_PRIVATE    = 5;
var SSRF_METADATA   = 6;
var SSRF_UNSPEC     = 7;
var SSRF_MULTICAST  = 8;

# Return 1 if cstr `s` starts with `prefix`, else 0.
fn _ssrf_starts_with(s, prefix) {
    if (s == 0 || prefix == 0) { return 0; }
    var i = 0;
    while (1 == 1) {
        var p = load8(prefix + i);
        if (p == 0) { return 1; }
        if (load8(s + i) != p) { return 0; }
        i = i + 1;
    }
    return 0;
}

# ASCII-lowercase a cstr into a fresh alloc. Caller owns the result.
fn _ssrf_lower(s) {
    var n = strlen(s);
    var out = alloc(n + 1);
    var i = 0;
    while (i < n) {
        var c = load8(s + i);
        if (c >= 65 && c <= 90) { c = c + 32; }
        store8(out + i, c);
        i = i + 1;
    }
    store8(out + n, 0);
    return out;
}

# Parse a CANONICAL base-10 octet out of cstr `s[pos..end]`. Canonical
# means: 1–3 digits, no leading zero on multi-digit octets, value 0-255.
# Rejecting leading zeros closes the 1.9.5 audit's octal-IPv4 bypass —
# `0177` would otherwise parse as decimal 177 here while glibc inet_aton
# treats it as octal 127 and connects to loopback. Hex (`0x7f`) is
# already rejected because it contains non-`[0-9]` bytes.
fn _ssrf_parse_octet(s, pos, end, out_val) {
    if (pos >= end) { return 0 - 1; }
    var v = 0;
    var p = pos;
    var digits = 0;
    while (p < end) {
        var c = load8(s + p);
        if (c < 48 || c > 57) { p = end; }
        else {
            v = v * 10 + (c - 48);
            digits = digits + 1;
            p = p + 1;
        }
    }
    if (digits == 0 || digits > 3 || v > 255) { return 0 - 1; }
    # Reject leading-zero multi-digit forms: "0", "10", "127" all OK,
    # "00", "01", "010", "0177" all rejected (non-canonical / octal).
    if (digits > 1 && load8(s + pos) == 48) { return 0 - 1; }
    store64(out_val, v);
    return pos + digits;
}

# Classify a dotted-decimal IPv4 host substring s[start..end]. Returns
# an SSRF_* code: SSRF_OK if the address is public, otherwise the
# reason category. Returns SSRF_PARSE if not a valid IPv4 literal
# (caller should fall back to hostname classification).
fn _ssrf_classify_ipv4(s, start, end) {
    var a_slot[8]; var b_slot[8]; var c_slot[8]; var d_slot[8];
    store64(&a_slot, 0); store64(&b_slot, 0);
    store64(&c_slot, 0); store64(&d_slot, 0);

    # Walk four octets separated by dots
    var p = start;
    # Find three dots first to chop s into four ranges
    var dot1 = 0 - 1; var dot2 = 0 - 1; var dot3 = 0 - 1;
    var k = start;
    while (k < end) {
        var c = load8(s + k);
        if (c == 46) {
            if (dot1 < 0) { dot1 = k; }
            elif (dot2 < 0) { dot2 = k; }
            elif (dot3 < 0) { dot3 = k; }
            else { return SSRF_PARSE; }
        }
        k = k + 1;
    }
    if (dot3 < 0) { return SSRF_PARSE; }

    # Each octet parse must consume EXACTLY the bytes between dots —
    # `64:ff9b::1.2.3.4` would otherwise parse as `64.2.3.4` (the
    # parser stops at ':' and returns 64) and bypass the IPv6 path.
    # 1.9.5 audit C3 fix.
    var ra = _ssrf_parse_octet(s, start, dot1, &a_slot);
    if (ra != dot1) { return SSRF_PARSE; }
    var rb = _ssrf_parse_octet(s, dot1 + 1, dot2, &b_slot);
    if (rb != dot2) { return SSRF_PARSE; }
    var rc = _ssrf_parse_octet(s, dot2 + 1, dot3, &c_slot);
    if (rc != dot3) { return SSRF_PARSE; }
    var rd = _ssrf_parse_octet(s, dot3 + 1, end, &d_slot);
    if (rd != end) { return SSRF_PARSE; }

    var a = load64(&a_slot);
    var b = load64(&b_slot);

    # 0.0.0.0/8 — unspecified / "any interface"
    if (a == 0) { return SSRF_UNSPEC; }
    # 127.0.0.0/8 — loopback
    if (a == 127) { return SSRF_LOOPBACK; }
    # 169.254.0.0/16 — link-local (covers AWS/GCP/Azure metadata at 169.254.169.254)
    if (a == 169 && b == 254) { return SSRF_METADATA; }
    # 10.0.0.0/8 — RFC 1918 private
    if (a == 10) { return SSRF_PRIVATE; }
    # 172.16.0.0/12
    if (a == 172 && b >= 16 && b <= 31) { return SSRF_PRIVATE; }
    # 192.168.0.0/16
    if (a == 192 && b == 168) { return SSRF_PRIVATE; }
    # 224.0.0.0/4 — multicast
    if (a >= 224 && a <= 239) { return SSRF_MULTICAST; }
    return SSRF_OK;
}

# Classify a hostname (non-IP string). Conservative blocklist.
#
# Also rejects all-`[0-9]` hostnames as SSRF_PARSE: `2130706433` is the
# integer form of 127.0.0.1 — glibc's inet_aton accepts it, our IPv4
# parser rejects it (no dots), and a naked-digit hostname is never
# valid per RFC 952/1123. This closes the 1.9.5 audit's integer-IPv4
# bypass (audit C1).
fn _ssrf_classify_hostname(h) {
    if (streq(h, "localhost") == 1) { return SSRF_LOOPBACK; }
    if (streq(h, "metadata.google.internal") == 1) { return SSRF_METADATA; }
    if (streq(h, "metadata") == 1) { return SSRF_METADATA; }
    # All-digit hostname → reject. Also any short-form IPv4 (1, 2, or 3
    # dots with all-digit segments) we might've missed elsewhere.
    var hlen = strlen(h);
    if (hlen > 0) {
        var all_digits_or_dots = 1;
        var has_digit = 0;
        var i = 0;
        while (i < hlen) {
            var c = load8(h + i);
            if (c >= 48 && c <= 57) { has_digit = 1; }
            elif (c != 46) { all_digits_or_dots = 0; i = hlen; }
            i = i + 1;
        }
        if (all_digits_or_dots == 1 && has_digit == 1) { return SSRF_PARSE; }
    }
    return SSRF_OK;
}

# Classify an IPv6 literal (without surrounding brackets). Conservative
# prefix-match — covers the cases real production traffic would use:
#   ::1                  loopback
#   ::                   unspec
#   ::ffff:a.b.c.d       IPv4-mapped (1.9.5 audit C3 bypass) — reject
#                        outright; v4-classifier doesn't see this form
#                        because the host extractor pulls IPv6 brackets
#                        as a whole. Conservatively block all `::ffff:`
#                        and `::` prefixes ahead of a v4-shaped tail.
#   ::*.*.*.* (v4-compat) likewise rejected
#   64:ff9b::a.b.c.d     NAT64 (well-known prefix) — reject
#   fe80::/10            link-local (high 10 bits = 1111 1110 10)
#   fc00::/7             ULA private (high 7 bits = 1111 110)
#   ff00::/8             multicast
# A full 16-byte IPv6 parser would extract the embedded v4 octets and
# re-run `_ssrf_classify_ipv4` on them; for now we just refuse the
# whole class — every consumer-facing host should be a hostname.
fn _ssrf_classify_ipv6(h, hlen) {
    if (hlen < 2) { return SSRF_PARSE; }

    # ::1 loopback (exact)
    if (hlen == 3 && load8(h) == 58 && load8(h + 1) == 58 && load8(h + 2) == 49) {
        return SSRF_LOOPBACK;
    }
    # :: unspec (exact)
    if (hlen == 2 && load8(h) == 58 && load8(h + 1) == 58) { return SSRF_UNSPEC; }

    # ::ffff:* — IPv4-mapped. Block as PRIVATE (worst case is loopback;
    # a permissive bypass would let `::ffff:127.0.0.1` slip through).
    if (hlen >= 7
    && load8(h) == 58 && load8(h + 1) == 58
    && load8(h + 2) == 102 && load8(h + 3) == 102
    && load8(h + 4) == 102 && load8(h + 5) == 102
    && load8(h + 6) == 58) {
        return SSRF_PRIVATE;
    }

    # `::` followed by a digit and a `.` somewhere → IPv4-compatible /
    # mixed v6+v4 form. Reject conservatively.
    if (hlen >= 4 && load8(h) == 58 && load8(h + 1) == 58) {
        var has_dot = 0;
        var i2 = 2;
        while (i2 < hlen) {
            if (load8(h + i2) == 46) { has_dot = 1; i2 = hlen; }
            i2 = i2 + 1;
        }
        if (has_dot == 1) { return SSRF_PRIVATE; }
    }

    # 64:ff9b: — NAT64 well-known prefix (RFC 6052). Match byte-by-byte;
    # nested ifs because cyrius's chained && through 8 terms is fragile.
    if (hlen >= 8) {
        if (load8(h) == 54) {
            if (load8(h + 1) == 52) {
                if (load8(h + 2) == 58) {
                    if (load8(h + 3) == 102) {
                        if (load8(h + 4) == 102) {
                            if (load8(h + 5) == 57) {
                                if (load8(h + 6) == 98) {
                                    if (load8(h + 7) == 58) {
                                        return SSRF_PRIVATE;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    # fe80::/10 link-local
    if (hlen >= 5
    && load8(h) == 102 && load8(h + 1) == 101
    && load8(h + 2) == 56 && load8(h + 3) == 48
    && load8(h + 4) == 58) {
        return SSRF_LINK_LOCAL;
    }

    # fc00::/7 ULA private (fc or fd)
    if (hlen >= 2
    && load8(h) == 102
    && (load8(h + 1) == 99 || load8(h + 1) == 100)) {
        return SSRF_PRIVATE;
    }

    # ff00::/8 multicast
    if (hlen >= 2 && load8(h) == 102 && load8(h + 1) == 102) {
        return SSRF_MULTICAST;
    }

    return SSRF_OK;
}

# Extract the host component of a URL. Writes pointers to host start /
# end into *out_start, *out_end. Returns SSRF_OK on parse success,
# SSRF_PARSE on malformed input, SSRF_SCHEME if scheme isn't http/https.
fn _ssrf_extract_host(url, out_start, out_end) {
    if (url == 0) { return SSRF_PARSE; }
    var lower = _ssrf_lower(url);

    # Scheme gate — only http:// and https:// are valid for SSRF context
    var scheme_end = 0;
    if (_ssrf_starts_with(lower, "http://") == 1) { scheme_end = 7; }
    elif (_ssrf_starts_with(lower, "https://") == 1) { scheme_end = 8; }
    else { return SSRF_SCHEME; }

    # Skip optional userinfo (user:pass@)
    var n = strlen(lower);
    var host_start = scheme_end;
    var at = 0 - 1;
    var i = scheme_end;
    while (i < n) {
        var c = load8(lower + i);
        if (c == 64) { at = i; i = n; }
        elif (c == 47) { i = n; }   # path start — no @ in authority
        else { i = i + 1; }
    }
    if (at >= 0) { host_start = at + 1; }

    # IPv6 literal? URL form is `http://[::1]:8080/...`
    if (host_start < n && load8(lower + host_start) == 91) {
        var bracket_end = host_start + 1;
        while (bracket_end < n && load8(lower + bracket_end) != 93) {
            bracket_end = bracket_end + 1;
        }
        if (bracket_end >= n) { return SSRF_PARSE; }
        # Inside brackets — exclude the [ and ]
        store64(out_start, lower + host_start + 1);
        store64(out_end,   lower + bracket_end);
        return SSRF_OK;
    }

    # Hostname / IPv4 — host ends at first ':' (port), '/' (path),
    # '?' (query), '#' (fragment), or end of string.
    var host_end = n;
    var j = host_start;
    while (j < host_end) {
        var c = load8(lower + j);
        if (c == 58 || c == 47 || c == 63 || c == 35) { host_end = j; }
        else { j = j + 1; }
    }
    if (host_end <= host_start) { return SSRF_PARSE; }

    store64(out_start, lower + host_start);
    store64(out_end,   lower + host_end);
    return SSRF_OK;
}

# Public entry: given a URL cstr, return 0 (safe) or an SSRF_* code.
fn ssrf_check(url) {
    var start_slot[8]; var end_slot[8];
    store64(&start_slot, 0); store64(&end_slot, 0);
    var parse = _ssrf_extract_host(url, &start_slot, &end_slot);
    if (parse != SSRF_OK) { return parse; }

    var host_ptr = load64(&start_slot);
    var host_end_ptr = load64(&end_slot);
    var host_len = host_end_ptr - host_ptr;

    # Copy out the host as its own NUL-terminated cstr so we can feed
    # it to streq against the string blocklist.
    var host = alloc(host_len + 1);
    memcpy(host, host_ptr, host_len);
    store8(host + host_len, 0);

    # Try IPv4 literal first. _ssrf_classify_ipv4 operates on offsets
    # into the original lowered buffer; re-use our extracted copy.
    var v4 = _ssrf_classify_ipv4(host, 0, host_len);
    if (v4 != SSRF_PARSE) { return v4; }

    # IPv6 literal? Detected by presence of any ':' in the host bytes
    # (legal hostnames don't contain ':' once port is stripped, and
    # _ssrf_extract_host already pulled the host out of any [...] brackets).
    var has_colon = 0;
    var ci = 0;
    while (ci < host_len) {
        if (load8(host + ci) == 58) { has_colon = 1; ci = host_len; }
        ci = ci + 1;
    }
    if (has_colon == 1) { return _ssrf_classify_ipv6(host, host_len); }

    # Fall back to hostname blocklist (conservative; does NOT resolve DNS).
    return _ssrf_classify_hostname(host);
}

# Convenience: 1 if the URL is safe to fetch, 0 otherwise.
fn ssrf_is_safe(url) {
    if (ssrf_check(url) == SSRF_OK) { return 1; }
    return 0;
}

# --- libro_tools.cyr ---

# bote::libro_tools — five built-in MCP tools over a libro audit chain.
#
# Tools (all prefixed `libro_` so they're one namespace for clients):
#
#   libro_query      search / filter / paginate chain entries
#   libro_verify     verify chain integrity (hash-link + self-hash)
#   libro_export     return the chain as a JSON array (in-memory)
#   libro_proof      Merkle inclusion proof for one entry by index
#   libro_retention  apply a retention policy, return archive summary
#
# Wiring: bote calls `libro_tools_init(chain)` once, then
# `libro_tools_register(dispatcher)`. The chain pointer is stashed in a
# module-level var (handlers have a single-arg signature in cyrius, no
# closures — this is the standard workaround).
#
# All libro boundaries expect Str (fat string {data, len}); MCP args
# arrive as cstr. Every cross-boundary pass wraps with str_from() — the
# same pattern that fixed the v1.2.1 audit_libro cstr/Str heisenbug.
#
# 2.6.2 port: libro 2.x dropped the public `entry_action` /
# `entry_severity` / `entry_hash` / `entry_source` / `entry_agent_id` /
# `entry_timestamp` accessors, the `chain_entries` getter, the
# `error_code` / `error_index` / `error_msg` getters, the
# `merkle_tree_leaf_count` accessor, and renamed `merkle_proof` to
# `merkle_inclusion_proof`. All of those are now field reads on
# struct-typed handles. We re-introduce the thin accessor names
# below as module-local `_lt_*` helpers so the handler bodies stay
# readable — matches the entry struct layout at lib/libro.cyr:200
# (raw offsets are documented inline).

# ================================================================
# Module state: the chain we're wrapping, set once at init
# ================================================================

var _libro_tools_chain = 0;

fn libro_tools_init(chain) {
    _libro_tools_chain = chain;
    return 0;
}

# ================================================================
# libro 2.x struct-field accessors (used to be public; raw offsets
# now). Layout reference: lib/libro.cyr:200 (entry), :28 (error),
# :1079 (chain), :2046 (merkle_tree).
# ================================================================

# struct entry — +0 uuid_hi, +8 uuid_lo, +16 timestamp, +24 severity,
# +32 source(Str), +40 action(Str), +48 details(Str),
# +56 agent_id(Str|0), +64 prev_hash(Str), +72 hash(Str),
# +80 hash_algorithm.
fn _lt_entry_timestamp(e) { return load64(e + 16); }
fn _lt_entry_severity(e)  { return load64(e + 24); }
fn _lt_entry_source(e)    { return load64(e + 32); }
fn _lt_entry_action(e)    { return load64(e + 40); }
fn _lt_entry_agent_id(e)  { return load64(e + 56); }
fn _lt_entry_hash(e)      { return load64(e + 72); }

# struct chain — +0 entries(vec), +8 prev_hash(Str), +16 max_capacity,
# +24 overflow(vec).
fn _lt_chain_entries(c)   { return load64(c); }

# struct error — +0 code, +8 msg(cstr), +16 field_name, +24 index,
# +32 expected, +40 actual.
fn _lt_err_code(err)      { return load64(err);      }
fn _lt_err_msg(err)       { return load64(err + 8);  }
fn _lt_err_index(err)     { return load64(err + 24); }

# struct merkle_tree — +0 nodes(vec), +8 leaf_count.
fn _lt_merkle_leaf_count(t) { return load64(t + 8); }

# ================================================================
# Small helpers
# ================================================================

# Parse a JSON number field out of args_cstr. Returns 0 if absent.
# (Bote-wide pattern: 0 is "absent"; handlers treat 0 as default.)
fn _lt_get_int(args, key) {
    var raw = jsonx_get_raw(args, key);
    if (raw == 0) { return 0; }
    # raw is a cstr like "42"; wrap + parse
    return str_to_int(str_from(raw));
}

# Build {"ok":false,"error":"<msg>"} for handler failure paths.
fn _lt_error(msg) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"ok\":false,\"error\":\"");
    _json_emit_escaped(sb, msg);
    str_builder_add_cstr(sb, "\"}");
    return str_data(str_builder_build(sb));
}

# Emit one entry as a JSON object into sb.
fn _lt_emit_entry(sb, e) {
    str_builder_add_cstr(sb, "{\"timestamp\":");
    str_builder_add_int(sb, _lt_entry_timestamp(e));
    str_builder_add_cstr(sb, ",\"severity\":");
    str_builder_add_int(sb, _lt_entry_severity(e));
    str_builder_add_cstr(sb, ",\"source\":\"");
    _json_emit_escaped(sb, str_data(_lt_entry_source(e)));
    str_builder_add_cstr(sb, "\",\"action\":\"");
    _json_emit_escaped(sb, str_data(_lt_entry_action(e)));
    str_builder_add_cstr(sb, "\",\"agent_id\":\"");
    var aid = _lt_entry_agent_id(e);
    if (aid != 0) { _json_emit_escaped(sb, str_data(aid)); }
    str_builder_add_cstr(sb, "\",\"hash\":\"");
    _json_emit_escaped(sb, str_data(_lt_entry_hash(e)));
    str_builder_add_cstr(sb, "\"}");
    return 0;
}

# Emit a vec of entries as a JSON array into sb.
fn _lt_emit_entries_array(sb, entries) {
    str_builder_add_cstr(sb, "[");
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        if (i > 0) { str_builder_add_cstr(sb, ","); }
        _lt_emit_entry(sb, vec_get(entries, i));
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]");
    return 0;
}

# ================================================================
# libro_query — search / filter / paginate
#
# args: {source?, agent_id?, action?, severity?, min_severity?,
#        after?, before?, offset?, limit?}
# result: {"ok":true,"entries":[{...}]}
# ================================================================

fn libro_tool_query(args, claims) {
    if (_libro_tools_chain == 0) { return _lt_error("libro not configured"); }

    var q = query_new();
    var src = jsonx_get_str(args, "source");
    if (src != 0) { query_source(q, str_from(src)); }
    var aid = jsonx_get_str(args, "agent_id");
    if (aid != 0) { query_agent_id(q, str_from(aid)); }
    var act = jsonx_get_str(args, "action");
    if (act != 0) { query_action(q, str_from(act)); }

    if (jsonx_has(args, "severity") == 1) {
        query_severity(q, _lt_get_int(args, "severity"));
    }
    if (jsonx_has(args, "min_severity") == 1) {
        query_min_severity(q, _lt_get_int(args, "min_severity"));
    }
    if (jsonx_has(args, "after") == 1) {
        query_after(q, _lt_get_int(args, "after"));
    }
    if (jsonx_has(args, "before") == 1) {
        query_before(q, _lt_get_int(args, "before"));
    }

    var matched = query_apply(q, _lt_chain_entries(_libro_tools_chain));

    # Pagination: offset + limit slice the matched vec.
    var offset = _lt_get_int(args, "offset");
    var limit = _lt_get_int(args, "limit");
    var page = vec_new();
    var total = vec_len(matched);
    var start = offset;
    if (start < 0) { start = 0; }
    var end = total;
    if (limit > 0 && start + limit < end) { end = start + limit; }
    var i = start;
    while (i < end) {
        vec_push(page, vec_get(matched, i));
        i = i + 1;
    }

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"ok\":true,\"total\":");
    str_builder_add_int(sb, total);
    str_builder_add_cstr(sb, ",\"entries\":");
    _lt_emit_entries_array(sb, page);
    str_builder_add_cstr(sb, "}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# libro_verify — hash-link integrity check
#
# args: {} (no params)
# result: {"ok":true} | {"ok":false,"code":N,"message":"..."}
# ================================================================

fn libro_tool_verify(args, claims) {
    if (_libro_tools_chain == 0) { return _lt_error("libro not configured"); }
    var err = chain_verify(_libro_tools_chain);
    if (err == 0) { return "{\"ok\":true}"; }

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"ok\":false,\"code\":");
    str_builder_add_int(sb, _lt_err_code(err));
    str_builder_add_cstr(sb, ",\"index\":");
    str_builder_add_int(sb, _lt_err_index(err));
    str_builder_add_cstr(sb, ",\"message\":\"");
    var m = _lt_err_msg(err);
    if (m != 0) { _json_emit_escaped(sb, m); }
    str_builder_add_cstr(sb, "\"}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# libro_export — return the chain as a JSON array of entries
#
# args: {} (no params)
# result: {"ok":true,"count":N,"entries":[...]}
# ================================================================

fn libro_tool_export(args, claims) {
    if (_libro_tools_chain == 0) { return _lt_error("libro not configured"); }
    var entries = _lt_chain_entries(_libro_tools_chain);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"ok\":true,\"count\":");
    str_builder_add_int(sb, vec_len(entries));
    str_builder_add_cstr(sb, ",\"entries\":");
    _lt_emit_entries_array(sb, entries);
    str_builder_add_cstr(sb, "}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# libro_proof — Merkle inclusion proof for entry at index
#
# args: {"index": N}
# result: {"ok":true,"root":"<hex>","leaf_count":N,"index":N} |
#         {"ok":false,"error":"..."}
#
# Note: the path hashes are omitted here to keep the response compact;
# the verifier can reconstruct the tree from libro_export and validate.
# A richer "path" field can be added in a follow-up release once the
# wire format is pinned.
# ================================================================

fn libro_tool_proof(args, claims) {
    if (_libro_tools_chain == 0) { return _lt_error("libro not configured"); }
    if (jsonx_has(args, "index") == 0) { return _lt_error("missing 'index'"); }
    var idx = _lt_get_int(args, "index");

    var entries = _lt_chain_entries(_libro_tools_chain);
    if (idx < 0 || idx >= vec_len(entries)) { return _lt_error("index out of range"); }

    var tree = merkle_build(entries);
    if (tree == 0) { return _lt_error("empty chain"); }
    var proof = merkle_inclusion_proof(tree, idx);
    if (proof == 0) { return _lt_error("proof unavailable"); }

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"ok\":true,\"index\":");
    str_builder_add_int(sb, idx);
    str_builder_add_cstr(sb, ",\"leaf_count\":");
    str_builder_add_int(sb, _lt_merkle_leaf_count(tree));
    str_builder_add_cstr(sb, ",\"root\":\"");
    var root = merkle_tree_root(tree);
    if (root != 0) { _json_emit_escaped(sb, str_data(root)); }
    str_builder_add_cstr(sb, "\"}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# libro_retention — apply a retention policy, return archive summary
#
# args: {"policy": "keep_count"|"keep_duration"|"keep_after"|
#                  "pci_dss"|"hipaa"|"sox",
#        "value": N (required for keep_count/keep_duration/keep_after)}
# result: {"ok":true,"archived":N,"retained":M} |
#         {"ok":false,"error":"..."}
# ================================================================

fn libro_tool_retention(args, claims) {
    if (_libro_tools_chain == 0) { return _lt_error("libro not configured"); }
    var policy_name = jsonx_get_str(args, "policy");
    if (policy_name == 0) { return _lt_error("missing 'policy'"); }

    var policy = 0;
    if (streq(policy_name, "keep_count") == 1) {
        policy = retention_keep_count(_lt_get_int(args, "value"));
    } elif (streq(policy_name, "keep_duration") == 1) {
        policy = retention_keep_duration(_lt_get_int(args, "value"));
    } elif (streq(policy_name, "keep_after") == 1) {
        policy = retention_keep_after(_lt_get_int(args, "value"));
    } elif (streq(policy_name, "pci_dss") == 1) {
        policy = retention_pci_dss();
    } elif (streq(policy_name, "hipaa") == 1) {
        policy = retention_hipaa();
    } elif (streq(policy_name, "sox") == 1) {
        policy = retention_sox();
    } else {
        return _lt_error("unknown policy");
    }

    var before = vec_len(_lt_chain_entries(_libro_tools_chain));
    chain_apply_retention(_libro_tools_chain, policy);
    var after = vec_len(_lt_chain_entries(_libro_tools_chain));
    var archived = before - after;
    if (archived < 0) { archived = 0; }

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"ok\":true,\"archived\":");
    str_builder_add_int(sb, archived);
    str_builder_add_cstr(sb, ",\"retained\":");
    str_builder_add_int(sb, after);
    str_builder_add_cstr(sb, "}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# Registration: add all 5 tools to the dispatcher + registry
# ================================================================

fn libro_tools_register(dispatcher) {
    var reg = dispatcher_registry(dispatcher);
    var empty = vec_new();
    var obj_schema = schema_new("object", 0, empty);

    registry_register(reg, tool_def_new(
    "libro_query", "Search the libro audit chain (filter by source/agent/severity/time + paginate)",
    obj_schema));
    dispatcher_handle(dispatcher, "libro_query", &libro_tool_query);

    registry_register(reg, tool_def_new(
    "libro_verify", "Verify the libro chain's hash-link integrity",
    obj_schema));
    dispatcher_handle(dispatcher, "libro_verify", &libro_tool_verify);

    registry_register(reg, tool_def_new(
    "libro_export", "Return every entry on the libro chain as a JSON array",
    obj_schema));
    dispatcher_handle(dispatcher, "libro_export", &libro_tool_export);

    registry_register(reg, tool_def_new(
    "libro_proof", "Generate a Merkle inclusion proof for the entry at the given index",
    obj_schema));
    dispatcher_handle(dispatcher, "libro_proof", &libro_tool_proof);

    registry_register(reg, tool_def_new(
    "libro_retention", "Apply a retention policy to the libro chain, archive old entries",
    obj_schema));
    dispatcher_handle(dispatcher, "libro_retention", &libro_tool_retention);
    return 0;
}

# --- fs_tools.cyr ---

# fs_tools — filesystem MCP tools for the bote binary
# (fs_write / fs_read / fs_mkdir).
#
# Additive: registered on an existing dispatcher by fs_tools_register(),
# called from src/main.cyr after bote_dispatcher_with_echo(). Mirrors the
# libro_tools_register() idiom.
#
# Results are MCP content blocks ({"content":[{"type":"text",...}],"isError":..})
# so an MCP client (thoth) renders them directly.
#
# SECURITY: writes/reads/mkdirs are confined to a root (env BOTE_FS_ROOT,
# default "."). A relative arg-path containing a ".." segment or a leading "/"
# is REFUSED — defense-in-depth beneath t-ron's per-tool authorization. This
# is a demo tool; the root confinement is a floor, not a full sandbox.

var FS_READ_CAP = 65536;    # max bytes fs_read returns

# ---- root + path safety ---------------------------------------------------

fn _fs_root() {
    var r = getenv("BOTE_FS_ROOT");
    if (r == 0) { return "."; }
    if (load8(r) == 0) { return "."; }
    return r;
}

# 1 if the relative path is unsafe (empty / absolute / contains "..").
fn _fs_path_unsafe(rel) {
    if (rel == 0) { return 1; }
    if (load8(rel) == 0) { return 1; }      # empty
    if (load8(rel) == 47) { return 1; }     # leading '/'  -> absolute
    var n = strlen(rel);
    var i = 0;
    while ((i + 1) < n) {
        if ((load8(rel + i) == 46) && (load8(rel + i + 1) == 46)) { return 1; }  # ".."
        i = i + 1;
    }
    return 0;
}

# Join root + "/" + rel into a fresh NUL-terminated cstr.
fn _fs_join(rel) {
    var root = _fs_root();
    var rl = strlen(root);
    var pl = strlen(rel);
    var out = alloc(rl + 1 + pl + 1);
    memcpy(out, root, rl);
    store8(out + rl, 47);                    # '/'
    memcpy(out + rl + 1, rel, pl);
    store8(out + rl + 1 + pl, 0);
    return out;
}

# mkdir every directory prefix of `full`. When include_last is 1, `full`
# itself is created too (fs_mkdir); otherwise only the parents (fs_write).
# Temporarily NUL-splits `full` in place (restored each step). Errors from
# an already-existing dir are ignored; only a later open/write failure is
# surfaced. i starts at 1 so a root '/' is never mkdir'd.
fn _fs_mkparents(full, include_last) {
    var n = strlen(full);
    var i = 1;
    while (i < n) {
        if (load8(full + i) == 47) {         # '/'
            store8(full + i, 0);
            sys_mkdir(full, 0x1ED);          # 0755; ignore EEXIST
            store8(full + i, 47);
        }
        i = i + 1;
    }
    if (include_last == 1) {
        sys_mkdir(full, 0x1ED);
    }
    return 0;
}

# ---- JSON string unescape -------------------------------------------------
# jsonx_get_str returns the RAW inner bytes (no unescaping), so a
# "content":"a\nb" arrives as the literal bytes a \ n b. Decode the JSON
# string escapes here. Writes the decoded length to *len_out and returns a
# fresh NUL-terminated buffer (decoded length <= input length + UTF-8 for \u).

fn _fs_hexval(c) {
    if ((c >= 48) && (c <= 57))  { return c - 48; }        # 0-9
    if ((c >= 97) && (c <= 102)) { return (c - 97) + 10; }  # a-f
    if ((c >= 65) && (c <= 70))  { return (c - 65) + 10; }  # A-F
    return 0 - 1;
}

fn _fs_unescape(src, len_out) {
    var n = strlen(src);
    var out = alloc(n + 1);                  # decoded is never longer than src
    var i = 0;
    var o = 0;
    while (i < n) {
        var c = load8(src + i);
        if ((c == 92) && ((i + 1) < n)) {    # backslash
            var d = load8(src + i + 1);
            if (d == 110)      { store8(out + o, 10); o = o + 1; i = i + 2; }   # \n
            elif (d == 116)    { store8(out + o, 9);  o = o + 1; i = i + 2; }   # \t
            elif (d == 114)    { store8(out + o, 13); o = o + 1; i = i + 2; }   # \r
            elif (d == 34)     { store8(out + o, 34); o = o + 1; i = i + 2; }   # \"
            elif (d == 92)     { store8(out + o, 92); o = o + 1; i = i + 2; }   # \\
            elif (d == 47)     { store8(out + o, 47); o = o + 1; i = i + 2; }   # \/
            elif (d == 98)     { store8(out + o, 8);  o = o + 1; i = i + 2; }   # \b
            elif (d == 102)    { store8(out + o, 12); o = o + 1; i = i + 2; }   # \f
            elif ((d == 117) && ((i + 5) < n)) {                                # \uXXXX
                var h1 = _fs_hexval(load8(src + i + 2));
                var h2 = _fs_hexval(load8(src + i + 3));
                var h3 = _fs_hexval(load8(src + i + 4));
                var h4 = _fs_hexval(load8(src + i + 5));
                if ((h1 < 0) || (h2 < 0) || (h3 < 0) || (h4 < 0)) {
                    store8(out + o, d); o = o + 1; i = i + 2;    # malformed -> keep 'u'
                } else {
                    var cp = ((h1 * 4096) + (h2 * 256)) + ((h3 * 16) + h4);
                    if (cp < 128) {
                        store8(out + o, cp); o = o + 1;
                    } elif (cp < 2048) {
                        store8(out + o, 192 + (cp / 64)); o = o + 1;
                        store8(out + o, 128 + (cp - ((cp / 64) * 64))); o = o + 1;
                    } else {
                        var hi = cp / 4096;
                        var mid = (cp / 64) - (hi * 64);
                        var lo = cp - ((cp / 64) * 64);
                        store8(out + o, 224 + hi); o = o + 1;
                        store8(out + o, 128 + mid); o = o + 1;
                        store8(out + o, 128 + lo); o = o + 1;
                    }
                    i = i + 6;
                }
            }
            else { store8(out + o, d); o = o + 1; i = i + 2; }  # unknown escape -> keep char
        } else {
            store8(out + o, c); o = o + 1; i = i + 1;
        }
    }
    store8(out + o, 0);
    store64(len_out, o);
    return out;
}

# ---- result builders ------------------------------------------------------

fn _fs_result(msg, is_err) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"content\":[{\"type\":\"text\",\"text\":\"");
    _json_emit_escaped(sb, msg);
    str_builder_add_cstr(sb, "\"}],\"isError\":");
    if (is_err == 1) { str_builder_add_cstr(sb, "true}"); }
    else { str_builder_add_cstr(sb, "false}"); }
    return str_data(str_builder_build(sb));
}

fn _fs_ok(msg)  { return _fs_result(msg, 0); }
fn _fs_err(msg) { return _fs_result(msg, 1); }

# ---- handlers -------------------------------------------------------------

# fs_write {path, content} -> writes content to <root>/<path> (parents mkdir'd).
fn fs_write_handler(args, claims) {
    var path = jsonx_get_str(args, "path");
    if (_fs_path_unsafe(path) == 1) {
        return _fs_err("fs_write: refused unsafe path (must be relative, no '..')");
    }
    var raw = jsonx_get_str(args, "content");
    if (raw == 0) { raw = ""; }
    var lslot[8];
    store64(&lslot, 0);
    var data = _fs_unescape(raw, &lslot);
    var dlen = load64(&lslot);

    var full = _fs_join(path);
    _fs_mkparents(full, 0);
    var wrote = file_write_all(full, data, dlen);
    if (wrote < 0) {
        var sbe = str_builder_new();
        str_builder_add_cstr(sbe, "fs_write: failed to write ");
        str_builder_add_cstr(sbe, full);
        return _fs_err(str_data(str_builder_build(sbe)));
    }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "wrote ");
    str_builder_add_int(sb, wrote);
    str_builder_add_cstr(sb, " bytes to ");
    str_builder_add_cstr(sb, full);
    return _fs_ok(str_data(str_builder_build(sb)));
}

# fs_read {path} -> returns the (capped) file contents as a text block.
fn fs_read_handler(args, claims) {
    var path = jsonx_get_str(args, "path");
    if (_fs_path_unsafe(path) == 1) {
        return _fs_err("fs_read: refused unsafe path (must be relative, no '..')");
    }
    var full = _fs_join(path);
    var buf = alloc(FS_READ_CAP + 1);
    var got = file_read_all(full, buf, FS_READ_CAP);
    if (got < 0) {
        var sbe = str_builder_new();
        str_builder_add_cstr(sbe, "fs_read: cannot read ");
        str_builder_add_cstr(sbe, full);
        return _fs_err(str_data(str_builder_build(sbe)));
    }
    store8(buf + got, 0);
    # NOTE: _json_emit_escaped stops at NUL, so an embedded NUL truncates the
    # rendered text — acceptable for text/source files (the demo's use).
    return _fs_ok(buf);
}

# fs_mkdir {path} -> creates <root>/<path> (and any missing parents).
fn fs_mkdir_handler(args, claims) {
    var path = jsonx_get_str(args, "path");
    if (_fs_path_unsafe(path) == 1) {
        return _fs_err("fs_mkdir: refused unsafe path (must be relative, no '..')");
    }
    var full = _fs_join(path);
    _fs_mkparents(full, 1);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "created directory ");
    str_builder_add_cstr(sb, full);
    return _fs_ok(str_data(str_builder_build(sb)));
}

# ---- registration ---------------------------------------------------------

# Register fs_write / fs_read / fs_mkdir on an existing dispatcher.
# Call after bote_dispatcher_with_echo() (see src/main.cyr).
fn fs_tools_register(dispatcher) {
    var reg = dispatcher_registry(dispatcher);

    registry_register(reg, tool_def_new(
        "fs_write", "write a UTF-8 text file (parents created) under the server root; args {path, content}",
        schema_new("object", 0, vec_new())));
    dispatcher_handle(dispatcher, "fs_write", &fs_write_handler);

    registry_register(reg, tool_def_new(
        "fs_read", "read a text file under the server root; args {path}",
        schema_new("object", 0, vec_new())));
    dispatcher_handle(dispatcher, "fs_read", &fs_read_handler);

    registry_register(reg, tool_def_new(
        "fs_mkdir", "create a directory (and parents) under the server root; args {path}",
        schema_new("object", 0, vec_new())));
    dispatcher_handle(dispatcher, "fs_mkdir", &fs_mkdir_handler);

    return 0;
}
