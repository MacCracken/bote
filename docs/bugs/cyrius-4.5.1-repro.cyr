# Minimal repro for cyrius 4.5.1 identifier-buffer cap (64 KB).
#
# Build: cyrius test docs/bugs/cyrius-4.5.1-repro.cyr
#
# Expected (clean diagnostic, good):
#   error: identifier buffer full (65530/65536 bytes) — reduce included
#   modules or split into separate unit
#
# The diagnostic itself is helpful. The bug is that the cap is reached
# far too easily in real projects (see notes in cyrius-4.5.1-identifier-
# buffer-cap.md) — a single mid-size project that includes ~15 stdlib
# modules + ~15 vendored deps + its own ~15 sources hits the ceiling
# before the module count is unusual.
#
# When overflow lands *inside* an include directive rather than at a
# top-level fn def, the cascading error is misleading:
#
#   error:lib/assert.cyr:3: expected '=', got string
#
# (Line 3 of assert.cyr is itself an `include "lib/string.cyr"` —
# the parser has lost track of what `include` means.)

include "lib/string.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

fn some_long_function_name_number_1(x) { return x + 1; }
