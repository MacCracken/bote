# bote::dispatch — JSON-RPC tool dispatcher
# Mirrors rust-old/src/dispatch.rs (sync path; streaming/audit/events deferred)
#
# Requires (entry point includes):
#   string, fmt, alloc, vec, str, hashmap, fnptr,
#   src/error.cyr, src/protocol.cyr, src/registry.cyr, src/jsonx.cyr

# ================================================================
# Supported MCP protocol versions
# ================================================================

fn _mcp_is_supported(v) {
    if (v == 0) { return 0; }
    if (streq(v, "2024-11-05") == 1) { return 1; }
    if (streq(v, "2025-03-26") == 1) { return 1; }
    if (streq(v, "2025-11-25") == 1) { return 1; }
    return 0;
}

fn _mcp_latest_version() { return "2025-11-25"; }

fn _bote_server_version() { return "2.9.0"; }

# ================================================================
# Tool name validation (project_tool convention)
# ================================================================
#
# Returns 0 if valid, BoteError ptr otherwise.

fn _is_alnum_or_under(c) {
    if (c >= 48 && c <= 57) { return 1; }
    if (c >= 65 && c <= 90) { return 1; }
    if (c >= 97 && c <= 122) { return 1; }
    if (c == 95) { return 1; }
    return 0;
}

fn validate_tool_name(name) {
    if (name == 0) {
        return bote_err_new(ERR_INVALID_PARAMS, "", "tool name must be 1-256 characters");
    }
    var n = strlen(name);
    if (n == 0 || n > 256) {
        return bote_err_new(ERR_INVALID_PARAMS, "", "tool name must be 1-256 characters");
    }
    var i = 0;
    var has_under = 0;
    while (i < n) {
        var c = load8(name + i);
        if (_is_alnum_or_under(c) == 0) {
            return bote_err_new(ERR_INVALID_PARAMS, name, "tool name must be alphanumeric + underscore");
        }
        if (c == 95) { has_under = 1; }
        i = i + 1;
    }
    if (has_under == 0) {
        return bote_err_new(ERR_INVALID_PARAMS, name,
        "tool name must contain at least one underscore (project_tool format)");
    }
    return 0;
}

# ================================================================
# Dispatcher struct (48 bytes):
#   +0  registry            ptr
#   +8  handlers            hashmap: name_cstr -> fn ptr (sync handler)
#   +16 streaming_handlers  hashmap: name_cstr -> fn ptr (reserved for v1.3)
#   +24 audit_sink          AuditSink ptr or 0 (no-op when 0)
#   +32 event_sink          EventSink ptr or 0 (no-op when 0)
#   +40 prompt_registry     PromptRegistry ptr or 0 (prompts capability off
#                           when 0; created lazily by dispatcher_register_prompt)
#   +48 resource_registry   ResourceRegistry ptr or 0 (resources capability off
#                           when 0; created lazily by dispatcher_register_resource)
#   +56 completion_handler  fn ptr or 0 (completions capability off when 0;
#                           set via dispatcher_set_completion)
# ================================================================

fn dispatcher_new(reg) {
    var d = alloc(64);
    store64(d, reg);
    store64(d + 8, map_new());
    store64(d + 16, map_new());
    store64(d + 24, 0);
    store64(d + 32, 0);
    store64(d + 40, 0);
    store64(d + 48, 0);
    store64(d + 56, 0);
    return d;
}

fn dispatcher_registry(d)   { return load64(d); }
fn dispatcher_handlers(d)   { return load64(d + 8); }
fn dispatcher_streaming(d)  { return load64(d + 16); }
fn dispatcher_audit_sink(d) { return load64(d + 24); }
fn dispatcher_event_sink(d) { return load64(d + 32); }
fn dispatcher_prompts(d)    { return load64(d + 40); }
fn dispatcher_resources(d)  { return load64(d + 48); }
fn dispatcher_completion(d) { return load64(d + 56); }

fn dispatcher_set_audit(d, sink) { store64(d + 24, sink); return d; }
fn dispatcher_set_events(d, sink) { store64(d + 32, sink); return d; }
fn dispatcher_set_prompts(d, preg) { store64(d + 40, preg); return d; }
fn dispatcher_set_resources(d, rreg) { store64(d + 48, rreg); return d; }

# Set the completion handler. ABI: fn h(params_cstr, claims) → result_cstr,
# where params is the completion/complete params ({ref, argument, ...}) and
# the result is the full {"completion":{"values":[...]}} body. Setting it
# flips the `completions` capability on at initialize.
fn dispatcher_set_completion(d, handler_fp) { store64(d + 56, handler_fp); return d; }

# Register a sync tool handler. **2.0 ABI**: handler signature is
#   fn h(args_cstr, claims) → result_cstr (claims always 0 today)
fn dispatcher_handle(d, name, handler_fp) {
    map_set(dispatcher_handlers(d), name, handler_fp);
    return 0;
}

# Register a streaming tool handler (placeholder — dispatch_streaming not yet ported).
fn dispatcher_handle_streaming(d, name, handler_fp) {
    map_set(dispatcher_streaming(d), name, handler_fp);
    return 0;
}

fn dispatcher_is_streaming_tool(d, name) {
    return map_has(dispatcher_streaming(d), name);
}

# Build {"tool_name":"<name>"} for a register/dereg/deprecate event payload.
fn _emit_tool_name_payload(name) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"tool_name\":\"");
    _json_emit_escaped(sb, name);
    str_builder_add_cstr(sb, "\"}");
    return str_data(str_builder_build(sb));
}

# Dynamic registration: validates the tool name, registers in registry,
# inserts handler. Returns 0 on success, BoteError ptr on failure.
# Emits TOPIC_TOOL_REGISTERED on success.
fn dispatcher_register_tool(d, tool_def, handler_fp) {
    var name = tool_def_name(tool_def);
    var verr = validate_tool_name(name);
    if (verr != 0) { return verr; }
    registry_register(dispatcher_registry(d), tool_def);
    map_set(dispatcher_handlers(d), name, handler_fp);
    event_sink_publish(dispatcher_event_sink(d), TOPIC_TOOL_REGISTERED(),
    _emit_tool_name_payload(name));
    return 0;
}

# Returns 0 on success, BoteError ptr on failure (tool not found).
# Emits TOPIC_TOOL_DEREGISTERED on success.
fn dispatcher_deregister_tool(d, name) {
    var removed = registry_deregister(dispatcher_registry(d), name);
    map_delete(dispatcher_handlers(d), name);
    map_delete(dispatcher_streaming(d), name);
    if (removed == 0) {
        return bote_err_new(ERR_TOOL_NOT_FOUND, name, 0);
    }
    event_sink_publish(dispatcher_event_sink(d), TOPIC_TOOL_DEREGISTERED(),
    _emit_tool_name_payload(name));
    return 0;
}

# Register an MCP prompt + its generator handler. Lazily stands up the
# dispatcher's PromptRegistry on first call — which is also what flips the
# `prompts` capability on at initialize (see _build_capabilities). Prompt
# names are freeform (no project_tool underscore convention). Returns 0.
fn dispatcher_register_prompt(d, prompt_def, handler_fp) {
    var preg = dispatcher_prompts(d);
    if (preg == 0) {
        preg = prompt_registry_new();
        dispatcher_set_prompts(d, preg);
    }
    prompt_registry_register(preg, prompt_def, handler_fp);
    return 0;
}

# Register an MCP resource + its read handler. Lazily stands up the
# dispatcher's ResourceRegistry on first call — which is also what flips the
# `resources` capability on at initialize (see _build_capabilities).
# Returns 0.
fn dispatcher_register_resource(d, resource_def, handler_fp) {
    var rreg = dispatcher_resources(d);
    if (rreg == 0) {
        rreg = resource_registry_new();
        dispatcher_set_resources(d, rreg);
    }
    resource_registry_register(rreg, resource_def, handler_fp);
    return 0;
}

# ================================================================
# JSON helpers — escape, build literals
# ================================================================

# Append `cstr` to sb, JSON-escaping " \ and control chars.
fn _json_emit_escaped(sb, cstr) {
    if (cstr == 0) { return 0; }
    var i = 0;
    while (1 == 1) {
        var c = load8(cstr + i);
        if (c == 0) { return 0; }
        if (c == 34) { str_builder_add_cstr(sb, "\\\""); }
        elif (c == 92) { str_builder_add_cstr(sb, "\\\\"); }
        elif (c == 10) { str_builder_add_cstr(sb, "\\n"); }
        elif (c == 13) { str_builder_add_cstr(sb, "\\r"); }
        elif (c == 9) { str_builder_add_cstr(sb, "\\t"); }
        else {
            var one[2];
            store8(&one, c);
            store8(&one + 1, 0);
            str_builder_add_cstr(sb, &one);
        }
        i = i + 1;
    }
    return 0;
}

# Append "key":"value" (value JSON-escaped). Caller responsible for commas.
fn _json_emit_str_field(sb, key, value) {
    str_builder_add_cstr(sb, "\"");
    str_builder_add_cstr(sb, key);
    str_builder_add_cstr(sb, "\":\"");
    _json_emit_escaped(sb, value);
    str_builder_add_cstr(sb, "\"");
    return 0;
}

# Append "key":raw  where raw is already JSON-formatted.
fn _json_emit_raw_field(sb, key, raw) {
    str_builder_add_cstr(sb, "\"");
    str_builder_add_cstr(sb, key);
    str_builder_add_cstr(sb, "\":");
    str_builder_add_cstr(sb, raw);
    return 0;
}

# Build a JSON object representation of a ToolSchema.
fn _emit_schema(sb, schema) {
    str_builder_add_cstr(sb, "{\"type\":\"");
    var t = schema_type(schema);
    if (t != 0) { _json_emit_escaped(sb, t); }
    str_builder_add_cstr(sb, "\"");

    var props = schema_properties(schema);
    if (props != 0 && vec_len(props) > 0) {
        str_builder_add_cstr(sb, ",\"properties\":{");
        var n = vec_len(props);
        var i = 0;
        while (i < n) {
            if (i > 0) { str_builder_add_cstr(sb, ","); }
            var p = vec_get(props, i);
            str_builder_add_cstr(sb, "\"");
            _json_emit_escaped(sb, schema_prop_key(p));
            str_builder_add_cstr(sb, "\":");
            str_builder_add_cstr(sb, schema_prop_value(p));
            i = i + 1;
        }
        str_builder_add_cstr(sb, "}");
    }

    var req = schema_required(schema);
    if (req != 0 && vec_len(req) > 0) {
        str_builder_add_cstr(sb, ",\"required\":[");
        var nr = vec_len(req);
        var ri = 0;
        while (ri < nr) {
            if (ri > 0) { str_builder_add_cstr(sb, ","); }
            str_builder_add_cstr(sb, "\"");
            _json_emit_escaped(sb, vec_get(req, ri));
            str_builder_add_cstr(sb, "\"");
            ri = ri + 1;
        }
        str_builder_add_cstr(sb, "]");
    }
    str_builder_add_cstr(sb, "}");
    return 0;
}

# Append a single tri-state annotation hint as "key":true/false.
# `first` is 1 when no hint has been emitted yet (suppresses the leading
# comma); returns the updated `first` flag. HINT_UNSET emits nothing.
fn _emit_hint_field(sb, first, key, hint) {
    if (hint == HINT_UNSET) { return first; }
    if (first == 0) { str_builder_add_cstr(sb, ","); }
    str_builder_add_cstr(sb, "\"");
    str_builder_add_cstr(sb, key);
    if (hint == HINT_TRUE) { str_builder_add_cstr(sb, "\":true"); }
    else { str_builder_add_cstr(sb, "\":false"); }
    return 0;
}

# Append ,"annotations":{...} for a ToolDef's ToolAnnotations ptr.
# Emits nothing when `ann` is 0 or every hint is unset (so the leading
# comma is only produced when at least one hint is serialized). MCP
# 2025-11-25 ToolAnnotations: readOnlyHint/destructiveHint/idempotentHint/
# openWorldHint, each an optional boolean (skip when unset).
fn _emit_annotations(sb, ann) {
    if (ann == 0) { return 0; }
    var r = ann_read_only_hint(ann);
    var dd = ann_destructive_hint(ann);
    var idem = ann_idempotent_hint(ann);
    var ow = ann_open_world_hint(ann);
    if (r == HINT_UNSET && dd == HINT_UNSET && idem == HINT_UNSET && ow == HINT_UNSET) {
        return 0;
    }
    str_builder_add_cstr(sb, ",\"annotations\":{");
    var first = 1;
    first = _emit_hint_field(sb, first, "readOnlyHint", r);
    first = _emit_hint_field(sb, first, "destructiveHint", dd);
    first = _emit_hint_field(sb, first, "idempotentHint", idem);
    first = _emit_hint_field(sb, first, "openWorldHint", ow);
    str_builder_add_cstr(sb, "}");
    return 0;
}

# ================================================================
# Method handlers
# ================================================================

# Does bote emit `notifications/tools/list_changed` to the client?
#
# The registry emits internal EventSink topics (TOPIC_TOOL_REGISTERED /
# _DEREGISTERED) on register/deregister, but those go to bote's OWN event
# bus — they are NOT MCP client notifications. There is no server→client
# push path yet (dispatch is strictly request→response; the streamable SSE
# GET closes immediately), so we cannot deliver `notifications/tools/
# list_changed`. Advertising `listChanged:true` would make the client wait
# for notifications that never arrive, so we return 0 (⇒ omit the flag,
# which defaults to false). Flip this to 1 AND wire the notification
# together once a persistent push channel lands.
fn _server_emits_tool_list_changed() { return 0; }

# Append the MCP `capabilities` object advertised at initialize.
#
# Advertised keys are DERIVED from what bote actually implements, so we
# never advertise a capability we can't honor:
#   - `tools`: always — bote is a tool server (an empty registry is still
#     tool-capable). `listChanged` gated on _server_emits_tool_list_changed.
#   - `prompts`: advertised iff the dispatcher has a PromptRegistry (i.e. at
#     least one prompt was registered — see dispatcher_register_prompt).
#   - `resources`: advertised iff the dispatcher has a ResourceRegistry (see
#     dispatcher_register_resource). `subscribe`/`listChanged` omitted — no
#     server→client push path yet.
#   - `completions`: advertised iff a completion handler is set (see
#     dispatcher_set_completion).
#   - logging: NOT YET — it exists only to gate `notifications/message`
#     (server→client push), which is not wired; advertising it would promise
#     log messages that never arrive. Lands with the notification path.
#
# Version policy: every capability below exists across all supported
# protocol versions (2024-11-05 … 2025-11-25), so none is gated on the
# negotiated version. A version-exclusive capability would branch on the
# negotiated version passed in here.
fn _build_capabilities(sb, d) {
    str_builder_add_cstr(sb, "{\"tools\":{");
    if (_server_emits_tool_list_changed() == 1) {
        str_builder_add_cstr(sb, "\"listChanged\":true");
    }
    str_builder_add_cstr(sb, "}");
    if (dispatcher_prompts(d) != 0) {
        str_builder_add_cstr(sb, ",\"prompts\":{}");
    }
    if (dispatcher_resources(d) != 0) {
        str_builder_add_cstr(sb, ",\"resources\":{}");
    }
    if (dispatcher_completion(d) != 0) {
        str_builder_add_cstr(sb, ",\"completions\":{}");
    }
    str_builder_add_cstr(sb, "}");
    return 0;
}

# Build the initialize response result body.
fn _build_initialize_result(d, params_cstr) {
    var requested = jsonx_get_str(params_cstr, "protocolVersion");
    var negotiated = _mcp_latest_version();
    if (_mcp_is_supported(requested) == 1) { negotiated = requested; }

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"protocolVersion\":\"");
    str_builder_add_cstr(sb, negotiated);
    str_builder_add_cstr(sb, "\",\"capabilities\":");
    _build_capabilities(sb, d);
    str_builder_add_cstr(sb, ",\"serverInfo\":{\"name\":\"bote\",\"version\":\"");
    str_builder_add_cstr(sb, _bote_server_version());
    str_builder_add_cstr(sb, "\"}}");
    return str_data(str_builder_build(sb));
}

# Build the prompts/list response result body.
fn _build_prompts_list_result(preg) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"prompts\":[");
    var lst = prompt_registry_list(preg);
    var n = vec_len(lst);
    var i = 0;
    while (i < n) {
        if (i > 0) { str_builder_add_cstr(sb, ","); }
        var p = vec_get(lst, i);
        str_builder_add_cstr(sb, "{");
        _json_emit_str_field(sb, "name", prompt_def_name(p));
        var pd = prompt_def_description(p);
        if (pd != 0) {
            str_builder_add_cstr(sb, ",");
            _json_emit_str_field(sb, "description", pd);
        }
        var pargs = prompt_def_arguments(p);
        if (pargs != 0 && vec_len(pargs) > 0) {
            str_builder_add_cstr(sb, ",\"arguments\":[");
            var na = vec_len(pargs);
            var ai = 0;
            while (ai < na) {
                if (ai > 0) { str_builder_add_cstr(sb, ","); }
                var a = vec_get(pargs, ai);
                str_builder_add_cstr(sb, "{");
                _json_emit_str_field(sb, "name", prompt_arg_name(a));
                var ad = prompt_arg_description(a);
                if (ad != 0) {
                    str_builder_add_cstr(sb, ",");
                    _json_emit_str_field(sb, "description", ad);
                }
                if (prompt_arg_required(a) == 1) {
                    str_builder_add_cstr(sb, ",\"required\":true");
                }
                str_builder_add_cstr(sb, "}");
                ai = ai + 1;
            }
            str_builder_add_cstr(sb, "]");
        }
        str_builder_add_cstr(sb, "}");
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return str_data(str_builder_build(sb));
}

# Does tool `t` belong in a `profile`-filtered listing? A null profile means
# no filter was requested, so every tool matches (full listing, unchanged).
fn _tool_matches_profile(t, profile) {
    if (profile == 0) { return 1; }
    return tool_def_has_profile(t, profile);
}

# Build the tools/list response result body.
#
# `profile` (cstr or 0) is an OPTIONAL bote extension: when a client passes
# {"profile":"<tag>"} in tools/list params, only tools tagged with that
# profile are returned (exact-match). When absent (0), the full tool list is
# returned — byte-identical to pre-extension behavior.
fn _build_tools_list_result(reg, profile) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"tools\":[");
    var lst = registry_list(reg);
    var n = vec_len(lst);
    var i = 0;
    var emitted = 0;
    while (i < n) {
        var t = vec_get(lst, i);
        if (_tool_matches_profile(t, profile) == 0) {
            i = i + 1;
            continue;
        }
        if (emitted > 0) { str_builder_add_cstr(sb, ","); }
        emitted = emitted + 1;
        str_builder_add_cstr(sb, "{");
        _json_emit_str_field(sb, "name", tool_def_name(t));
        str_builder_add_cstr(sb, ",");
        _json_emit_str_field(sb, "description", tool_def_description(t));
        str_builder_add_cstr(sb, ",\"inputSchema\":");
        _emit_schema(sb, tool_def_input_schema(t));
        var v = tool_def_version(t);
        if (v != 0) {
            str_builder_add_cstr(sb, ",");
            _json_emit_str_field(sb, "version", v);
        }
        var dep = tool_def_deprecated(t);
        if (dep != 0) {
            str_builder_add_cstr(sb, ",");
            _json_emit_str_field(sb, "deprecated", dep);
        }
        _emit_annotations(sb, tool_def_annotations(t));
        str_builder_add_cstr(sb, "}");
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return str_data(str_builder_build(sb));
}

# Extract and validate the tool name from a tools/call request's params.
# Returns cstr (name) or 0; sets *err_out (BoteError ptr) on failure.
fn _extract_tool_name(params_cstr, err_out) {
    var name = jsonx_get_str(params_cstr, "name");
    if (name == 0 || strlen(name) == 0) {
        store64(err_out, bote_err_new(ERR_INVALID_PARAMS, "", "missing or empty 'name' field"));
        return 0;
    }
    store64(err_out, 0);
    return name;
}

# Build the resources/list response result body.
fn _build_resources_list_result(rreg) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"resources\":[");
    var lst = resource_registry_list(rreg);
    var n = vec_len(lst);
    var i = 0;
    while (i < n) {
        if (i > 0) { str_builder_add_cstr(sb, ","); }
        var r = vec_get(lst, i);
        str_builder_add_cstr(sb, "{");
        _json_emit_str_field(sb, "uri", resource_def_uri(r));
        str_builder_add_cstr(sb, ",");
        _json_emit_str_field(sb, "name", resource_def_name(r));
        var rd = resource_def_description(r);
        if (rd != 0) {
            str_builder_add_cstr(sb, ",");
            _json_emit_str_field(sb, "description", rd);
        }
        var rm = resource_def_mime_type(r);
        if (rm != 0) {
            str_builder_add_cstr(sb, ",");
            _json_emit_str_field(sb, "mimeType", rm);
        }
        str_builder_add_cstr(sb, "}");
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# dispatch — main entry
# ================================================================
#
# Returns a JsonRpcResponse ptr, or 0 if the request is a notification.

fn dispatcher_dispatch(d, request, claims) {
    if (req_is_notification(request) == 1) { return 0; }

    var id = req_id(request);
    var method = req_method(request);
    var params = req_params(request);
    var reg = dispatcher_registry(d);
    var handlers = dispatcher_handlers(d);

    if (streq(method, "initialize") == 1) {
        return resp_success(id, _build_initialize_result(d, params));
    }

    if (streq(method, "tools/list") == 1) {
        var lprofile = 0;
        if (params != 0) { lprofile = jsonx_get_str(params, "profile"); }
        return resp_success(id, _build_tools_list_result(reg, lprofile));
    }

    # prompts/* only when the prompts capability is enabled (a PromptRegistry
    # is present). Otherwise fall through to method-not-found (-32601), which
    # matches the un-advertised capability.
    if (streq(method, "prompts/list") == 1 && dispatcher_prompts(d) != 0) {
        return resp_success(id, _build_prompts_list_result(dispatcher_prompts(d)));
    }

    if (streq(method, "prompts/get") == 1 && dispatcher_prompts(d) != 0) {
        var pname = jsonx_get_str(params, "name");
        if (pname == 0 || strlen(pname) == 0) {
            var pe = bote_err_new(ERR_INVALID_PARAMS, "", "missing or empty 'name' field");
            return resp_error(id, bote_err_rpc_code(bote_err_tag(pe)), str_data(bote_err_format(pe)));
        }
        var phandler = prompt_registry_handler(dispatcher_prompts(d), pname);
        if (phandler == 0) {
            var nf = bote_err_new(ERR_INVALID_PARAMS, pname, "prompt not found");
            return resp_error(id, bote_err_rpc_code(bote_err_tag(nf)), str_data(bote_err_format(nf)));
        }
        var pargs = jsonx_get_raw(params, "arguments");
        if (pargs == 0) { pargs = "{}"; }
        var presult = fncall2(phandler, pargs, claims);
        if (presult == 0) { presult = "{\"messages\":[]}"; }
        return resp_success(id, presult);
    }

    # resources/* only when the resources capability is enabled (a
    # ResourceRegistry is present). Otherwise fall through to -32601.
    if (streq(method, "resources/list") == 1 && dispatcher_resources(d) != 0) {
        return resp_success(id, _build_resources_list_result(dispatcher_resources(d)));
    }

    if (streq(method, "resources/read") == 1 && dispatcher_resources(d) != 0) {
        var ruri = jsonx_get_str(params, "uri");
        if (ruri == 0 || strlen(ruri) == 0) {
            var re = bote_err_new(ERR_INVALID_PARAMS, "", "missing or empty 'uri' field");
            return resp_error(id, bote_err_rpc_code(bote_err_tag(re)), str_data(bote_err_format(re)));
        }
        var rhandler = resource_registry_handler(dispatcher_resources(d), ruri);
        if (rhandler == 0) {
            var rnf = bote_err_new(ERR_INVALID_PARAMS, ruri, "resource not found");
            return resp_error(id, bote_err_rpc_code(bote_err_tag(rnf)), str_data(bote_err_format(rnf)));
        }
        var rresult = fncall2(rhandler, ruri, claims);
        if (rresult == 0) { rresult = "{\"contents\":[]}"; }
        return resp_success(id, rresult);
    }

    # completion/complete only when a completion handler is set. The handler
    # receives the raw params ({ref, argument, ...}) and returns the full
    # {"completion":{"values":[...]}} body. Otherwise fall through to -32601.
    if (streq(method, "completion/complete") == 1 && dispatcher_completion(d) != 0) {
        var cparams = params;
        if (cparams == 0) { cparams = "{}"; }
        var cresult = fncall2(dispatcher_completion(d), cparams, claims);
        if (cresult == 0) { cresult = "{\"completion\":{\"values\":[]}}"; }
        return resp_success(id, cresult);
    }

    if (streq(method, "tools/call") == 1) {
        var err_slot[8];
        store64(&err_slot, 0);
        var name = _extract_tool_name(params, &err_slot);
        if (name == 0) {
            var ne = load64(&err_slot);
            return resp_error(id, bote_err_rpc_code(bote_err_tag(ne)), str_data(bote_err_format(ne)));
        }

        # Optional: version negotiation
        var ver = jsonx_get_str(params, "version");
        if (ver != 0 && registry_get_versioned(reg, name, ver) == 0) {
            var sb = str_builder_new();
            str_builder_add_cstr(sb, "version '");
            str_builder_add_cstr(sb, ver);
            str_builder_add_cstr(sb, "' not found");
            var verr = bote_err_new(ERR_INVALID_PARAMS, name, str_data(str_builder_build(sb)));
            return resp_error(id, bote_err_rpc_code(bote_err_tag(verr)), str_data(bote_err_format(verr)));
        }

        # Extract arguments (default to "{}" if absent), caller_id (optional)
        var args = jsonx_get_raw(params, "arguments");
        if (args == 0) { args = "{}"; }
        var caller_id = jsonx_get_str(params, "caller_id");

        # Validate
        var verr2 = registry_validate_params(reg, name, args);
        if (verr2 != 0) {
            return resp_error(id, bote_err_rpc_code(bote_err_tag(verr2)), str_data(bote_err_format(verr2)));
        }

        # Deprecation event (best-effort; never blocks dispatch)
        var t = registry_get(reg, name);
        if (t != 0) {
            var dep = tool_def_deprecated(t);
            if (dep != 0) {
                var ds = str_builder_new();
                str_builder_add_cstr(ds, "{\"tool_name\":\"");
                _json_emit_escaped(ds, name);
                str_builder_add_cstr(ds, "\",\"message\":\"");
                _json_emit_escaped(ds, dep);
                str_builder_add_cstr(ds, "\"}");
                event_sink_publish(dispatcher_event_sink(d), TOPIC_TOOL_DEPRECATED(),
                str_data(str_builder_build(ds)));
            }
        }

        # Dispatch with timing + audit + event hooks
        var t_start = clock_now_ns();
        if (map_has(handlers, name) == 0) {
            var dur_nh = (clock_now_ns() - t_start) / 1000000;
            var nf = bote_err_new(ERR_TOOL_NOT_FOUND, name, 0);
            var msg_nh = str_data(bote_err_format(nf));
            var ev_nh = tool_call_event_new(name, dur_nh, 0, msg_nh, caller_id);
            audit_sink_log(dispatcher_audit_sink(d), ev_nh);
            event_sink_publish(dispatcher_event_sink(d), TOPIC_TOOL_FAILED(),
            tool_call_event_to_json(ev_nh));
            return resp_error(id, bote_err_rpc_code(bote_err_tag(nf)), msg_nh);
        }
        var fp = map_get(handlers, name);
        # 2.0 ABI: fncall2 with claims (always 0 in 2.0; populated in 2.x)
        var result = fncall2(fp, args, claims);
        var dur_ms = (clock_now_ns() - t_start) / 1000000;
        if (result == 0) { result = "null"; }
        var ev_ok = tool_call_event_new(name, dur_ms, 1, 0, caller_id);
        audit_sink_log(dispatcher_audit_sink(d), ev_ok);
        event_sink_publish(dispatcher_event_sink(d), TOPIC_TOOL_COMPLETED(),
        tool_call_event_to_json(ev_ok));
        return resp_success(id, result);
    }

    # Unknown method — JSON-RPC §5.1
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "method not found: ");
    str_builder_add_cstr(sb, method);
    return resp_error(id, 0 - 32601, str_data(str_builder_build(sb)));
}
