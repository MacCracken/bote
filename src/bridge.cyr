# bote::bridge — TypeScript-bridge HTTP transport with CORS + MCP envelope wrap
# Mirrors rust-old/src/bridge.rs.
#
# Reuses transport_http.cyr for socket/parsing/response plumbing. Adds:
#   - POST /            — JSON-RPC dispatch, wraps tools/call results in MCP envelope
#   - OPTIONS /         — CORS preflight (204 + headers)
#   - GET /health       — liveness check ("ok")
#   - CORS headers on every response
#
# An MCP envelope for a tool result looks like:
#   { "content": [{"type":"text","text":"..."}] }
# wrap_tool_result passes through if the value already has a "content" array.

# ================================================================
# BridgeConfig (48 bytes):
#   +0  bind_addr        i64 (network-order IPv4)
#   +8  port             i64
#   +16 allowed_origins  vec of cstrs or 0 (0 / empty / contains "*" → wildcard)
#   +24 dispatcher       Dispatcher ptr (set by transport_bridge_run)
#   +32 bearer_validator fn ptr (token, ctx) → claims | 0, or 0 to disable
#   +40 bearer_ctx       i64 ctx passed verbatim to validator
# ================================================================

fn bridge_config_new(addr, port) {
    var c = alloc(48);
    store64(c, addr);
    store64(c + 8, port);
    store64(c + 16, 0);
    store64(c + 24, 0);
    store64(c + 32, 0);
    store64(c + 40, 0);
    return c;
}

fn bridge_config_with_origins(c, vec)        { store64(c + 16, vec); return c; }
fn bridge_config_with_dispatcher(c, d)       { store64(c + 24, d);   return c; }
fn bridge_config_with_bearer_validator(c, fp, ctx) {
    store64(c + 32, fp);
    store64(c + 40, ctx);
    return c;
}
fn bridge_config_addr(c)             { return load64(c); }
fn bridge_config_port(c)             { return load64(c + 8); }
fn bridge_config_origins(c)          { return load64(c + 16); }
fn bridge_config_dispatcher(c)       { return load64(c + 24); }
fn bridge_config_bearer_validator(c) { return load64(c + 32); }
fn bridge_config_bearer_ctx(c)       { return load64(c + 40); }

# ================================================================
# Envelope wrappers
# ================================================================

# Wrap a raw tool result cstr (raw JSON literal) into the MCP envelope
# unless it already has a top-level `content` array.
#
# Three input shapes, three behaviours:
#   1. Object with a `content` array → pass through verbatim. Used by
#      handlers that pre-shape their own envelope.
#   2. Object with a `type` field (a single MCP content block, possibly
#      carrying annotations) → lift into a 1-element content array.
#      This preserves any block-level annotations the handler attached
#      via `content_with_annotations` (1.9.6); the block is spliced
#      verbatim rather than re-stringified as a `text` payload.
#   3. Anything else (scalar, string, non-block object, array) → wrap
#      the JSON-escaped text under a synthesised `text` block.
fn wrap_tool_result(result) {
    if (result == 0) { result = "null"; }
    if (jsonx_is_object(result) == 1) {
        # (1) Passthrough — has a `content` array.
        if (jsonx_has(result, "content") == 1) {
            var c = jsonx_get_raw(result, "content");
            if (c != 0) {
                var ci = 0;
                var clen = strlen(c);
                while (ci < clen) {
                    var cc = load8(c + ci);
                    if (cc == 32 || cc == 9 || cc == 10 || cc == 13) { ci = ci + 1; }
                    else {
                        if (cc == 91) { return result; }
                        ci = clen;
                    }
                }
            }
        }
        # (2) Single content block — lift into the envelope without
        # decomposing. Preserves annotations (1.9.6 → 2.7.0).
        if (jsonx_has(result, "type") == 1) {
            var sb_lift = str_builder_new();
            str_builder_add_cstr(sb_lift, "{\"content\":[");
            str_builder_add_cstr(sb_lift, result);
            str_builder_add_cstr(sb_lift, "]}");
            return str_data(str_builder_build(sb_lift));
        }
    }
    # (3) Else build a synthesised text-block envelope. The text payload
    # is the raw JSON, JSON-escaped.
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"content\":[{\"type\":\"text\",\"text\":\"");
    _json_emit_escaped(sb, result);
    str_builder_add_cstr(sb, "\"}]}");
    return str_data(str_builder_build(sb));
}

# Wrap an error message into an MCP envelope with isError: true.
fn wrap_error_result(message) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"content\":[{\"type\":\"text\",\"text\":\"");
    if (message != 0) { _json_emit_escaped(sb, message); }
    str_builder_add_cstr(sb, "\"}],\"isError\":true}");
    return str_data(str_builder_build(sb));
}

# ================================================================
# Bridge-aware message processor
# ================================================================
#
# Like codec_process_message, but for tools/call responses:
#   - success: wrap result in MCP envelope (passthrough if already shaped)
#   - error:   convert to success(wrap_error_result(message)) per SY contract
#              (JSON-RPC 2.0 forbids both result+error; SY wants the envelope)
# Other methods (initialize, tools/list, batch elements) pass through unchanged.

fn _bridge_process_single(line, dispatcher, claims) {
    var req = codec_parse_request(line);
    if (req == 0) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "invalid request: malformed object");
        return codec_serialize_response(resp_error("null", 0 - 32600, str_data(str_builder_build(sb))));
    }
    if (streq(req_jsonrpc(req), "2.0") == 0) {
        var sb2 = str_builder_new();
        str_builder_add_cstr(sb2, "unsupported jsonrpc version '");
        str_builder_add_cstr(sb2, req_jsonrpc(req));
        str_builder_add_cstr(sb2, "'");
        var id_v = req_id(req);
        if (id_v == 0) { id_v = "null"; }
        return codec_serialize_response(resp_error(id_v, 0 - 32600, str_data(str_builder_build(sb2))));
    }
    var resp = dispatcher_dispatch(dispatcher, req, claims);
    if (resp == 0) { return 0; }

    # Bridge wrapping only applies to tools/call.
    if (streq(req_method(req), "tools/call") == 1) {
        var success_result = resp_result(resp);
        var err_obj = resp_error_obj(resp);
        if (success_result != 0) {
            var wrapped = wrap_tool_result(success_result);
            return codec_serialize_response(resp_success(resp_id(resp), wrapped));
        }
        if (err_obj != 0) {
            var wrapped_err = wrap_error_result(rpc_err_message(err_obj));
            return codec_serialize_response(resp_success(resp_id(resp), wrapped_err));
        }
    }
    return codec_serialize_response(resp);
}

fn bridge_process_message(input, dispatcher, claims) {
    if (input == 0) { return _cdc_parse_error("empty input"); }
    var len = strlen(input);
    var i = _cdc_skip_ws(input, len, 0);
    if (i >= len) { return _cdc_parse_error("empty input"); }
    var first = load8(input + i);

    # Batch arrays defer to the codec (no per-element wrapping; the bridge
    # contract is single-tool-call → MCP envelope).
    if (first == 91) { return codec_process_message(input, dispatcher, claims); }
    if (first == 123) { return _bridge_process_single(input, dispatcher, claims); }
    return _cdc_invalid_request("expected object or array");
}

# ================================================================
# CORS header builder
# ================================================================
#
# Returns a cstr of CORS headers (each line ending in CRLF) ready to splice
# into _http_send_* via the extra_headers slot. allowed_origins is a vec or 0.

fn _bridge_cors_origin(allowed_origins, request_origin) {
    if (allowed_origins == 0) { return "*"; }
    var n = vec_len(allowed_origins);
    var i = 0;
    while (i < n) {
        if (streq(vec_get(allowed_origins, i), "*") == 1) { return "*"; }
        i = i + 1;
    }
    if (n == 0) { return "*"; }
    if (request_origin != 0) {
        var j = 0;
        while (j < n) {
            if (streq(vec_get(allowed_origins, j), request_origin) == 1) {
                return request_origin;
            }
            j = j + 1;
        }
    }
    # 1.9.6 audit M3: don't echo allowed_origins[0] on miss. That would
    # leak the first allowed origin to any cross-origin requester.
    # `null` is a spec-compliant value — browser will block the response.
    return "null";
}

fn _bridge_cors_headers(allowed_origins, request_origin) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "Access-Control-Allow-Origin: ");
    str_builder_add_cstr(sb, _bridge_cors_origin(allowed_origins, request_origin));
    str_builder_add_cstr(sb, "\r\nAccess-Control-Allow-Methods: POST, GET, OPTIONS\r\n");
    str_builder_add_cstr(sb, "Access-Control-Allow-Headers: content-type\r\n");
    return str_data(str_builder_build(sb));
}

fn _bridge_send_health(cfd, allowed_origins, request_origin) {
    var cors = _bridge_cors_headers(allowed_origins, request_origin);
    sandhi_server_send_response(cfd, HTTP_OK, "OK", "text/plain", "ok", 2, cors);
    return 0;
}

# ================================================================
# Per-connection handler — invoked per connection by sandhi_server_run
# ================================================================
#
# BridgeConfig now carries the dispatcher in the +24 slot (see
# bridge_config_with_dispatcher below). We pass the config as ctx.

fn _bridge_handle(config, cfd, buf, n) {
    var allowed_origins = bridge_config_origins(config);
    var dispatcher      = bridge_config_dispatcher(config);

    var method = sandhi_server_get_method(buf, n);
    var path   = sandhi_server_get_path(buf, n);
    var origin = sandhi_server_find_header(buf, n, "Origin");
    var cors   = _bridge_cors_headers(allowed_origins, origin);

    # OPTIONS preflight
    if (streq(method, "OPTIONS") == 1) {
        http_send_204(cfd, cors);
        return 0;
    }
    # GET /health
    if (streq(method, "GET") == 1) {
        if (streq(sandhi_server_path_only(path), "/health") == 1) {
            _bridge_send_health(cfd, allowed_origins, origin);
            return 0;
        }
        sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
        return 0;
    }
    # Anything other than POST is rejected.
    if (streq(method, "POST") == 0) {
        sandhi_server_send_status(cfd, HTTP_METHOD_NOT_ALLOWED, "Method Not Allowed");
        return 0;
    }
    # Only "/" is the bridge endpoint.
    if (streq(sandhi_server_path_only(path), "/") == 0) {
        sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
        return 0;
    }

    # Reject ambiguous Transfer-Encoding (HTTP smuggling guard, RFC 9112)
    if (sandhi_server_find_header(buf, n, "Transfer-Encoding") != 0) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request"); return 0;
    }
    # Bearer auth (no-op when no validator configured)
    var claims_slot[8]; store64(&claims_slot, 0);
    if (auth_bearer_check(cfd, buf, n,
                          bridge_config_bearer_validator(config),
                          bridge_config_bearer_ctx(config),
                          &claims_slot) != 0) { return 0; }

    # 413 cap on oversized declared bodies (audit M1). 60 KB headroom
    # keeps us inside the 64 KB recv buffer with room for headers.
    var declared_clen = sandhi_server_content_length(buf, n);
    if (declared_clen > 61440) {
        sandhi_server_send_status(cfd, HTTP_PAYLOAD_TOO_LARGE, "Payload Too Large"); return 0;
    }

    var body_off = sandhi_server_body_offset(buf, n);
    if (body_off < 0 || body_off > n) {
        sandhi_server_send_status(cfd, HTTP_BAD_REQUEST, "Bad Request");
        return 0;
    }
    var clen = sandhi_server_content_length(buf, n);
    if (clen <= 0) { clen = n - body_off; }
    if (clen < 0) { clen = 0; }
    if (clen > n - body_off) { clen = n - body_off; }
    var body = alloc(clen + 1);
    memcpy(body, buf + body_off, clen);
    store8(body + clen, 0);

    var resp = bridge_process_message(body, dispatcher, load64(&claims_slot));
    if (resp == 0) {
        http_send_204(cfd, cors);
        return 0;
    }
    sandhi_server_send_response(cfd, HTTP_OK, "OK", "application/json",
                       resp, strlen(resp), cors);
    return 0;
}

# ================================================================
# Server entry — defers to stdlib sandhi_server_run
# ================================================================

fn transport_bridge_run(dispatcher, config) {
    bridge_config_with_dispatcher(config, dispatcher);
    return sandhi_server_run(bridge_config_addr(config),
                           bridge_config_port(config),
                           &_bridge_handle,
                           config);
}
